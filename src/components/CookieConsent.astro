---
// Opt-out cookie notice: analytics run by default (Consent Mode default set in
// Base.astro <head>); Decline updates Consent Mode to denied and persists the
// choice, which the Base.astro default honors on later visits.
---
<div class="cc" id="cookie-consent" role="dialog" aria-label="Cookie consent" hidden>
  <p class="cc__text">
    We use privacy-friendly analytics to improve this site — no ads, no selling your data.
    See our <a href="/privacy">Privacy Policy</a>.
  </p>
  <div class="cc__actions">
    <button type="button" class="btn btn--ghost cc__btn" data-cc="decline">Decline</button>
    <button type="button" class="btn cc__btn" data-cc="accept">Accept</button>
  </div>
</div>

<style>
  .cc {
    position: fixed; left: 1rem; right: 1rem; bottom: 1rem; z-index: 70;
    max-width: 42rem; margin-inline: auto;
    background: var(--color-cream-card);
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 1rem 1.1rem;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem 1.2rem;
  }
  .cc[hidden] { display: none; }
  .cc__text { font-size: 0.95rem; color: var(--color-ink-soft); line-height: 1.55; flex: 1 1 18rem; }
  .cc__text a { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }
  .cc__actions { display: flex; gap: 0.6rem; margin-left: auto; }
  .cc__btn { padding: 0.72em 1.15em; font-size: 0.98rem; }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('cookie-consent');
    if (!el) return;
    var stored = null;
    try { stored = localStorage.getItem('jth_consent'); } catch (e) {}
    if (!stored) el.hidden = false;
    function choose(v) {
      try { localStorage.setItem('jth_consent', v); } catch (e) {}
      if (typeof window.gtag === 'function') {
        window.gtag('consent', 'update', { analytics_storage: v === 'granted' ? 'granted' : 'denied' });
      }
      el.hidden = true;
    }
    el.querySelectorAll('[data-cc]').forEach(function (b) {
      b.addEventListener('click', function () {
        choose(b.getAttribute('data-cc') === 'accept' ? 'granted' : 'denied');
      });
    });
  })();
</script>
