---
import '@fontsource/sigmar/400.css';
import '@fontsource/volkhov/400.css';
import '@fontsource/volkhov/400-italic.css';
import '@fontsource/volkhov/700.css';
import '@fontsource/volkhov/700-italic.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Joshua Tree Health — Design Lab',
  description = 'Internal visual-system review for Joshua Tree Health.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFAF3" />
    <title>{title}</title>
    <link rel="canonical" href="https://www.jtreehealth.com/design-lab/" />
    <link rel="icon" href="/brand-v2/logos/submark-forest.svg" type="image/svg+xml" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Batica Sans';
    src: url('/brand-v2/fonts/batica-sans-regular.ttf') format('truetype');
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  @font-face {
    font-family: 'Batica Sans';
    src: url('/brand-v2/fonts/batica-sans-bold.ttf') format('truetype');
    font-style: normal;
    font-weight: 700;
    font-display: swap;
  }

  /* Current (live-site) faces — kept alongside the proposed faces below so the
     A/B toggle on the design-lab page can flip instantly, with no reload. */
  @font-face {
    font-family: 'Misoka Heavy';
    src: url('/brand-v2/fonts/misoka-heavy.ttf') format('truetype');
    font-style: normal;
    font-weight: 900;
    font-display: swap;
  }
  @font-face {
    font-family: 'Fraunces SuperSoft';
    src: url('/brand-v2/fonts/fraunces-supersoft-regular.ttf') format('truetype');
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }
  @font-face {
    font-family: 'Fraunces SuperSoft';
    src: url('/brand-v2/fonts/fraunces-supersoft-semibold.ttf') format('truetype');
    font-style: normal;
    font-weight: 600;
    font-display: swap;
  }

  :root {
    --jth-forest: #1e3d34;
    --jth-deep-sage: #2c5f52;
    --jth-mist-sage: #8fbfb0;
    --jth-lime: #b8e04a;
    --jth-lavender: #a89fd8;
    --jth-cream: #fffaf3;
    --jth-paper: #f7f2e8;
    --jth-ink-soft: #4d625b;
    --jth-line: rgba(30, 61, 52, 0.18);
    --jth-display: 'Batica Sans', Arial, sans-serif;
    --jth-ui: 'Batica Sans', Arial, sans-serif;

    /* --- Typography A/B test ---------------------------------------------
       Two named font pairings for the impact (headings/nav/buttons) and
       editorial (body) roles. `data-typeface` on <html> selects which one
       is live; see the toggle script on the design-lab page. Defaults to
       the proposed pairing. --jth-ui / --jth-display (Batica Sans) are
       intentionally excluded from the test so the toggle control itself
       and the page's main headline stay stable while switching. --- */
    --jth-impact-current: 'Misoka Heavy', 'Batica Sans', Arial, sans-serif;
    --jth-editorial-current: 'Fraunces SuperSoft', Georgia, serif;
    --jth-impact-proposed: 'Sigmar', 'Batica Sans', Arial, sans-serif;
    --jth-editorial-proposed: 'Volkhov', Georgia, serif;

    --jth-impact: var(--jth-impact-proposed);
    --jth-editorial: var(--jth-editorial-proposed);
    --jth-body: var(--jth-editorial);
  }

  html[data-typeface='current'] {
    --jth-impact: var(--jth-impact-current);
    --jth-editorial: var(--jth-editorial-current);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; background: var(--jth-cream); overflow-x: hidden; }
  body {
    margin: 0;
    min-width: 320px;
    background: var(--jth-cream);
    color: var(--jth-forest);
    font-family: var(--jth-body);
    font-size: 17px;
    line-height: 1.58;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  img { display: block; max-width: 100%; }
  a { color: inherit; }
  button, a { -webkit-tap-highlight-color: transparent; }
  ::selection { background: var(--jth-lime); color: var(--jth-forest); }

  .skip {
    position: fixed;
    z-index: 100;
    left: 1rem;
    top: 1rem;
    padding: .7rem 1rem;
    background: var(--jth-forest);
    color: var(--jth-cream);
    transform: translateY(-160%);
    transition: transform 180ms ease;
  }
  .skip:focus { transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
