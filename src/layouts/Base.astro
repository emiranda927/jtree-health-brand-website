---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/sora';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/caveat';
import '../styles/global.css';
import CrisisBar from '../components/CrisisBar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string | URL;
  robots?: string;
  ogImage?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
}

const {
  title = 'Joshua Tree Health — Teen PHP & IOP | Apex, NC',
  description = 'PHP and IOP care for adolescents ages 10–17 in Apex, NC, grounded in DBT, nervous system regulation, and family involvement.',
  canonical: canonicalOverride,
  robots: robotsOverride,
  ogImage = '/og-image.png?v=20260718',
  ogImageAlt = 'Joshua Tree Health logo with a custom growth illustration',
  jsonLd,
  bodyClass = '',
} = Astro.props;

const site = Astro.site ?? 'https://www.jtreehealth.com';
const canonical = canonicalOverride
  ? new URL(canonicalOverride.toString(), site)
  : new URL(Astro.url.pathname, site);
const ogImageUrl = new URL(ogImage, site).href;
const isPreview = process.env.VERCEL_ENV === 'preview';
const analyticsEnabled = import.meta.env.PROD && !isPreview;
const robots = robotsOverride ?? (isPreview ? 'noindex, nofollow' : 'index, follow, max-image-preview:large');
const extraSchema = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const seoGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://www.jtreehealth.com/#website',
      url: 'https://www.jtreehealth.com/',
      name: 'Joshua Tree Health',
      publisher: { '@id': 'https://www.jtreehealth.com/#organization' },
      inLanguage: 'en-US',
    },
    {
      '@type': ['Organization', 'MedicalBusiness', 'MentalHealthCenter'],
      '@id': 'https://www.jtreehealth.com/#organization',
      name: 'Joshua Tree Health',
      alternateName: 'Simply Teens Outpatient',
      description: 'Adolescent PHP and IOP mental health care in Apex, North Carolina.',
      url: 'https://www.jtreehealth.com/',
      logo: 'https://www.jtreehealth.com/brand-v2/logos/primary-forest.svg',
      image: ogImageUrl,
      telephone: '+1-919-335-5053',
      email: 'admissions@jtreehealth.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '800 West Williams St, Suite 203',
        addressLocality: 'Apex',
        addressRegion: 'NC',
        postalCode: '27502',
        addressCountry: 'US',
      },
      areaServed: ['Apex', 'Cary', 'Raleigh', 'Durham', 'Chapel Hill', 'Wake County'],
      medicalSpecialty: 'Psychiatric',
    },
    {
      '@type': 'WebPage',
      '@id': `${canonical.href}#webpage`,
      url: canonical.href,
      name: title,
      description,
      isPartOf: { '@id': 'https://www.jtreehealth.com/#website' },
      about: { '@id': 'https://www.jtreehealth.com/#organization' },
      inLanguage: 'en-US',
    },
    ...extraSchema,
  ],
};

// Public config (env-driven; safe to expose). Defaults match the live setup.
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || 'GTM-WGCMNLXH';
const INQUIRY_API = import.meta.env.PUBLIC_INQUIRY_API_URL || 'https://api.jtreehealth.com/api/inquiry';
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
const jtreeConfig = {
  apiUrl: INQUIRY_API,
  careersApiUrl: INQUIRY_API.replace(/\/api\/inquiry$/, '/api/careers/apply'),
  thankYouUrl: '/thank-you/',
  turnstileSiteKey: TURNSTILE_SITE_KEY,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <link rel="canonical" href={canonical.href} />

    <link rel="icon" type="image/svg+xml" href="/brand-v2/logos/submark-forest.svg?v=20260719" />
    <link rel="icon" type="image/png" sizes="32x32" href="/brand-v2/logos/favicon-32.png?v=20260719" />
    <link rel="icon" type="image/png" sizes="64x64" href="/brand-v2/logos/favicon-64.png?v=20260719" />
    <link rel="apple-touch-icon" href="/brand-v2/logos/apple-touch-icon.png?v=20260719" />
    <meta name="theme-color" content="#183b2e" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Joshua Tree Health" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={canonical.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(seoGraph).replace(/</g, '\\u003c')} is:inline />

    <!-- No-FOUC: flag JS + reduced-motion before first paint -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.add('has-js');
        try {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            d.classList.add('reduced-motion');
          }
        } catch (e) {}
      })();
    </script>

    <script is:inline set:html={`window.JTREE_CONFIG=${JSON.stringify(jtreeConfig)};`} />

    {analyticsEnabled && (
      <>
        <!-- Consent Mode v2 default: analytics ON unless the visitor has declined (opt-out).
             Ad storage/personalization stay denied — we run no ads. -->
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];window.gtag=window.gtag||function(){window.dataLayer.push(arguments);};var c=null;try{c=localStorage.getItem('jth_consent');}catch(e){}window.gtag('consent','default',{ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',analytics_storage:c==='denied'?'denied':'granted'});`} />
        <!-- Google Tag Manager -->
        <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${GTM_ID}');`} />
      </>
    )}
  </head>
  <body class={bodyClass}>
    {analyticsEnabled && <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />}
    <a href="#main" class="skip-link">Skip to content</a>
    <CrisisBar />
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <div class="grain grain--fixed" aria-hidden="true"></div>
    <CookieConsent />

    <script>
      import { initMotion } from '../lib/motion';
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => initMotion(), { once: true });
      } else {
        initMotion();
      }
    </script>

    {analyticsEnabled && (
      <script is:inline>
        document.addEventListener('click', function (event) {
          var link = event.target instanceof Element ? event.target.closest('a[href]') : null;
          if (!link) return;
          var href = link.getAttribute('href') || '';
          var eventName = '';
          if (href.indexOf('tel:') === 0) eventName = 'click_to_call';
          else if (href === '/insurance' || href.indexOf('/insurance?') === 0) eventName = 'insurance_cta';
          else if (location.pathname === '/refer' && href === '/contact') eventName = 'referral_cta';
          if (!eventName) return;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: eventName, page_path: location.pathname });
        });
      </script>
    )}

    <style is:global>
      .skip-link {
        position: fixed;
        top: 0.5rem;
        left: 0.5rem;
        z-index: 100;
        padding: 0.6rem 1rem;
        background: var(--color-deep-green);
        color: var(--color-cream);
        border-radius: var(--radius-pill);
        font-size: 1rem;
        font-weight: 600;
        transform: translateY(-150%);
        transition: transform var(--dur) var(--ease-soft);
      }
      .skip-link:focus { transform: translateY(0); }
    </style>
  </body>
</html>
