---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const terms = [
  {
    t: 'Copay',
    b: 'A flat amount you pay per session or per day of treatment, set by your insurance plan.',
  },
  {
    t: 'Coinsurance',
    b: 'A percentage of the service cost you pay after your deductible is met.',
  },
  {
    t: 'Deductible',
    b: 'The amount you pay out of pocket before your insurance starts covering services.',
  },
  {
    t: 'Out-of-pocket maximum',
    b: 'The most you pay for covered services in a plan year. After you reach it, your plan pays the full cost of covered services.',
  },
];

const coverageSteps = [
  { n: '01', t: 'Call us', b: 'Tell us which insurance plan you have. We’ll tell you what we know about your coverage right away, and what we still need to check.' },
  { n: '02', t: 'We gather the details', b: 'Our admissions team contacts your insurer to verify your benefits and confirm what’s covered for IOP and PHP specifically, before any commitments are made.' },
  { n: '03', t: 'We explain your costs', b: 'We walk you through what your plan covers and what your out-of-pocket costs are likely to be, so you can make the decision with the numbers in front of you.' },
  { n: '04', t: 'You decide', b: 'Once you know the numbers, you decide whether to move forward. If you do, a typical start is three to five days from first contact.' },
];

const insurerQuestions = [
  'Is Joshua Tree Health in network with my specific plan?',
  'Does my plan cover partial hospitalization (PHP) and intensive outpatient (IOP) programs?',
  'What is my deductible, and how much of it have I met?',
  'Do I have a copay or coinsurance for these services?',
  'Is prior authorization required before starting a program?',
  'What billing codes will be used? (We can provide these on request.)',
];

const howWeHelp = [
  'Verify your benefits before care begins',
  'Explain what your plan covers for PHP and IOP specifically',
  'Help manage prior authorization and communication with your insurer',
  'Answer questions about copays, deductibles, and what to expect at billing',
];

const faqs = [
  {
    q: 'Do you accept Medicaid?',
    a: 'No. We do not accept Medicaid. Self-pay is available, and our admissions team can explain what that would look like for your family.',
  },
  {
    q: 'What if you are not in network with my plan?',
    a: 'Call us anyway. We’ll ask your insurer whether your plan includes out-of-network benefits and explain what comes back. Self-pay is also an option.',
  },
  {
    q: 'How do I know what I’ll pay before we commit to anything?',
    a: 'We verify your specific coverage and walk you through expected costs before your teen starts the program. You’ll know what to expect at billing before care begins.',
  },
  {
    q: 'Does insurance cover both IOP and PHP?',
    a: 'Some commercial plans cover both. Coverage depends on your specific policy, your deductible, and whether prior authorization is required. Our team verifies benefits and can help with the authorization process.',
  },
  {
    q: 'What is prior authorization?',
    a: 'Some plans require approval before they will cover a program like IOP or PHP. Our team submits that request and handles the back-and-forth with your insurer, so you don’t have to manage it yourself.',
  },
  {
    q: 'Can I use my HSA or FSA?',
    a: 'IOP and PHP services are generally eligible for HSA and FSA funds. Check with your plan administrator to confirm how your account applies.',
  },
  {
    q: 'What if insurance only covers part of the cost?',
    a: 'Many families have some out-of-pocket costs, depending on their deductible and coinsurance. We’ll give you a clear picture of what that looks like for your specific plan before care begins.',
  },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Insurance & Costs for Teen PHP & IOP | Joshua Tree Health"
  description="How coverage works for adolescent PHP and IOP at Joshua Tree Health in Apex, NC. We verify your benefits and explain expected costs before care begins."
>
  <!-- TODO: VERIFY "many commercial insurance plans" phrasing against current payer participation before launch (docs/CLAIM_REGISTER.md: named in-network payer contracts pending). -->
  <PageHero
    art="growth"
    title="Understand your coverage before care begins."
    sub="Benefits can differ even between plans from the same insurer. We check your specific policy and explain the likely cost before you decide."
    primaryCta={{ label: 'Check your coverage', href: '/get-started' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <section class="section surface-cream-deep" aria-labelledby="coverage-process-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What happens when you call</p>
        <h2 class="section-title font-display" id="coverage-process-title">What happens when we check your benefits.</h2>
      </div>
      <ol class="process__steps" data-reveal-group>
        {coverageSteps.map((step) => (
          <li class="step" data-reveal-item>
            <span class="step__num">{step.n}</span>
            <h3>{step.t}</h3>
            <p>{step.b}</p>
          </li>
        ))}
      </ol>
      <p class="coverage-note" data-reveal><strong>We do not accept Medicaid.</strong> Self-pay is available. Call our admissions team for details.</p>
    </div>
  </section>

  <!-- ===== INSURANCE VOCABULARY ===== -->
  <section class="section" aria-labelledby="terms-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="terms-title">Understanding how your coverage works.</h2>
        <p class="section-sub">A few terms come up again and again when families call about coverage. Here is what each one means in plain language.</p>
      </div>
      <div class="grid-4" data-reveal-group>
        {terms.map((term) => (
          <div class="info-card" data-reveal-item>
            <h3 class="info-card__title">{term.t}</h3>
            <p class="info-card__body">{term.b}</p>
          </div>
        ))}
      </div>
      <p class="prose" data-reveal style="margin-top:2rem;max-width:60ch;">
        PHP and IOP often use daily rates or weekly bundles. Weekly outpatient therapy usually bills per session. Our team will walk you through how your specific plan applies to our programs.
      </p>
    </div>
  </section>

  <!-- ===== PLAN VERIFICATION ===== -->
  <!-- TODO: VERIFY named in-network payer contracts before adding any insurer list or logo strip here (docs/CLAIM_REGISTER.md: pending contract verification). -->
  <section class="section surface-cream-deep" aria-labelledby="plan-verification-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Your specific plan</p>
        <h2 class="section-title font-display" id="plan-verification-title">We verify your plan directly.</h2>
        <p class="section-sub">Network participation and benefits differ from plan to plan and can change. Admissions checks your exact policy and tells you what the insurer confirms.</p>
      </div>
      <a class="btn" href="/get-started">Check your coverage <span class="btn__arrow">→</span></a>
    </div>
  </section>

  <!-- ===== QUESTIONS TO ASK YOUR INSURER ===== -->
  <section class="section" aria-labelledby="questions-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="questions-title">Questions to ask your insurer.</h2>
        <p class="section-sub">If you’d like to check things yourself before you call us, these are the questions to ask.</p>
      </div>
      <ul class="checklist" data-reveal>
        {insurerQuestions.map((q) => <li>{q}</li>)}
      </ul>
    </div>
  </section>

  <!-- ===== HOW WE HELP ===== -->
  <section class="section surface-cream-deep" aria-labelledby="help-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="help-title">What admissions handles with you.</h2>
        <p class="section-sub">Our admissions team will:</p>
      </div>
      <ul class="checklist" data-reveal>
        {howWeHelp.map((item) => <li>{item}</li>)}
      </ul>
      <div class="section-head section-head--center" data-reveal style="margin-top:2.5rem;">
        <p class="section-sub">Not sure where to start? Call us. We’ll figure it out together before anything begins.</p>
        <a class="btn" href="/get-started">Check your coverage<span class="btn__arrow">→</span></a>
        <p class="section-sub" style="margin-top:1rem;">
          <a class="link-arrow" href="tel:+19193355053">Call (919) 335-5053</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section" aria-labelledby="ins-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="ins-faq-title">Common questions about coverage.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .coverage-note { margin-top: 2rem; max-width: 52rem; color: var(--color-ink-soft); font-size: 1.05rem; line-height: 1.6; }
</style>
