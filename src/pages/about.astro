---
import Base from '../layouts/Base.astro';
import BrandPageHero from '../components/BrandPageHero.astro';
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import gabyImg from '../assets/images/Gaby-founder-headshot.JPG';

const aboutEntry = await getEntry('aboutPage', 'about');
if (!aboutEntry) throw new Error('Missing CMS content: about page');
const content = aboutEntry.data;
---

<Base
  bodyClass="brand-page about-page"
  title={content.seo.title}
  description={content.seo.description}
>
  <BrandPageHero
    eyebrow=""
    title={`${content.hero.title} <em>${content.hero.emphasis}</em>`}
    sub={content.hero.sub}
    tone="forest"
    primaryCta={{ label: content.hero.primaryCta, href: '/about/team' }}
    secondaryCta={{ label: content.hero.secondaryCta, href: '/what-we-offer/our-approach' }}
    facts={content.hero.facts.map((fact) => ({ label: fact.title, detail: fact.body }))}
  >
    <div class="about-hero-art">
      <img class="about-hero-art__wash" src="/brand-v2/washes/wash-03.webp" alt="" aria-hidden="true" />
      <img class="about-hero-art__tree" src="/brand-v2/collage/joshua-tree-cut-collage.webp" alt="A Joshua tree cut into a layered paper collage" />
      <img class="about-hero-art__mark" src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
    </div>
  </BrandPageHero>

  <section class="section about-mission" aria-labelledby="mission-title">
    <div class="container-x about-mission__layout">
      <div data-reveal>
        <p class="eyebrow">{content.mission.eyebrow}</p>
        <h2 class="section-title font-display" id="mission-title">{content.mission.title}</h2>
      </div>
      <div class="about-mission__copy" data-reveal data-reveal-delay="0.08">
        <p class="about-mission__lead">{content.mission.lead}</p>
        {content.mission.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        <!-- Josh story: Gaby to write 2-4 sentences here in her own words about who Josh was and what his memory means to this work. This is the only place on the site where the personal story appears. Do not publish any version of it she has not approved. -->
      </div>
    </div>
  </section>

  <section class="section founder-section" aria-labelledby="founder-title">
    <div class="container-x founder-section__layout">
      <figure class="founder-art" data-reveal>
        <img class="founder-art__wash" src="/brand-v2/washes/wash-09.webp" alt="" aria-hidden="true" />
        <div class="founder-art__frame">
          <Image src={gabyImg} alt={`${content.founder.name}, ${content.founder.role} of Joshua Tree Health`} widths={[540, 800, 1100]} sizes="(max-width: 980px) 88vw, 44vw" class="founder-art__photo" />
        </div>
        <img class="founder-art__mark" src="/brand-v2/halos/halo-9-lavender.svg" alt="" aria-hidden="true" />
        <figcaption>{content.founder.name} · {content.founder.role}</figcaption>
      </figure>

      <div class="founder-section__copy" data-reveal data-reveal-delay="0.08">
        <p class="eyebrow">{content.founder.eyebrow}</p>
        <h2 class="section-title font-display" id="founder-title">{content.founder.name}</h2>
        <p class="founder-section__role">{content.founder.role}</p>
        <p>{content.founder.description}</p>
        <p><a class="link-arrow" href="/about/team">{content.founder.teamCta}</a></p>
      </div>
    </div>
  </section>

  <section class="section surface-cream" aria-labelledby="history-title">
    <div class="container-x prose" data-reveal>
      <p class="eyebrow">{content.history.eyebrow}</p>
      <h2 id="history-title">{content.history.title}</h2>
      <!-- TODO: VERIFY tenure. Founder guide says "more than five years"; publish a specific figure only once confirmed. -->
      {content.history.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="section values-section" aria-labelledby="values-title">
    <div class="container-x values-section__layout">
      <div class="values-section__intro" data-reveal>
        <p class="eyebrow">{content.values.eyebrow}</p>
        <h2 class="section-title font-display" id="values-title">{content.values.title}</h2>
        <img src="/brand-v2/spots/nature-walking.svg" alt="Illustration of a character growing alongside a Joshua tree" loading="lazy" />
      </div>
      <div class="values-list" data-reveal-group>
        {content.values.items.map((value, index) => (
          <article class="value-row" data-reveal-item>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{value.name}</h3>
            <p>{value.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section credibility-section" aria-labelledby="program-facts-title">
    <div class="container-x credibility-section__layout">
      <div data-reveal>
        <img class="credibility-section__mark" src="/brand-v2/graphics/element-13-deep-sage.svg" alt="" aria-hidden="true" />
        <p class="eyebrow">{content.programFacts.eyebrow}</p>
        <h2 class="section-title font-display" id="program-facts-title">{content.programFacts.title}</h2>
        <p class="section-sub">{content.programFacts.intro}</p>
        <div class="about-carf">
          <img src="/brand/carf-accredited.svg" alt="CARF Accredited" width="72" height="72" />
          <p>Joshua Tree Health is <strong>CARF-accredited</strong> — an independent, international mark of quality and accountability in behavioral health care.</p>
        </div>
      </div>
      <dl class="credibility-facts" data-reveal data-reveal-delay="0.08">
        {content.programFacts.items.map((fact) => <div><dt>{fact.label}</dt><dd>{fact.detail}</dd></div>)}
      </dl>
    </div>
  </section>

  <section class="about-cta" aria-labelledby="about-cta-title">
    <div class="container-x about-cta__inner" data-reveal>
      <img src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
      <div>
        <p class="eyebrow">{content.closing.eyebrow}</p>
        <h2 class="font-display" id="about-cta-title">{content.closing.title}</h2>
        <p>{content.closing.body}</p>
        <div class="about-cta__actions">
          <a class="btn btn--on-dark" href="/get-started">{content.closing.primaryCta} <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .about-hero-art { position: absolute; inset: 0; isolation: isolate; }
  .about-hero-art img { position: absolute; max-width: none; }
  .about-hero-art__wash { z-index: -1; width: 110%; left: 50%; top: 4%; opacity: .72; transform: translateX(-50%) rotate(-3deg); }
  .about-hero-art__tree { z-index: 2; width: 108%; left: 50%; bottom: -18%; transform: translateX(-50%); filter: drop-shadow(0 24px 34px rgba(7, 23, 17, .18)); }
  .about-hero-art__mark { z-index: 4; width: 15%; left: 1%; top: 8%; transform: rotate(-9deg); filter: brightness(0) saturate(100%) invert(91%) sepia(35%) saturate(943%) hue-rotate(27deg) brightness(101%); }

  .about-mission { background: var(--color-cream); }
  .about-mission__layout { display: grid; grid-template-columns: minmax(0, .82fr) minmax(0, 1.18fr); gap: clamp(3rem, 8vw, 9rem); align-items: start; }
  .about-mission__copy { max-width: 52rem; display: grid; gap: 1.3rem; color: var(--color-ink-soft); font-size: 1.18rem; line-height: 1.7; }
  .about-mission__lead { font-family: var(--font-sans); font-size: clamp(1.5rem, 2.3vw, 2.35rem); line-height: 1.32; color: var(--color-deep-green); }
  .about-mission__personal { display: grid; grid-template-columns: 4.5rem 1fr; gap: 1.5rem; align-items: start; margin-top: 1rem; padding: 1.6rem 0 0; border-top: 1px solid var(--color-line-strong); }
  .about-mission__personal img { width: 64px; transform: rotate(-8deg); }
  .about-mission__personal p { font-size: 1.08rem; }
  .about-carf { display: flex; align-items: center; gap: 1rem; margin-top: 1.75rem; }
  .about-carf img { width: 68px; height: 68px; flex: none; }
  .about-carf p { color: var(--color-ink-soft); font-size: 1.02rem; line-height: 1.55; margin: 0; }

  .founder-section { overflow: hidden; background: var(--color-lavender-soft); }
  .founder-section__layout { display: grid; grid-template-columns: minmax(380px, .92fr) minmax(0, 1.08fr); gap: clamp(3rem, 8vw, 9rem); align-items: center; }
  .founder-art { position: relative; min-height: 650px; margin: 0; isolation: isolate; }
  .founder-art__wash { position: absolute; z-index: -1; width: 112%; max-width: none; left: 50%; top: 6%; opacity: .68; transform: translateX(-50%) rotate(4deg); }
  .founder-art__frame { position: absolute; z-index: 2; width: 82%; left: 8%; top: 4%; padding: 10px; background: var(--color-cream); box-shadow: 0 28px 54px rgba(30, 61, 52, .14); transform: rotate(-1.5deg); clip-path: polygon(2% 4%, 98% 0, 100% 93%, 94% 100%, 3% 97%, 0 12%); }
  .founder-art__photo { width: 100%; height: 520px; object-fit: cover; object-position: 42% 28%; clip-path: polygon(1% 2%, 99% 0, 100% 95%, 94% 100%, 2% 98%, 0 8%); }
  .founder-art__tape { position: absolute; z-index: 3; width: 27%; right: 3%; top: 1%; transform: rotate(12deg); }
  .founder-art__mark { position: absolute; z-index: 4; width: 17%; left: 0; bottom: 7%; transform: rotate(-9deg); }
  .founder-art figcaption { position: absolute; left: 8%; bottom: 0; font-family: var(--font-head); font-size: .98rem; line-height: 1.15; letter-spacing: .03em; text-transform: uppercase; color: var(--color-deep-green); }
  .founder-section__role { margin-top: 1.1rem; font-family: var(--font-head); font-size: 1rem; line-height: 1.15; letter-spacing: .025em; text-transform: uppercase; color: var(--color-deep-sage); }
  .founder-section__copy > p:not(.eyebrow):not(.founder-section__role) { max-width: 43rem; margin-top: 1.3rem; color: var(--color-ink-soft); font-size: 1.12rem; line-height: 1.62; }

  .values-section { background: var(--color-cream-deep); }
  .values-section__layout { display: grid; grid-template-columns: minmax(300px, .82fr) minmax(0, 1.18fr); gap: clamp(3rem, 8vw, 9rem); align-items: start; }
  .values-section__intro { position: sticky; top: 110px; }
  .values-section__intro > img { width: min(100%, 420px); margin-top: 2.5rem; }
  .values-list { border-top: 1px solid var(--color-line-strong); }
  .value-row { display: grid; grid-template-columns: 4.5rem minmax(180px, .65fr) minmax(0, 1fr); gap: 1.5rem; align-items: baseline; padding: 1.7rem 0; border-bottom: 1px solid var(--color-line-strong); }
  .value-row > span { font-family: var(--font-display); font-size: 2.4rem; font-weight: 700; line-height: 1; letter-spacing: -.05em; color: var(--color-lavender-deep); }
  .value-row h3 { font-family: var(--font-head); font-size: 1.2rem; font-weight: 900; line-height: .98; letter-spacing: .018em; text-transform: uppercase; }
  .value-row p { color: var(--color-ink-soft); font-size: 1.04rem; line-height: 1.52; }

  .credibility-section { background: var(--color-cream); }
  .credibility-section__layout { display: grid; grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr); gap: clamp(3rem, 8vw, 9rem); align-items: center; }
  .credibility-section__mark { width: 78px; margin-bottom: 1.5rem; }
  .credibility-facts { margin: 0; border-top: 1px solid var(--color-line-strong); }
  .credibility-facts div { display: grid; grid-template-columns: minmax(150px, .7fr) 1.3fr; gap: 1.5rem; padding: 1.35rem 0; border-bottom: 1px solid var(--color-line-strong); }
  .credibility-facts dt { font-family: var(--font-head); font-size: 1rem; line-height: 1.15; letter-spacing: .025em; text-transform: uppercase; color: var(--color-deep-green); }
  .credibility-facts dd { margin: 0; color: var(--color-ink-soft); line-height: 1.5; }

  .about-cta { padding-block: clamp(5.5rem, 9vw, 9rem); background: var(--color-deep-green); color: var(--color-cream); }
  .about-cta__inner { display: grid; grid-template-columns: 7rem minmax(0, 1fr); gap: clamp(2rem, 5vw, 5rem); align-items: start; }
  .about-cta__inner > img { width: 92px; filter: brightness(0) saturate(100%) invert(91%) sepia(35%) saturate(943%) hue-rotate(27deg) brightness(101%); }
  .about-cta .eyebrow { color: var(--color-lime); }
  .about-cta h2 { max-width: 13ch; margin-top: 1rem; color: var(--color-cream); font-size: clamp(3rem, 5vw, 5.4rem); }
  .about-cta h2 + p { max-width: 44rem; margin-top: 1.5rem; color: var(--color-cream-dim); font-size: 1.15rem; }
  .about-cta__actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 2rem; }

  @media (max-width: 980px) {
    .about-hero-art { max-width: 680px; margin-inline: auto; }
    .about-mission__layout, .founder-section__layout, .values-section__layout, .credibility-section__layout { grid-template-columns: 1fr; }
    .founder-art { max-width: 620px; }
    .values-section__intro { position: static; }
    .values-section__intro > img { max-width: 360px; }
  }

  @media (max-width: 700px) {
    .about-hero-art__tree { width: 118%; bottom: -12%; }
    .about-mission__personal { grid-template-columns: 3.5rem 1fr; gap: 1rem; }
    .about-mission__personal img { width: 50px; }
    .founder-art { min-height: 535px; }
    .founder-art__frame { width: 90%; left: 4%; }
    .founder-art__photo { height: 420px; }
    .founder-art figcaption { left: 4%; font-size: .92rem; }
    .value-row { grid-template-columns: 3.5rem minmax(0, 1fr); gap: 1rem; }
    .value-row p { grid-column: 2; }
    .credibility-facts div { grid-template-columns: 1fr; gap: .5rem; }
    .about-cta__inner { grid-template-columns: 1fr; }
    .about-cta__inner > img { width: 72px; }
  }
</style>
