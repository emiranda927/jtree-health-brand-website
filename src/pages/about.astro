---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { Image } from 'astro:assets';
import gabyImg from '../assets/images/Gaby-founder-headshot.JPG';

const values = [
  {
    name: 'Rooted Honesty',
    body: 'We tell teens and families the truth, even when it’s hard — and we never punish someone for telling us theirs.',
  },
  {
    name: 'Earned Trust',
    body: 'We don’t ask anyone to open up before we’ve shown we’re safe to open up to. Trust is built in the room, session by session.',
  },
  {
    name: 'Steady Structure',
    body: 'Lasting change happens inside consistency, not chaos. We build the structure so teens don’t have to build it alone.',
  },
  {
    name: 'Whole-Person Care',
    body: 'We treat the teen in front of us, not just the diagnosis on the chart. The family is part of every treatment plan.',
  },
];
---
<Base
  title="About Us — Joshua Tree Health"
  description="Why Joshua Tree Health exists, and what we believe. Adolescent PHP & IOP in Apex, NC, built around honest, family-centered care for teens ages 10–17."
>
  <PageHero
    title="Rooted enough to weather hard things.<br>Flexible enough to grow in your own shape."
    variant="green"
    center={true}
  />

  <!-- ===== MISSION / WHY JOSHUA TREE ===== -->
  <section class="section" aria-labelledby="mission-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="mission-title">Why Joshua Tree?</h2>
      </div>
      <div class="prose" data-reveal>
        <p class="lead">The Joshua Tree doesn’t grow like other trees. It grows in harsh conditions, in its own direction, in a shape that’s entirely its own. That’s what we believe healing can look like for teenagers: not conformity, not polish, not becoming someone else’s idea of okay.</p>
        <p>We built Joshua Tree Health to be a different kind of behavioral health program. One that takes teens seriously, meets families without judgment, and treats clinical care and human warmth as the same thing, not a tradeoff.</p>

        {/* PLACEHOLDER: Gaby to supply — the personal Josh paragraph. Do NOT fabricate Josh's story, Gaby's relationship to him, or a cause of death. Leave the bracket visible until she writes it. */}
        <p>The name also carries something personal. Joshua Tree Health is named for Josh, [Gaby’s relationship to Josh].</p>
        <p class="mission-note"><em>Gaby will complete this paragraph — 2 to 4 sentences about who Josh was, what his memory means to her, and how it shaped why this work matters. This is the one place on the site this story lives.</em></p>
      </div>
    </div>
  </section>

  <!-- ===== FOUNDER ===== -->
  <section class="section surface-cream-deep" aria-labelledby="founder-title">
    <div class="container-x">
      <div class="split founder">
        <figure class="founder__media" data-reveal>
          <Image src={gabyImg} alt="Gabriela Forter, founder of Joshua Tree Health" widths={[420, 640, 900]} sizes="(min-width: 880px) 44vw, 92vw" class="founder__img" />
          <figcaption class="founder__cap">Gabriela Forter · Founder &amp; CEO</figcaption>
        </figure>
        <div data-reveal data-reveal-delay="0.08">
          <p class="eyebrow">The founder</p>
          <h2 class="section-title font-display" id="founder-title">Gabriela Forter</h2>
          <p class="section-sub">Founder &amp; CEO</p>
          {/* PLACEHOLDER: Gaby to supply bio and preferred personal detail. Do NOT fabricate a background, credentials, or biography. */}
          <p class="founder__bio"><em>Gaby will add a short bio here — her background, why she started Joshua Tree Health, and one personal detail she wants families to know.</em></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section" aria-labelledby="values-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="values-title">What we believe.</h2>
      </div>
      <div class="grid-4" data-reveal-group>
        {values.map((v) => (
          <article class="info-card" data-reveal-item>
            <h3 class="info-card__title">{v.name}</h3>
            <p class="info-card__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ACCREDITATION ===== -->
  <section class="section surface-cream-deep" aria-labelledby="carf-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal>
          <p class="eyebrow">Accreditation</p>
          <h2 class="section-title font-display" id="carf-title">CARF accredited.</h2>
          <p class="section-sub">CARF accreditation is an independent, rigorous review of safety, ethics, and quality of care in behavioral health. Joshua Tree Health has earned it.</p>
        </div>
        <div class="carf-card card" data-reveal data-reveal-delay="0.08">
          <p class="eyebrow eyebrow--plain">Who we serve</p>
          <p class="carf-card__title font-display">Adolescents ages 10–17.</p>
          <p class="carf-card__body">We offer Partial Hospitalization (PHP) and Intensive Outpatient (IOP) programs from our lakeside location in Apex, NC, with family involvement built into every treatment plan.</p>
        </div>
      </div>
    </div>
  </section>

  {/* PLACEHOLDER: Gaby to supply an attributable parent quote (with consent). Do NOT ship an invented testimonial — the pull-quote section is intentionally omitted until approved copy exists. */}

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="about-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="about-cta-title">Start the conversation.</h2>
        <p class="section-sub">One call is enough to find out whether Joshua Tree is the right fit. No commitment, no pressure.</p>
      </div>
      <div class="cta-row" data-reveal data-reveal-delay="0.08">
        <a class="btn btn--on-dark" href="/admissions">Start the Conversation <span class="btn__arrow">→</span></a>
        <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .mission-note { color: var(--color-ink-soft); font-size: 0.95rem; }

  .carf-card { padding: clamp(1.6rem, 1rem + 2vw, 2.4rem); display: flex; flex-direction: column; gap: 0.8rem; }
  .carf-card__title { font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.2rem); color: var(--color-deep-green); }
  .carf-card__body { color: var(--color-ink-soft); line-height: 1.6; }

  .founder__media { margin: 0; }
  .founder__img { width: 100%; border-radius: var(--radius-2xl); box-shadow: var(--shadow-lg); aspect-ratio: 4 / 5; object-fit: cover; object-position: 40% 28%; }
  .founder__cap { margin-top: 0.9rem; font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-sage); }
  .founder__bio { margin-top: 1.1rem; color: var(--color-ink-soft); line-height: 1.65; }

  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
