---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const cities = ['Apex', 'Cary', 'Raleigh', 'Durham', 'Chapel Hill', 'Holly Springs', 'Morrisville', 'Fuquay-Varina', 'Wake Forest'];
---
<Base
  title="Service Area — The NC Triangle | Joshua Tree Health"
  description="Adolescent PHP & IOP in Apex, NC, serving families across the Raleigh-Durham-Chapel Hill Triangle — most reach us in under 30 minutes."
>
  <PageHero
    eyebrow="Where we are"
    title="Apex, NC — easy access from across the <em>Triangle</em>."
    sub="We're built around your family's commute, not the other way around. Most families reach us in under 30 minutes."
    primaryCta={{ label: 'Start the Conversation', href: '/admissions' }}
  />

  <section class="section" aria-labelledby="visit-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal>
          <p class="eyebrow">Visit us</p>
          <h2 class="section-title font-display" id="visit-title">800 West Williams St.</h2>
          <address class="location__address">
            800 West Williams St, STE 203<br />
            Apex, NC 27502
          </address>
          <p class="section-sub">Just off US-64 in downtown Apex, with parking on site. Serving families across the Raleigh-Durham-Chapel Hill Triangle.</p>
          <div class="location__actions">
            <a class="btn btn--ghost" href="https://maps.google.com/?q=800+West+Williams+St+STE+203+Apex+NC+27502" target="_blank" rel="noopener">Get directions →</a>
            <a class="link-arrow" href="tel:+19193355053">(919) 335-5053</a>
          </div>
        </div>
        <div class="split__media" data-reveal data-reveal-delay="0.08">
          <iframe
            title="Map to Joshua Tree Health in Apex, NC"
            src="https://maps.google.com/maps?q=800%20West%20Williams%20St%20Apex%20NC%2027502&t=&z=13&ie=UTF8&iwloc=&output=embed"
            loading="lazy"
            style="width:100%;height:100%;border:0;filter:grayscale(0.15) contrast(1.02);"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="section surface-cream-deep" aria-labelledby="cities-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Communities we serve</p>
        <h2 class="section-title font-display" id="cities-title">Families come to us from across the Triangle.</h2>
      </div>
      <div class="carriers" data-reveal-group>
        {cities.map((c) => <div class="carrier" data-reveal-item>{c}</div>)}
      </div>
    </div>
  </section>
</Base>

<style>
  .location__address { font-style: normal; font-size: var(--text-body-l); line-height: 1.6; color: var(--color-deep-green); margin: 1.3rem 0; font-family: var(--font-head); font-weight: 500; }
  .location__actions { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; margin-top: 1.5rem; }
  .split__media { aspect-ratio: 4 / 3; }
  .carriers { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .carrier {
    font-family: var(--font-head); font-weight: 600; font-size: 1.05rem;
    color: var(--color-deep-green); background: var(--color-cream-card);
    border: 1px solid var(--color-line); border-radius: var(--radius-pill);
    padding: 0.8rem 1.4rem;
  }
</style>
