---
import Base from '../layouts/Base.astro';

const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
const RITTEN_URL = 'https://simplyteens.ritten.io/#/lead-application';

// Quick-referral field option lists (kept in sync with referral.ts mapping).
const roles = [
  'Therapist / counselor',
  'Psychiatrist / prescriber',
  'Pediatrician / PCP',
  'School counselor',
  'Hospital / discharge team',
  'Other',
];
const bestTimes = ['No preference', 'Morning', 'Afternoon', 'Late afternoon'];
const patientAges = Array.from({ length: 8 }, (_, i) => 10 + i);
const levelsOfCare = [
  { value: '', label: 'Not sure' },
  { value: 'IOP', label: 'IOP' },
  { value: 'PHP', label: 'PHP' },
  { value: 'Either', label: 'Either — help me decide' },
];
const timeframes = ['Routine', 'Within a week', 'Urgent step-down'];

// TODO: VERIFY referral response turnaround. The founder-approved design promises
// "usually within one business day"; keep in sync with the claim register.
const faqs = [
  {
    question: 'What are the clinical criteria for IOP admission?',
    answer: 'Adolescents ages 10–17 experiencing moderate to severe symptoms that impair daily functioning but do not require inpatient or residential care. Common presentations include anxiety, depression, trauma and PTSD, emotional dysregulation, self-harm, suicidal ideation not requiring inpatient stabilization, school avoidance, and ASD with co-occurring mood or anxiety.',
  },
  {
    question: 'What are the clinical criteria for PHP admission?',
    answer: 'Adolescents who need a higher level of clinical contact than IOP: typically more acute symptom severity, a recent discharge from a higher level of care, or deteriorating function despite IOP-level support. PHP serves as both a step-up from IOP and a step-down from inpatient or residential care.',
  },
  {
    question: 'What are your exclusion criteria?',
    answer: 'We are not appropriate for adolescents requiring 24-hour supervision, active psychosis, primary substance use disorder as the presenting concern, or medical instability. If you are unsure whether a client is appropriate, call us.',
  },
  {
    question: 'What records do you need for a referral?',
    answer: 'A brief clinical summary of presenting concerns and current symptom level is enough to initiate intake. We do not require full records before scheduling an assessment.',
  },
  {
    question: 'How quickly do you respond to referrals?',
    answer: 'Referral inquiries go directly to our clinical team, and we respond promptly — usually within one business day. For urgent step-down situations, call (919) 335-5053.',
  },
  {
    question: 'How will you communicate with me during treatment?',
    answer: 'We provide communication at admission, updates during treatment on request, and a discharge summary with clinical recommendations at the end of the episode of care. We coordinate warm handoffs back to outpatient providers.',
  },
  {
    question: 'What is your clinical model?',
    answer: "Programs are built around a DBT skills curriculum, with nervous system regulation and trauma-informed practice shaping delivery. Expressive and experiential methods are used in the group curriculum. Individual and family therapy run alongside group care, and programming is developmentally appropriate across ages 10–17. Admissions can explain current group organization for a given client's age.",
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---
<Base
  bodyClass="brand-page rollout-page refer-page"
  title="Refer a Patient | Joshua Tree Health"
  description="Refer an adolescent to PHP or IOP in Apex, NC. Send a complete clinical referral through our secure Ritten form, or a quick referral and we'll call you back — usually within one business day."
  jsonLd={faqSchema}
>
  <!-- ===== HERO: the referral action is the page ===== -->
  <section class="refer-hero" data-hero-scope>
    <div class="container-x refer-hero__grid">
      <!-- Left: value prop, credentials, calm -->
      <div class="refer-hero__copy">
        <p class="brand-hero__eyebrow" data-hero>For referring providers</p>
        <h1 class="refer-hero__title" data-hero>Two ways to refer. Both start <em>here</em>.</h1>
        <p class="refer-hero__sub" data-hero>Adolescent PHP and IOP in Apex, NC, for ages 10–17. Send a complete clinical referral, or just the basics and we’ll call you back — usually within one business day.</p>

        <ul class="refer-hero__badges" data-hero>
          <li>CARF Accredited</li>
          <li>Ages 10–17</li>
          <li>PHP · IOP</li>
          <li>In-network with major plans</li>
        </ul>

        <div class="refer-hero__urgent" data-hero>
          <p class="refer-hero__urgent-label">Time-sensitive step-down?</p>
          <p class="refer-hero__urgent-body">Call our clinical team directly and we’ll triage it with you.</p>
          <a class="btn btn--ghost" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>

      <!-- Right: THE referral chooser — the form, at the top -->
      <div class="refer-hero__panel">
        <img class="refer-hero__wash" src="/brand-v2/washes/wash-08.webp" alt="" aria-hidden="true" />
        <div class="chooser" data-referral>
          <img class="chooser__tape" src="/brand-v2/tapes/tape-08.webp" alt="" aria-hidden="true" />
          <p class="chooser__eyebrow">Make a referral</p>
          <p class="chooser__title font-display">How would you like to send it?</p>

          <div class="chooser__tabs" role="tablist" aria-label="Referral method">
            <button type="button" class="chooser__tab is-active" data-tab="full" role="tab" aria-selected="true">Full clinical referral</button>
            <button type="button" class="chooser__tab" data-tab="quick" role="tab" aria-selected="false">Quick referral</button>
          </div>

          <!-- PANEL: Full clinical referral (Ritten) -->
          <div class="chooser__panel-body" data-panel="full">
            <div class="chooser__meta">
              <span class="chooser__secure"><span class="chooser__dot" aria-hidden="true"></span>Secure · HIPAA</span>
              <span class="chooser__powered">Powered by Ritten</span>
            </div>
            <p class="chooser__lead">The complete intake — provider details, patient demographics, insurance, and presenting concerns — on our secure clinical platform. Takes about five minutes.</p>
            <ul class="chooser__points">
              <li>Goes straight to our clinical team</li>
              <li>Attach records and insurance in one place</li>
              <li>HIPAA-secure, entered directly into Ritten</li>
            </ul>
            <a class="btn chooser__cta" href={RITTEN_URL} target="_blank" rel="noopener">Open clinical referral form <span class="btn__arrow">→</span></a>
            <p class="chooser__fine">Opens the secure Ritten form in a new tab. Prefer to just send the basics? <a href="#" data-goto="quick">Switch to Quick referral →</a></p>
          </div>

          <!-- PANEL: Quick referral (short inline form) -->
          <div class="chooser__panel-body is-hidden" data-panel="quick">
            <form class="form chooser__form" id="referral-quick-form" novalidate>
              <div class="form-error-banner" role="alert" aria-live="assertive"></div>
              <p class="chooser__lead">Send us just enough to call you back. Keep detailed clinical records for the full referral form — this one stays off the website.</p>

              <div class="form__row form__row--2">
                <div class="field field--req">
                  <label for="ref_name">Your name</label>
                  <input id="ref_name" name="name" type="text" autocomplete="name" required />
                  <span class="jth-field-error" id="err-name"></span>
                </div>
                <div class="field field--req">
                  <label for="ref_role">Your role</label>
                  <select id="ref_role" name="role" required>
                    <option value="">Select…</option>
                    {roles.map((r) => <option value={r}>{r}</option>)}
                  </select>
                  <span class="jth-field-error" id="err-role"></span>
                </div>
              </div>

              <div class="form__row form__row--2">
                <div class="field">
                  <label for="ref_org">Organization <span class="field__opt">(optional)</span></label>
                  <input id="ref_org" name="organization" type="text" placeholder="Practice, school, or hospital" />
                </div>
                <div class="field field--req">
                  <label for="ref_email">Work email</label>
                  <input id="ref_email" name="email" type="email" autocomplete="email" required />
                  <span class="jth-field-error" id="err-email"></span>
                </div>
              </div>

              <div class="form__row form__row--2">
                <div class="field field--req">
                  <label for="ref_phone">Phone</label>
                  <input id="ref_phone" name="phone" type="tel" autocomplete="tel" required />
                  <span class="jth-field-error" id="err-phone"></span>
                </div>
                <div class="field">
                  <label for="ref_best_time">Best time to reach you <span class="field__opt">(optional)</span></label>
                  <select id="ref_best_time" name="best_time">
                    {bestTimes.map((t) => <option value={t}>{t}</option>)}
                  </select>
                </div>
              </div>

              <div class="form__row form__row--2">
                <div class="field">
                  <label for="ref_initials">Patient initials <span class="field__opt">(optional)</span></label>
                  <input id="ref_initials" name="patient_initials" type="text" maxlength="4" placeholder="e.g. J.M." />
                </div>
                <div class="field field--req">
                  <label for="ref_age">Patient age</label>
                  <select id="ref_age" name="patient_age" required>
                    <option value="">Select…</option>
                    {patientAges.map((a) => <option value={a}>{a}</option>)}
                  </select>
                  <span class="jth-field-error" id="err-patient_age"></span>
                </div>
              </div>

              <div class="form__row form__row--2">
                <div class="field">
                  <label for="ref_loc">Level of care <span class="field__opt">(optional)</span></label>
                  <select id="ref_loc" name="level_of_care">
                    {levelsOfCare.map((l) => <option value={l.value}>{l.label}</option>)}
                  </select>
                </div>
                <div class="field">
                  <label for="ref_timeframe">Timeframe <span class="field__opt">(optional)</span></label>
                  <select id="ref_timeframe" name="timeframe">
                    {timeframes.map((t) => <option value={t}>{t}</option>)}
                  </select>
                </div>
              </div>

              <div class="form__row">
                <div class="field">
                  <label for="ref_reason">Reason for referral <span class="field__opt">(optional)</span></label>
                  <textarea id="ref_reason" name="reason" rows="3" maxlength="600" placeholder="A brief summary of presenting concerns is enough to start."></textarea>
                </div>
              </div>

              <p class="chooser__fine">A brief clinical summary is enough to initiate intake — full records aren’t required before an assessment. Please avoid detailed PHI here; use the full clinical referral to share records securely.</p>

              {/* Honeypot */}
              <div class="hp" aria-hidden="true">
                <label for="ref_hp">Leave this field empty</label>
                <input id="ref_hp" name="hp_field" type="text" tabindex="-1" autocomplete="off" />
              </div>
              <input type="hidden" id="referral_session_id" name="session_id" value="" />

              {turnstileKey && <div id="cf-turnstile-referral" class="cf-turnstile-box"></div>}

              <button type="submit" class="btn form__submit chooser__cta">Send referral <span class="btn__arrow">→</span></button>
            </form>

            <div class="chooser__success is-hidden" data-referral-success>
              <div class="chooser__check" aria-hidden="true">✓</div>
              <p class="chooser__success-title font-display">Referral received.</p>
              <p class="chooser__success-body">Our clinical team will reach out at the number you provided, usually within one business day. For anything time-sensitive, call <a href="tel:+19193355053">(919) 335-5053</a>.</p>
              <p><a href="#" class="link-arrow" data-referral-reset>Send another →</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== BUILT FOR CLINICAL COORDINATION ===== -->
  <section class="section" aria-labelledby="coordination-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">How we work with you</p>
        <h2 class="section-title font-display" id="coordination-title">Built for clinical coordination.</h2>
        <p class="section-sub">We partner closely with referring providers — therapists, psychiatrists, pediatricians, schools, and hospitals — so transitions stay smooth and communication stays consistent throughout the episode of care.</p>
      </div>
      <div class="refer-coord" data-reveal-group>
        <div class="refer-coord__item" data-reveal-item>
          <h3 class="refer-coord__title">At admission</h3>
          <p>A clinical screening confirms fit before admission, and we notify you once your patient is admitted.</p>
        </div>
        <div class="refer-coord__item" data-reveal-item>
          <h3 class="refer-coord__title">During treatment</h3>
          <p>Treatment updates with authorization and as clinically appropriate, plus coordination with outpatient providers.</p>
        </div>
        <div class="refer-coord__item" data-reveal-item>
          <h3 class="refer-coord__title">At discharge</h3>
          <p>A discharge summary with next-step recommendations and a warm handoff back to you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHO WE TREAT + CLINICAL MODEL ===== -->
  <section class="section surface-cream-deep" aria-labelledby="who-title">
    <div class="container-x refer-split">
      <div class="prose" data-reveal>
        <p class="eyebrow">Who we treat</p>
        <h2 class="section-title font-display" id="who-title">Adolescents, ages 10–17.</h2>
        <p>Teens presenting with anxiety, depression, emotional dysregulation, trauma, and co-occurring behavioral health challenges. We serve PHP and IOP levels of care — both a step-up from outpatient and a step-down from inpatient or residential.</p>
      </div>
      <div class="prose" data-reveal data-reveal-delay="0.08">
        <p class="eyebrow">Our clinical model</p>
        <h2 class="section-title font-display">DBT-based, trauma-informed care.</h2>
        <p>A DBT skills curriculum with nervous-system regulation and somatic work. Group work can include somatic exercises, art, and music. Individual therapy, family involvement, and care coordination connect the program to the rest of the treatment plan.</p>
      </div>
    </div>
  </section>

  <!-- ===== CLINICIAN FAQS ===== -->
  <section class="section" aria-labelledby="refer-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Referral questions</p>
        <h2 class="section-title font-display" id="refer-faq-title">Answers for referring clinicians.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((faq) => (
          <details class="faq__item">
            <summary>{faq.question}</summary>
            <div class="faq__answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="refer-cta-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Ready to refer</p>
        <h2 class="section-title font-display" id="refer-cta-title">Make a referral or connect with our clinical team.</h2>
        <p class="section-sub">For time-sensitive transitions, call us directly. Otherwise the secure referral form is the fastest way to get a teen scheduled for assessment.</p>
        <div class="cta-row">
          <a class="btn btn--on-dark" href={RITTEN_URL} target="_blank" rel="noopener">Open clinical referral form <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

{turnstileKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
)}
<script>
  import '../lib/referral';
</script>

<style>
  /* ===== Hero ===== */
  .refer-hero { position: relative; overflow: hidden; background: var(--color-cream); }
  .refer-hero__grid {
    padding-top: clamp(3rem, 2rem + 4vw, 5.5rem);
    padding-bottom: clamp(3rem, 2rem + 4vw, 5rem);
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }
  .refer-hero__copy { position: relative; z-index: 2; padding-top: 0.4rem; }
  .refer-hero__title {
    max-width: 16ch;
    margin: 0.7rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 1.4rem + 4.6vw, 4.4rem);
    font-weight: 700;
    line-height: 0.94;
    letter-spacing: -0.038em;
    color: var(--color-deep-green);
    text-wrap: balance;
  }
  .refer-hero__title em { font-style: normal; color: var(--color-deep-sage); }
  .refer-hero__sub {
    max-width: 32rem;
    margin: 1.3rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 1rem + 0.45vw, 1.28rem);
    line-height: 1.6;
    color: var(--color-ink-soft);
    text-wrap: pretty;
  }
  .refer-hero__badges {
    list-style: none; margin: 1.6rem 0 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }
  .refer-hero__badges li {
    border: 1px solid var(--color-line-strong);
    padding: 0.4rem 0.7rem;
    font-family: var(--font-head);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.72rem;
    line-height: 1;
    color: var(--color-deep-green);
  }
  .refer-hero__urgent { border-top: 1px solid var(--color-line); margin-top: 1.8rem; padding-top: 1.2rem; }
  .refer-hero__urgent-label {
    font-family: var(--font-head); font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.06em; font-size: 0.72rem; color: var(--color-deep-sage);
  }
  .refer-hero__urgent-body { font-size: 1.02rem; line-height: 1.55; color: var(--color-ink-soft); margin: 0.4rem 0 0.9rem; max-width: 26rem; }

  /* ===== Chooser card ===== */
  .refer-hero__panel { position: relative; z-index: 2; }
  .refer-hero__wash { position: absolute; z-index: -1; top: -34px; right: -40px; width: 60%; opacity: 0.5; pointer-events: none; }
  .chooser {
    position: relative;
    background: var(--color-cream-card);
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 0.8rem + 1.4vw, 2rem);
    box-shadow: var(--shadow);
  }
  .chooser__tape { position: absolute; top: -20px; left: 34px; width: 96px; transform: rotate(-8deg); pointer-events: none; }
  .chooser__eyebrow {
    font-family: var(--font-head); font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.06em; font-size: 0.72rem; color: var(--color-deep-sage);
  }
  .chooser__title {
    font-size: clamp(1.35rem, 1.1rem + 0.8vw, 1.7rem);
    line-height: 1.02; letter-spacing: -0.03em;
    color: var(--color-deep-green); margin: 0.3rem 0 1rem;
  }
  .chooser__tabs { display: flex; gap: 0.5rem; margin-bottom: 1.25rem; }
  .chooser__tab {
    flex: 1; padding: 0.8rem 0.6rem;
    font-family: var(--font-head); font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.03em; font-size: 0.78rem; line-height: 1.1;
    border-radius: var(--radius-pill);
    background: transparent; color: var(--color-deep-green);
    border: 1px solid var(--color-line-strong);
    cursor: pointer;
    transition: background-color var(--dur) var(--ease-soft), color var(--dur) var(--ease-soft), border-color var(--dur) var(--ease-soft);
  }
  .chooser__tab.is-active { background: var(--color-deep-green); color: var(--color-cream); border-color: var(--color-deep-green); }

  .chooser__panel-body.is-hidden { display: none; }
  .chooser__meta { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.85rem; flex-wrap: wrap; }
  .chooser__secure {
    display: inline-flex; align-items: center; gap: 0.4rem;
    border: 1px solid var(--color-line-strong); padding: 0.3rem 0.6rem;
    font-family: var(--font-head); font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.04em; font-size: 0.66rem; color: var(--color-deep-green);
  }
  .chooser__dot { width: 7px; height: 7px; background: var(--color-lime); border-radius: 50%; }
  .chooser__powered { font-family: var(--font-sans); font-size: 0.86rem; color: var(--color-ink-faint); }
  .chooser__lead { font-size: 1.02rem; line-height: 1.55; color: var(--color-ink-soft); margin: 0 0 1rem; }
  .chooser__points { list-style: none; padding: 0; margin: 0 0 1.25rem; display: grid; gap: 0.55rem; }
  .chooser__points li { position: relative; padding-left: 1.6rem; font-size: 1rem; line-height: 1.5; color: var(--color-ink-soft); }
  .chooser__points li::before { content: "→"; position: absolute; left: 0; top: 0; color: var(--color-lime-deep); font-weight: 700; }
  .chooser__cta { width: 100%; }
  .chooser__fine { font-size: 0.86rem; color: var(--color-ink-faint); line-height: 1.5; margin: 0.85rem 0 0; }
  .chooser__fine a { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }

  .chooser__form { gap: 0.9rem; }
  .chooser__form.is-hidden { display: none; }
  .chooser__form .chooser__lead { margin-bottom: 0.2rem; }

  /* ===== Quick-referral success ===== */
  .chooser__success { text-align: center; padding: 2rem 1rem; }
  .chooser__success.is-hidden { display: none; }
  .chooser__check {
    width: 56px; height: 56px; border-radius: 50%; background: var(--color-lime);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.1rem; font-size: 1.6rem; color: var(--color-deep-green);
  }
  .chooser__success-title { font-size: 1.5rem; letter-spacing: -0.03em; color: var(--color-deep-green); }
  .chooser__success-body { font-size: 1.05rem; line-height: 1.6; color: var(--color-ink-soft); max-width: 26rem; margin: 0.7rem auto 1.4rem; }
  .chooser__success-body a { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }

  /* ===== Coordination ===== */
  .refer-coord { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem 2.5rem; }
  .refer-coord__item { border-top: 1px solid var(--color-line-strong); padding-top: 1.1rem; }
  .refer-coord__title {
    font-family: var(--font-head); font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.03em; font-size: 1rem; color: var(--color-deep-green); margin-bottom: 0.5rem;
  }
  .refer-coord__item p { font-size: 1.02rem; line-height: 1.55; color: var(--color-ink-soft); }

  .refer-split { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 4vw, 4.5rem); }

  .cta-row { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 1.6rem; }

  @media (min-width: 820px) {
    .refer-split { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 980px) {
    .refer-hero__grid { grid-template-columns: 1fr; }
    .refer-hero__panel { max-width: 620px; }
    .refer-coord { grid-template-columns: 1fr; gap: 1.25rem; }
  }
</style>
