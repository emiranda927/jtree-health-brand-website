---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const expectations = [
  'Prompt intake response and clinical screening',
  'Clear communication at admission, during treatment, and at discharge',
  'Collaborative treatment planning',
  'High-quality documentation',
  'Appropriate management of clinical complexity and severity',
  'Warm handoffs back to outpatient care at discharge',
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Refer a Patient — Joshua Tree Health"
  description="A trusted step-up or step-down level of care for adolescents ages 10–17. Clear referral pathways, coordinated communication, and clinical standards you can rely on."
>
  <PageHero
    eyebrow="For referral partners"
    art="session"
    title="A trusted step-up or step-down level of care for adolescents."
    sub="Clear referral pathways. Coordinated communication. Clinical standards you can rely on."
    primaryCta={{ label: 'Contact Our Clinical Team', href: '/contact' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <!-- ===== BUILT FOR CLINICAL COORDINATION ===== -->
  <section class="section" aria-labelledby="coordination-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="coordination-title">Built for clinical coordination.</h2>
        <p>We partner closely with referring providers — therapists, psychiatrists, pediatricians, schools, and hospitals — to ensure smooth transitions and consistent communication throughout the episode of care.</p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT YOU CAN EXPECT ===== -->
  <section class="section surface-cream-deep" aria-labelledby="expect-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="expect-title">What you can expect from us.</h2>
      </div>
      <ul class="checklist" data-reveal-group>
        {expectations.map((item) => (
          <li data-reveal-item>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== WHO WE TREAT ===== -->
  <section class="section" aria-labelledby="who-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="who-title">Who we treat.</h2>
        <p>Adolescents ages 10–17 presenting with anxiety, depression, emotional dysregulation, trauma, and co-occurring behavioral health challenges. We serve PHP and IOP levels of care.</p>
      </div>
    </div>
  </section>

  <!-- ===== CLINICAL MODEL AT A GLANCE ===== -->
  <section class="section surface-cream-deep" aria-labelledby="model-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="model-title">Our clinical model at a glance.</h2>
        <p>Our programs are grounded in DBT, polyvagal-informed care, and trauma-informed treatment — all clinical staff are trained in trauma-informed care as a baseline. Experiential therapy (somatic exercises, body-based work) and expressive therapy (art therapy, music therapy) are integrated into every group session as standard curriculum. We also use our lakeside Apex location as part of mindfulness and experiential practice. Family systems work is incorporated throughout treatment.</p>
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="refer-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="refer-cta-title">Ready to make a referral or connect?</h2>
        <p class="section-sub">We respond to all referral inquiries within one business day.</p>
        <div class="cta-row">
          <a class="btn btn--on-dark" href="/contact">Contact Our Clinical Team <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
