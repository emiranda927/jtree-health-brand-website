---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const expectations = [
  'Clinical screening before admission',
  'Communication at admission and discharge',
  'Treatment updates with authorization and as clinically appropriate',
  'Coordination with outpatient providers',
  'A discharge summary with next-step recommendations',
];

// TODO: VERIFY referral response turnaround. The founder guide promises a
// one-business-day response; the claim register marks response-time guarantees
// pending, so the copy below says "promptly" instead.
// TODO: VERIFY scope of experiential/expressive integration ("every group
// session as standard curriculum" per guide) and trauma-informed training
// scope for all clinical staff.
const faqs = [
  {
    question: 'What are the clinical criteria for IOP admission?',
    answer: 'Adolescents ages 10–17 experiencing moderate to severe symptoms that impair daily functioning but do not require inpatient or residential care. Common presentations include anxiety, depression, trauma and PTSD, emotional dysregulation, self-harm, suicidal ideation not requiring inpatient stabilization, school avoidance, and ASD with co-occurring mood or anxiety.',
  },
  {
    question: 'What are the clinical criteria for PHP admission?',
    answer: 'Adolescents who need a higher level of clinical contact than IOP: typically more acute symptom severity, a recent discharge from a higher level of care, or deteriorating function despite IOP-level support. PHP serves as both a step-up from IOP and a step-down from inpatient or residential care.',
  },
  {
    question: 'What are your exclusion criteria?',
    answer: 'We are not appropriate for adolescents requiring 24-hour supervision, active psychosis, primary substance use disorder as the presenting concern, or medical instability. If you are unsure whether a client is appropriate, call us.',
  },
  {
    question: 'What records do you need for a referral?',
    answer: 'A brief clinical summary of presenting concerns and current symptom level is enough to initiate intake. We do not require full records before scheduling an assessment.',
  },
  {
    question: 'How quickly do you respond to referrals?',
    answer: 'Referral inquiries go directly to our clinical team, and we respond promptly. For urgent step-down situations, call (919) 335-5053.',
  },
  {
    question: 'How will you communicate with me during treatment?',
    answer: 'We provide communication at admission, updates during treatment on request, and a discharge summary with clinical recommendations at the end of the episode of care. We coordinate warm handoffs back to outpatient providers.',
  },
  {
    question: 'What is your clinical model?',
    answer: "Programs are built around a DBT skills curriculum, with nervous system regulation and trauma-informed practice shaping delivery. Expressive and experiential methods are used in the group curriculum. Individual and family therapy run alongside group care, and programming is developmentally appropriate across ages 10–17. Admissions can explain current group organization for a given client's age.",
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---
<Base
  bodyClass="brand-page rollout-page"
  title="Refer a Patient | Joshua Tree Health"
  description="Adolescent PHP and IOP in Apex, NC accepting referrals for ages 10–17. Clear referral pathways and coordinated communication with outpatient providers."
  jsonLd={faqSchema}
>
  <PageHero
    art="session"
    title="Step-up and step-down care for adolescents."
    sub="We screen for fit, coordinate transitions, and keep authorized providers informed."
    primaryCta={{ label: 'Contact our clinical team', href: '/contact' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <!-- ===== BUILT FOR CLINICAL COORDINATION ===== -->
  <section class="section" aria-labelledby="coordination-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="coordination-title">Built for clinical coordination.</h2>
        <p>We partner closely with referring providers, including therapists, psychiatrists, pediatricians, schools, and hospitals, so transitions stay smooth and communication stays consistent throughout the episode of care.</p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT YOU CAN EXPECT ===== -->
  <section class="section surface-cream-deep" aria-labelledby="expect-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="expect-title">What you can expect.</h2>
      </div>
      <ul class="checklist" data-reveal-group>
        {expectations.map((item) => (
          <li data-reveal-item>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== WHO WE TREAT ===== -->
  <section class="section" aria-labelledby="who-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="who-title">Who we treat.</h2>
        <p>Adolescents ages 10–17 presenting with anxiety, depression, emotional dysregulation, trauma, and co-occurring behavioral health challenges. We serve PHP and IOP levels of care.</p>
      </div>
    </div>
  </section>

  <!-- ===== CLINICAL MODEL AT A GLANCE ===== -->
  <section class="section surface-cream-deep" aria-labelledby="model-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="model-title">Our clinical model at a glance.</h2>
        <p>Our programs use a DBT skills curriculum, nervous system regulation and somatic work, and trauma-informed practice. Group work can include somatic exercises, art, and music. Individual therapy, family involvement, and care coordination connect the program to the rest of the treatment plan.</p>
      </div>
    </div>
  </section>

  <!-- ===== CLINICIAN FAQS ===== -->
  <section class="section" aria-labelledby="refer-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Referral questions</p>
        <h2 class="section-title font-display" id="refer-faq-title">Answers for referring clinicians.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((faq) => (
          <details class="faq__item">
            <summary>{faq.question}</summary>
            <div class="faq__answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="refer-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="refer-cta-title">Ready to make a referral or connect?</h2>
        <p class="section-sub">For time-sensitive transitions, call our clinical team directly.</p>
        <div class="cta-row">
          <a class="btn btn--on-dark" href="/contact">Contact our clinical team <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
