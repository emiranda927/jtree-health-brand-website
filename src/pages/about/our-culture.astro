---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const values = [
  {
    name: 'Evidence first',
    body: 'We build our programs around what clinical research shows works for adolescents, and we update how we practice as the evidence grows.',
  },
  {
    name: 'Family at the center',
    body: 'Teens don’t develop in isolation. Family involvement is built into the work because the relationships around a teen matter as much as what happens in the room.',
  },
  {
    name: 'A direction of their own',
    body: 'We help each teen build capacity and a clearer direction that fits who they are.',
  },
  {
    name: 'Structured care, lasting skills',
    body: 'Structure is what makes the work possible. Consistent programming gives teens something to count on, and skills they carry beyond the program.',
  },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Our Culture | Joshua Tree Health"
  description="What guides the team at Joshua Tree Health: the values and working culture behind adolescent PHP and IOP care in Apex, NC."
>
  <PageHero
    art="nature"
    title="A steady place to do serious work."
    sub="The standards behind the care and the kind of workplace we are building for clinicians."
    variant="green"
  />

  {/* Mission and vision stay out of public copy until Gaby finalizes them. */}

  <!-- ===== VALUES ===== -->
  <section class="section surface-cream-deep" aria-labelledby="values-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="values-title">What we believe.</h2>
      </div>
      <div class="grid-4" data-reveal-group>
        {values.map((v) => (
          <article class="info-card" data-reveal-item>
            <h3 class="info-card__title">{v.name}</h3>
            <p class="info-card__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CULTURE STATEMENT ===== -->
  <section class="section" aria-labelledby="culture-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="culture-title">How we work.</h2>
      </div>
      <div class="prose" data-reveal>
        <p class="lead">Clinicians need enough support to think clearly, ask hard questions, and keep learning. We are building a workplace with a defined clinical model, direct communication, and room to do the work carefully.</p>
      </div>
    </div>
  </section>

  <!-- ===== CAREERS CTA ===== -->
  <section class="section surface-green" aria-labelledby="careers-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="careers-title">Interested in joining us?</h2>
        <p class="section-sub">We’re growing our clinical team. If this is the kind of work you want to do, we’d like to hear from you.</p>
      </div>
      <div class="cta-row" data-reveal data-reveal-delay="0.08">
        <a class="btn btn--on-dark" href="/careers">Explore open roles <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
