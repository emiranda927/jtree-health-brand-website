---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const values = [
  {
    name: 'Honesty',
    body: 'We tell teens and families the truth, even when it’s hard, and we never punish someone for telling us theirs.',
  },
  {
    name: 'Earned Trust',
    body: 'We don’t ask anyone to open up before we’ve shown we’re safe to open up to. Trust is built in the room, session by session.',
  },
  {
    name: 'Steady Structure',
    body: 'Lasting change happens inside consistency, not chaos. We build the structure so teens don’t have to build it alone.',
  },
  {
    name: 'Whole-Person Care',
    body: 'We treat the teen in front of us, not just the diagnosis on the chart. The family is part of every treatment plan.',
  },
];
---
<Base
  title="Our Culture — Joshua Tree Health"
  description="What guides us as a team — the mission, vision, and values behind adolescent PHP & IOP care at Joshua Tree Health in Apex, NC."
>
  <PageHero
    title="Our culture"
    sub="Our mission matters. Our vision keeps our focus sharp. And our values shape how we work toward both — as a team and as a company."
    variant="green"
    center={true}
  />

  <!-- ===== MISSION & VISION ===== -->
  <section class="section" aria-labelledby="mission-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="mission-title">What we’re working toward.</h2>
      </div>
      <div class="grid-2" data-reveal-group>
        <article class="info-card" data-reveal-item>
          <p class="eyebrow eyebrow--plain">Our mission</p>
          {/* PLACEHOLDER: Gaby to finalize the mission in one sentence. Draft from copy guide 1.2 shown below, clearly marked as a draft. Do NOT publish as final. */}
          <p class="info-card__body">We help teens get well and stay well through structured, evidence-based care that’s grounded in who they are and where they’re starting from.</p>
          <p class="draft-note"><em>Draft — Gaby to finalize.</em></p>
        </article>
        <article class="info-card" data-reveal-item>
          <p class="eyebrow eyebrow--plain">Our vision</p>
          {/* PLACEHOLDER: Gaby to finalize the vision in one sentence. Draft from copy guide 1.2 shown below, clearly marked as a draft. Do NOT publish as final. */}
          <p class="info-card__body">A future where every teen going through a hard time has access to care that meets them without judgment and involves their family.</p>
          <p class="draft-note"><em>Draft — Gaby to finalize.</em></p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== VALUES ===== -->
  <section class="section surface-cream-deep" aria-labelledby="values-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="values-title">What we believe.</h2>
      </div>
      <div class="grid-4" data-reveal-group>
        {values.map((v) => (
          <article class="info-card" data-reveal-item>
            <h3 class="info-card__title">{v.name}</h3>
            <p class="info-card__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CULTURE STATEMENT ===== -->
  <section class="section" aria-labelledby="culture-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="culture-title">How we work.</h2>
      </div>
      <div class="prose" data-reveal>
        <p class="lead">We believe that the best care for teens comes from teams that feel supported, seen, and challenged to grow. We’re building a workplace where clinicians can do their best work — with strong supervision, a clear clinical model, and a culture that takes their wellbeing as seriously as our patients’.</p>
        {/* PLACEHOLDER: Gaby can expand this once the team and culture are further developed. For launch, keep it short and honest rather than aspirational and vague. */}
      </div>
    </div>
  </section>

  <!-- ===== CAREERS CTA ===== -->
  <section class="section surface-green" aria-labelledby="careers-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="careers-title">Interested in joining us?</h2>
        <p class="section-sub">We’re growing our clinical team. If this is the kind of work you want to do, we’d like to hear from you.</p>
      </div>
      <div class="cta-row" data-reveal data-reveal-delay="0.08">
        <a class="btn btn--on-dark" href="/careers">Explore Open Roles <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .draft-note { margin-top: 0.8rem; color: var(--color-ink-soft); font-size: 0.85rem; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
