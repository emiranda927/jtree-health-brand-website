---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

// TODO: VERIFY outcome percentages, alumni testimonials, and the specific
// standardized instruments in use before adding any statistics to this page.
// Register: pending data/methodology/consent review. Methodology copy only.
const measures = [
  {
    title: 'Symptoms and safety',
    body: 'Standardized measures track changes in anxiety, depression, and safety concerns, so the team can see whether treatment is working while there is still time to adjust it.',
  },
  {
    title: 'Daily functioning',
    body: 'Progress also shows up outside the therapy room: school participation, sleep, routines, and whether skills are holding in relationships. We ask about all of it.',
  },
  {
    title: 'Family experience',
    body: 'Stress and communication at home are part of the picture. Change has a better chance of holding when the people at home are part of the work.',
  },
];
---

<Base
  bodyClass="brand-page outcomes-page"
  title="Clinical Outcomes | Joshua Tree Health"
  description="How Joshua Tree Health measures teen PHP and IOP progress: standardized measures at intake, during care, and at discharge in Apex, NC."
>
  <PageHero
    title="How we measure <em>progress.</em>"
    sub="We measure progress from intake through discharge and use the results while care is still underway."
    art="growth"
  />

  <section class="section outcomes-lead" aria-labelledby="measurement-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Measurement-informed care</p>
        <h2 class="section-title font-display" id="measurement-title">Learn while there is still time to adjust.</h2>
        <p class="section-sub">We use standardized clinical measures from intake through discharge. The team reviews the results alongside what teens, families, and clinicians are seeing day to day.</p>
      </div>
      <div class="grid-3" data-reveal-group>
        {measures.map((measure) => (
          <article class="info-card" data-reveal-item>
            <h3>{measure.title}</h3>
            <p>{measure.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section surface-cream-deep" aria-labelledby="reporting-title">
    <div class="container-x prose" data-reveal>
      <h2 id="reporting-title">A number should be able to withstand a question.</h2>
      <p>The treatment team reviews progress regularly and shares it with families during the program, in plain language. You should not have to wait until discharge to learn how treatment is going.</p>
      <p>We will publish outcome percentages only after the data and methodology have been reviewed. Testimonials require documented consent. No program can guarantee an outcome for your teen.</p>
      <p>Families and referring clinicians are welcome to ask the clinical team how progress is measured in the current program.</p>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="outcomes-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="outcomes-cta-title">See whether this is the right fit.</h2>
        <p class="section-sub">Tell us what has been happening. Admissions will explain the assessment and the next step.</p>
        <div class="cta-row">
          <a class="btn btn--on-dark" href="/get-started">Get started <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .cta-row { display: flex; flex-wrap: wrap; gap: .85rem; justify-content: center; margin-top: 1.8rem; }
  /* Bring the body up: the growth hero + default section padding left a large gap below the hero. */
  :global(.outcomes-page .page-hero__grid) { padding-block: clamp(3rem, 5vw, 5.5rem); }
  .outcomes-lead { padding-top: clamp(1rem, 0.5rem + 1.5vw, 2rem); }
</style>
