---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

// Data-driven roster. Add verified biographies and credentials only after each
// team member has reviewed them.
const leadership = [
  {
    name: 'Gabriela Forter',
    credentials: 'Founder & CEO',
    title: 'Leadership',
  },
];

const clinicalTeam = [
  {
    name: 'Beth Bertram',
    credentials: 'Licensed Therapist',
    title: 'IOP Clinical Lead',
  },
  {
    name: 'Caitlyn Dowdy',
    credentials: 'Licensed Therapist',
    title: 'Clinical Director',
  },
  {
    name: 'Grace Beasley',
    credentials: 'Licensed Therapist',
    title: 'Primary Therapist',
  },
  {
    name: 'Alayna West',
    credentials: 'Licensed Therapist',
    title: 'Primary Therapist',
  },
];

// Build initials for the temporary portrait treatment from the member's name.
const initials = (name) =>
  name
    .split(' ')
    .filter(Boolean)
    .map((part) => part[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
---
<Base
  bodyClass="brand-page rollout-page"
  title="Our Team | Joshua Tree Health"
  description="Meet the licensed clinicians and staff at Joshua Tree Health, an adolescent PHP and IOP program in Apex, NC for ages 10–17."
>
  <PageHero
    art="happy"
    title="Meet our team."
    sub="The clinicians and staff responsible for assessment, treatment, and support at Joshua Tree Health."
    variant="green"
  />

  <!-- ===== LEADERSHIP ===== -->
  <section class="section" aria-labelledby="leadership-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Leadership</p>
        <h2 class="section-title font-display" id="leadership-title">The people building the program.</h2>
      </div>
      <div class="grid-3 team-grid" data-reveal-group>
        {leadership.map((member) => (
          <article class="team-card" data-reveal-item>
            <div class="team-card__photo" aria-hidden="true">
              <span class="team-card__initials font-display">{initials(member.name)}</span>
            </div>
            <h3 class="team-card__name font-display">{member.name}</h3>
            <p class="team-card__cred">{member.credentials}</p>
            <p class="team-card__title">{member.title}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLINICAL TEAM ===== -->
  <section class="section surface-cream-deep" aria-labelledby="clinical-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Clinical team</p>
        <h2 class="section-title font-display" id="clinical-title">The clinicians your teen may work with.</h2>
        <p class="section-sub">Our clinical team focuses on adolescent behavioral health. Admissions can walk you through who will be part of your teen’s assessment and care.</p>
      </div>
      <div class="grid-3 team-grid" data-reveal-group>
        {clinicalTeam.map((member) => (
          <article class="team-card" data-reveal-item>
            <div class="team-card__photo" aria-hidden="true">
              <span class="team-card__initials font-display">{initials(member.name)}</span>
            </div>
            <h3 class="team-card__name font-display">{member.name}</h3>
            <p class="team-card__cred">{member.credentials}</p>
            <p class="team-card__title">{member.title}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="team-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="team-cta-title">Ask who will be part of your teen’s care.</h2>
        <p class="section-sub">Admissions can explain who handles assessment, therapy, family communication, and treatment planning.</p>
      </div>
      <div class="cta-row" data-reveal data-reveal-delay="0.08">
        <a class="btn btn--on-dark" href="/get-started">Start the conversation <span class="btn__arrow">→</span></a>
        <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .team-grid { align-items: start; }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.35rem;
  }

  .team-card__photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-2xl);
    background: var(--color-cream-deep);
    border: 1px solid color-mix(in srgb, var(--color-sage) 22%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .surface-cream-deep .team-card__photo {
    background: var(--color-cream);
  }

  .team-card__initials {
    font-size: clamp(2.2rem, 1.6rem + 2vw, 3rem);
    color: var(--color-sage);
    letter-spacing: 0.04em;
  }

  .team-card__name {
    font-size: clamp(1.25rem, 1.05rem + 0.8vw, 1.5rem);
    color: var(--color-deep-green);
  }

  .team-card__cred {
    color: var(--color-ink-soft);
    font-size: 1.0625rem;
    line-height: 1.55;
  }

  .team-card__title {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.15;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-deep-sage);
    margin-top: 0.15rem;
  }

  .team-card__bio {
    margin-top: 0.8rem;
    color: var(--color-ink-soft);
    line-height: 1.6;
    font-size: 1.0625rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.6rem;
  }
</style>
