---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
---
<Base
  bodyClass="brand-page rollout-page"
  title="Contact | Joshua Tree Health"
  description="Contact Joshua Tree Health in Apex, NC about adolescent PHP and IOP care. Call (919) 335-5053, email, or start the admissions conversation online."
>
  <PageHero
    eyebrow="Contact"
    art="session"
    title="Get in touch."
    sub="Parents and referring providers can call or email us directly. If you are still deciding whether Joshua Tree fits, we can talk that through too."
  />

  <!-- ===== CONTACT ===== -->
  <section class="section" aria-labelledby="contact-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal>
          <h2 class="section-title font-display" id="contact-title" style="margin-bottom:1.5rem;">A few ways to reach us.</h2>
          <ul class="contact-list">
            <li><span class="contact-list__k">Call</span><a class="contact-list__v" href="tel:+19193355053">(919) 335-5053</a></li>
            <li><span class="contact-list__k">Fax</span><span class="contact-list__v">(855) 221-4226</span></li>
            <li><span class="contact-list__k">Email</span><a class="contact-list__v" href="mailto:admissions@jtreehealth.com">admissions@jtreehealth.com</a></li>
            <li><span class="contact-list__k">Visit</span><span class="contact-list__v">800 West Williams St, STE 203<br />Apex, NC 27502</span></li>
          </ul>
          <p class="contact-note">For the quickest response, call our admissions team during business hours.</p>
          <p class="contact-crisis">If you or your teen is in crisis, call or text <a href="tel:988">988</a>, or text HOME to <a href="sms:741741">741741</a>. <a href="/crisis">More crisis resources →</a></p>
        </div>

        <div class="card contact-cta" data-reveal data-reveal-delay="0.08">
          <p class="eyebrow eyebrow--plain">Ready to start</p>
          <h2 class="contact-cta__title font-display">Start the conversation.</h2>
          <p class="contact-cta__body">One call is usually enough to know the next step. Admissions will ask what has been going on, explain IOP and PHP, and check what your insurance may cover. Reaching out does not commit you to care.</p>
          <a href="/get-started" class="btn">Start the conversation <span class="btn__arrow">→</span></a>
          <p class="form__note">Prefer email? Write us at <a href="mailto:admissions@jtreehealth.com">admissions@jtreehealth.com</a>.</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.2rem; }
  .contact-list li { display: grid; grid-template-columns: 5rem 1fr; gap: 1rem; align-items: baseline; }
  .contact-list__k { font-family: var(--font-mono); font-size: 0.95rem; line-height: 1.15; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-deep-sage); }
  .contact-list__v { font-size: var(--text-body-l); color: var(--color-deep-green); font-weight: 500; line-height: 1.5; }
  a.contact-list__v { border-bottom: 1.5px solid var(--color-lime); width: fit-content; }
  .contact-note { margin-top: 1.6rem; font-size: 1.0625rem; line-height: 1.6; color: var(--color-ink-soft); }
  .contact-crisis { margin-top: 0.9rem; font-size: 1.0625rem; color: var(--color-ink-soft); line-height: 1.6; }
  .contact-crisis a { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }

  .contact-cta { padding: clamp(1.75rem, 1rem + 2vw, 2.75rem); display: flex; flex-direction: column; gap: 0.9rem; align-items: flex-start; }
  .contact-cta__title { font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.2rem); color: var(--color-deep-green); }
  .contact-cta__body { color: var(--color-ink-soft); line-height: 1.65; font-size: 1.125rem; }
  .contact-cta .btn { margin-top: 0.4rem; }
</style>
