---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
---
<Base
  title="Contact | Joshua Tree Health"
  description="Get in touch with Joshua Tree Health in Apex, NC. Call (919) 335-5053, or start the conversation and we'll respond within one business day."
>
  <PageHero
    eyebrow="Get in touch"
    title="Talk to our <em>team</em>."
    sub="Questions about programs, insurance, or whether we're the right fit? We're real people, and we'll get back to you within one business day."
  />

  <section class="section" aria-labelledby="contact-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal>
          <h2 class="section-title font-display" id="contact-title" style="margin-bottom:1.5rem;">A few ways to reach us.</h2>
          <ul class="contact-list">
            <li><span class="contact-list__k">Call</span><a class="contact-list__v" href="tel:+19193355053">(919) 335-5053</a></li>
            <li><span class="contact-list__k">Email</span><a class="contact-list__v" href="mailto:hello@jtreehealth.com">hello@jtreehealth.com</a></li>
            <li><span class="contact-list__k">Visit</span><span class="contact-list__v">800 West Williams St, STE 203<br />Apex, NC 27502</span></li>
            <li><span class="contact-list__k">Hours</span><span class="contact-list__v">Mon–Fri · 8am – 6pm</span></li>
          </ul>
          <p class="contact-crisis">In a crisis? Call or text <a href="tel:988">988</a> any time. <a href="/crisis">More crisis resources →</a></p>
        </div>

        <div class="card contact-cta" data-reveal data-reveal-delay="0.08">
          <p class="eyebrow eyebrow--plain">Ready when you are</p>
          <h2 class="contact-cta__title font-display">Start the conversation.</h2>
          <p class="contact-cta__body">The fastest way to get help for your teen is our two-minute callback form — we'll call you within one business day, no commitment.</p>
          <a href="/admissions" class="btn">Start the Conversation <span class="btn__arrow">→</span></a>
          <p class="form__note">Prefer email? <a href="mailto:hello@jtreehealth.com">hello@jtreehealth.com</a></p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.2rem; }
  .contact-list li { display: grid; grid-template-columns: 5rem 1fr; gap: 1rem; align-items: baseline; }
  .contact-list__k { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-sage); }
  .contact-list__v { font-size: var(--text-body-l); color: var(--color-deep-green); font-weight: 500; line-height: 1.5; }
  a.contact-list__v { border-bottom: 1.5px solid var(--color-lime); width: fit-content; }
  .contact-crisis { margin-top: 2rem; font-size: 0.92rem; color: var(--color-ink-soft); }
  .contact-crisis a { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }

  .contact-cta { padding: clamp(1.75rem, 1rem + 2vw, 2.75rem); display: flex; flex-direction: column; gap: 0.9rem; align-items: flex-start; }
  .contact-cta__title { font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.2rem); color: var(--color-deep-green); }
  .contact-cta__body { color: var(--color-ink-soft); line-height: 1.6; }
  .contact-cta .btn { margin-top: 0.4rem; }
</style>
