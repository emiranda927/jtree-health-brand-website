---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const steps = [
  {
    num: '01',
    title: 'The first call',
    body: "You call or fill out the form, and we have a conversation about what's been going on. No pressure, no commitment, and no need to have everything figured out before you call. We'll ask questions, you'll ask questions, and together we'll figure out whether Joshua Tree is the right fit.",
    action: { label: 'Call (919) 335-5053', href: 'tel:+19193355053' },
  },
  {
    num: '02',
    title: 'The intake',
    body: "If we're a good fit, we move into a structured intake process. This is a more in-depth conversation with you and, when appropriate, your teen. It gives us a clear picture of what they're experiencing, so we can match them to the right program and build the right treatment plan from day one.",
  },
  {
    num: '03',
    title: 'The program',
    body: "Your teen starts in IOP or PHP, depending on what the intake tells us. Groups run three days a week for IOP or daily for PHP. Individual therapy, family sessions, and the core treatment work happen in parallel. You'll be involved throughout, never left wondering how things are going.",
  },
  {
    num: '04',
    title: 'The transition',
    body: "We don't just discharge. When it's time to step down or wrap up, we work with you and your teen's outpatient provider to make sure there's a clear handoff and a plan in place.",
  },
];

const programs = [
  {
    tag: 'Our Approach',
    title: 'How we treat, explained plainly',
    body: 'DBT, polyvagal-informed care, and trauma-informed treatment, described in language you can follow without a clinical background.',
    href: '/what-we-offer/our-approach',
    link: 'See our approach →',
    accent: false,
  },
  {
    tag: 'Intensive Outpatient · IOP',
    title: 'Structured support, three days a week',
    body: 'Group therapy three days a week, while teens stay at home and in school.',
    href: '/what-we-offer/iop',
    link: 'Learn about IOP →',
    accent: true,
  },
  {
    tag: 'Partial Hospitalization · PHP',
    title: 'A full day of care, home each evening',
    body: 'A full day of structured treatment for teens who need more intensive support.',
    href: '/what-we-offer/php',
    link: 'Learn about PHP →',
    accent: false,
  },
];
---
<Base
  title="What We Offer — Joshua Tree Health"
  description="How Joshua Tree Health works for teens ages 10–17 in Apex, NC: what happens when you reach out, our IOP and PHP programs, and our clinical approach."
>
  <PageHero
    title="You're not the only parent who's searched 'teen therapist near me' at midnight."
    sub="You know something is off. You're just not sure what the options are, or whether what you're seeing warrants a higher level of care. That's what we're here to help you figure out."
    primaryCta={{ label: 'Start the Conversation', href: '/admissions' }}
  />

  <!-- ===== WHAT HAPPENS WHEN YOU REACH OUT ===== -->
  <section class="section" aria-labelledby="process-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What to expect</p>
        <h2 class="section-title font-display" id="process-title">Here's what happens when you reach out.</h2>
        <p class="section-sub">Before you make the call, it helps to know where the call leads. Here is the whole path, start to finish.</p>
      </div>
      <ol class="grid-4 wwo-steps" data-reveal-group>
        {steps.map((s) => (
          <li class="step" data-reveal-item>
            <span class="step__num">{s.num}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__body">{s.body}</p>
            {s.action && (
              <a href={s.action.href} class="link-arrow wwo-steps__action">{s.action.label}</a>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== PROGRAMS ===== -->
  <section class="section surface-cream-deep" aria-labelledby="programs-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Our programs</p>
        <h2 class="section-title font-display" id="programs-title">Where care happens.</h2>
        <p class="section-sub">Two levels of care and the clinical model behind them. If you're not sure which fits your teen, the first call will help you figure it out.</p>
      </div>
      <div class="grid-3" data-reveal-group>
        {programs.map((p) => (
          <article class={`program-card${p.accent ? ' program-card--accent' : ''}`} data-reveal-item>
            <p class="program-card__tag">{p.tag}</p>
            <h3 class="program-card__title font-display">{p.title}</h3>
            <p class="program-card__body">{p.body}</p>
            <a href={p.href} class="link-arrow">{p.link}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TEAM PREVIEW ===== -->
  <section class="section" aria-labelledby="team-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Our team</p>
        <h2 class="section-title font-display" id="team-title">Meet some of our clinical team.</h2>
        <p class="section-sub">Licensed clinicians who work with adolescents every day. You'll meet the people on your teen's care team early, so the program never feels like a black box.</p>
        {/* PLACEHOLDER: Gaby to supply team headshots, names, credentials, and one-line quotes — do not fabricate. Until then, link to the full team page. */}
        <a href="/about/team" class="link-arrow">See the full team →</a>
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section" aria-labelledby="start-title">
    <div class="container-x">
      <div class="callout surface-green" data-reveal>
        <div class="callout__text">
          <h2 class="section-title font-display" id="start-title">It's okay if you don't know what your teen needs yet.</h2>
          <p class="section-sub">That's what the first call is for. We'll figure it out together, and if we're not the right level of care, we'll help you find what is.</p>
        </div>
        <a href="/admissions" class="btn btn--on-dark callout__cta">Start the Conversation <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .wwo-steps { list-style: none; margin: 0; padding: 0; }
  .wwo-steps__action { margin-top: 0.4rem; }
</style>
