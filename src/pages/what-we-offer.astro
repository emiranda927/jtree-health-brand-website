---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const steps = [
  {
    num: '01',
    title: 'The first call',
    body: "You call or fill out the form. We'll ask about what's been going on, answer your questions, and help you figure out whether Joshua Tree is a good fit. No commitment, no pressure.",
    action: { label: 'Call (919) 335-5053', href: 'tel:+19193355053' },
  },
  {
    num: '02',
    title: 'Assessment',
    body: "If we seem like a match, we'll schedule an assessment with one of our licensed therapists. This is a structured clinical conversation with you and, when appropriate, your teen. It determines the right level of care and shapes the initial treatment plan.",
  },
  {
    num: '03',
    title: 'The program',
    // TODO: VERIFY PHP exact daily hours before publishing specifics.
    body: "Your teen starts in IOP or PHP, based on the assessment. IOP groups meet three to four days a week. PHP runs during the day, four to five days a week, and our admissions team will confirm the current schedule with you. Individual therapy, family therapy, and the core clinical work happen throughout. You'll be involved at every stage.",
  },
  {
    num: '04',
    title: 'Transition and discharge',
    body: "Before care ends, we work with your family and any outpatient providers to build a clear next-step plan. Your teen leaves knowing where support will come from next.",
  },
];

const programs = [
  {
    tag: 'Our approach',
    title: 'How we treat, explained plainly',
    body: 'How DBT skills, nervous-system awareness, and trauma-informed practice shape the work your teen does here.',
    href: '/what-we-offer/our-approach',
    link: 'See our approach →',
    accent: false,
  },
  {
    tag: 'Intensive outpatient · IOP',
    title: 'Structured support, three to four days a week',
    body: 'Group therapy three to four days a week, typically over 6–12 weeks. Teens go home every evening and stay connected to school.',
    href: '/what-we-offer/iop',
    link: 'Learn about IOP →',
    accent: true,
  },
  {
    tag: 'Partial hospitalization · PHP',
    title: 'A full day of structured treatment',
    body: 'For teens who need more support than IOP, typically over 2–6 weeks. Days in the program, evenings at home.',
    href: '/what-we-offer/php',
    link: 'Learn about PHP →',
    accent: false,
  },
  {
    tag: 'Clinical outcomes',
    title: 'How we measure progress',
    body: 'Standardized measures from intake through discharge. The team reviews the results while there is still time to adjust care.',
    href: '/about/outcomes',
    link: 'See our outcomes →',
    accent: false,
  },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Teen PHP & IOP Programs | Joshua Tree Health Apex, NC"
  description="Explore teen PHP and IOP programs in Apex, NC, including what happens after you call, how assessment works, and how the right level of care is selected."
>
  <PageHero
    art="group"
    title="Structured care, matched to what your teen needs right now."
    sub="IOP and PHP offer different amounts of support. The assessment tells us which level fits the moment your teen is in."
    primaryCta={{ label: 'Start the conversation', href: '/get-started' }}
  />

  <!-- ===== WHAT HAPPENS WHEN YOU REACH OUT ===== -->
  <section class="section" aria-labelledby="process-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What to expect</p>
        <h2 class="section-title font-display" id="process-title">Here's what happens when you reach out.</h2>
        <p class="section-sub">The first call should not feel like a leap into the unknown. Here is where it leads.</p>
      </div>
      <ol class="grid-4 wwo-steps" data-reveal-group>
        {steps.map((s) => (
          <li class="step" data-reveal-item>
            <span class="step__num">{s.num}</span>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__body">{s.body}</p>
            {s.action && (
              <a href={s.action.href} class="link-arrow wwo-steps__action">{s.action.label}</a>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== PROGRAMS ===== -->
  <section class="section surface-cream-deep" aria-labelledby="programs-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Our programs</p>
        <h2 class="section-title font-display" id="programs-title">Choose the question you need answered.</h2>
        <p class="section-sub">Read about the two levels of care, the methods behind them, or how we check progress. You can also call and let us point you to the right place.</p>
      </div>
      <div class="grid-4" data-reveal-group>
        {programs.map((p) => (
          <article class={`program-card${p.accent ? ' program-card--accent' : ''}`} data-reveal-item>
            <p class="program-card__tag">{p.tag}</p>
            <h3 class="program-card__title font-display">{p.title}</h3>
            <p class="program-card__body">{p.body}</p>
            <a href={p.href} class="link-arrow">{p.link}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TEAM PREVIEW ===== -->
  <section class="section" aria-labelledby="team-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Our team</p>
        <h2 class="section-title font-display" id="team-title">Meet some of our clinical team.</h2>
        <p class="section-sub">Licensed clinicians who work with adolescents every day. Admissions will explain who is involved in assessment, treatment, and communication with your family.</p>
        <a href="/about/team" class="link-arrow">See the full team →</a>
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section" aria-labelledby="start-title">
    <div class="container-x">
      <div class="callout surface-green" data-reveal>
        <div class="callout__text">
          <h2 class="section-title font-display" id="start-title">It's okay if you don't know what your teen needs yet.</h2>
          <p class="section-sub">That's what the first call is for. We'll work through it together, and if we're not the right level of care, we'll help you find what is.</p>
        </div>
        <a href="/get-started" class="btn btn--on-dark callout__cta">Start the conversation <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .wwo-steps { list-style: none; margin: 0; padding: 0; }
  .wwo-steps__action { margin-top: 0.4rem; }
</style>
