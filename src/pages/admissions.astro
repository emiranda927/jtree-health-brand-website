---
import Base from '../layouts/Base.astro';
import BrandPageHero from '../components/BrandPageHero.astro';

const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
const isLegacyAdmissionsRoute = Astro.url.pathname === '/admissions' || Astro.url.pathname === '/admissions/';

const steps = [
  { n: '01', t: 'Call us or complete the form', b: "Call (919) 335-5053 or fill out the short form below. We'll ask for some basic information about your teen and what's been going on. No commitment, no pressure." },
  { n: '02', t: 'Assessment with a licensed therapist', b: 'Your teen meets with a licensed therapist for a clinical assessment. It helps us determine whether IOP or PHP is the better fit and shapes the initial treatment plan.' },
  { n: '03', t: 'Start', b: 'Once the assessment is complete and your insurance is verified, we set a start date. A typical start is three to five days from first contact.' },
];
const ages = Array.from({ length: 8 }, (_, i) => 10 + i);
// value must match the API's ProgramInterest enum (IOP | PHP | Unsure)
const programs = [
  { value: 'IOP', label: 'IOP' },
  { value: 'PHP', label: 'PHP' },
  { value: 'Unsure', label: 'Not sure' },
];
const times = ['Morning', 'Afternoon', 'Evening'];
const sources = ['Google', 'Referral', 'Doctor', 'School', 'Other'];
const insurances = ['Aetna', 'BCBS NC', 'Cigna', 'UnitedHealthcare', 'UMR', 'Self-pay', 'Other'];
---
<Base
  bodyClass="brand-page admissions-page"
  title="Start Teen Mental Health Treatment | Joshua Tree Health Apex, NC"
  description="How to start adolescent IOP or PHP at Joshua Tree Health in Apex, NC: a call or short form, an assessment, and a typical start within three to five days."
  canonical="/get-started/"
  robots={isLegacyAdmissionsRoute ? 'noindex, follow' : undefined}
>
  <BrandPageHero
    eyebrow="Get started"
    title="Start with what <em>you know.</em>"
    sub="A call or short form is enough. Tell us what has changed, and we’ll help you understand the next step."
    primaryCta={{ label: 'Request a callback', href: '#inquiry-form' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
    facts={[
      { label: 'PHP + IOP', detail: 'Two levels of structured outpatient care' },
      { label: 'Ages 10–17', detail: 'Care designed for pre-teens and teens' },
      { label: '3–5 days', detail: 'Typical path from first contact to program start' },
    ]}
  >
    <div class="admissions-hero-art">
      <img class="admissions-hero-art__wash" src="/brand-v2/washes/wash-08.webp" alt="" aria-hidden="true" />
      <img class="admissions-hero-art__scene" src="/brand-v2/watercolor/one-on-one-therapy.webp" alt="Watercolor illustration of a teen meeting one-on-one with a therapist" />
      <img class="admissions-hero-art__tape" src="/brand-v2/tapes/tape-08.webp" alt="" aria-hidden="true" />
      <img class="admissions-hero-art__mark" src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
    </div>
  </BrandPageHero>

  <section class="section admissions-steps" aria-labelledby="admissions-steps-title">
    <div class="container-x admissions-steps__layout">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What happens next</p>
        <h2 class="section-title font-display" id="admissions-steps-title">What happens after you reach out.</h2>
        <p class="section-sub">If we're not the right fit, we'll tell you and help you find what is.</p>
      </div>
      <ol class="admissions-steps__grid" data-reveal-group>
        {steps.map((s) => (
          <li class="admission-step" data-reveal-item>
            <span class="step__num">{s.n}</span>
            <h2 class="step__title">{s.t}</h2>
            <p class="step__body">{s.b}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" aria-labelledby="ready-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal>
          <p class="eyebrow">Before you call</p>
          <h2 class="section-title font-display" id="ready-title">What to have ready.</h2>
          <ul class="checklist">
            <li>Your insurance card</li>
            <li>A general sense of what's been going on</li>
          </ul>
          <p class="ready-note">That's it.</p>
        </div>
        <div class="ready-facts" data-reveal data-reveal-delay="0.08">
          <div class="ready-fact">
            <h3>Ages 10–17</h3>
            <p>We work with adolescents ages 10–17. Programming is developmentally appropriate across that range, and our admissions team will explain how groups are organized for your child's age.</p>
          </div>
          <div class="ready-fact">
            <h3>Insurance</h3>
            <p>We'll verify your insurance benefits and walk you through expected costs before care begins. Self-pay is available. <a href="/insurance">More about insurance and costs →</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section surface-cream-deep" aria-labelledby="form-title">
    <div class="container-x admissions">
      <div class="admissions__intro" data-reveal>
        <img class="admissions__punct" src="/brand-v2/graphics/element-2-forest.svg" alt="" aria-hidden="true" />
        <p class="eyebrow">Request a callback</p>
        <h2 class="section-title font-display" id="form-title">A short form. The clinical details stay off the website.</h2>
        <p class="section-sub">You do not need a diagnosis or a complete history to reach out. Share only what we need to return your call. The admissions team can go over anything clinical by phone.</p>
        <ul class="checklist admissions__assure">
          <li>We answer questions about IOP, PHP, and cost</li>
          <li>We verify your insurance before care begins</li>
          <li>No waitlist. Reaching out does not commit you to care.</li>
        </ul>
      </div>

      <div class="admissions__formwrap" data-reveal data-reveal-delay="0.08">
        <div class="admissions__formhead">
          <p>Admissions inquiry</p>
          <span>Fields marked required help us return your call.</span>
        </div>
        <form class="form" id="inquiry-form" novalidate>
          <div class="form-error-banner" role="alert" aria-live="assertive"></div>

          <div class="form__row form__row--2">
            <div class="field field--req">
              <label for="name">Your name</label>
              <input id="name" name="name" type="text" autocomplete="name" required />
              <span class="jth-field-error" id="err-name"></span>
            </div>
            <div class="field field--req">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" required />
              <span class="jth-field-error" id="err-email"></span>
            </div>
          </div>

          <div class="form__row form__row--2">
            <div class="field field--req">
              <label for="phone">Phone</label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" required />
              <span class="jth-field-error" id="err-phone"></span>
            </div>
            <div class="field field--req">
              <label for="teen_age">Teen's age</label>
              <select id="teen_age" name="teen_age" required>
                <option value="">Select…</option>
                {ages.map((a) => <option value={a}>{a}</option>)}
              </select>
              <span class="jth-field-error" id="err-teen_age"></span>
            </div>
          </div>

          <div class="form__row form__row--2">
            <div class="field field--req">
              <label for="program_interest">Program of interest</label>
              <select id="program_interest" name="program_interest" required>
                <option value="">Select…</option>
                {programs.map((p) => <option value={p.value}>{p.label}</option>)}
              </select>
              <span class="jth-field-error" id="err-program_interest"></span>
            </div>
            <div class="field">
              <label for="best_time_to_call">Best time to call <span class="field__opt">(optional)</span></label>
              <select id="best_time_to_call" name="best_time_to_call">
                <option value="">No preference</option>
                {times.map((t) => <option value={t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div class="form__row form__row--2">
            <div class="field">
              <label for="insurance">Insurance <span class="field__opt">(optional)</span></label>
              <select id="insurance" name="insurance">
                <option value="">If you know it…</option>
                {insurances.map((i) => <option value={i}>{i}</option>)}
              </select>
            </div>
            <div class="field">
              <label for="zip">ZIP code <span class="field__opt">(optional)</span></label>
              <input id="zip" name="zip" type="text" inputmode="numeric" autocomplete="postal-code" maxlength="5" />
            </div>
          </div>

          <div class="form__row form__row--2">
            <div class="field">
              <label for="how_did_you_hear">How did you hear about us? <span class="field__opt">(optional)</span></label>
              <select id="how_did_you_hear" name="how_did_you_hear">
                <option value="">Select…</option>
                {sources.map((s) => <option value={s}>{s}</option>)}
              </select>
            </div>
            <div class="field"></div>
          </div>

          <div class="form__row">
            <div class="field">
              <label for="notes">Anything you'd like us to know? <span class="field__opt">(optional)</span></label>
              <textarea id="notes" name="notes" rows="3" maxlength="1000" placeholder="A sentence about what's been going on is plenty. No medical details, please."></textarea>
            </div>
          </div>

          <p class="form__disclaimer">By submitting, you’re asking Joshua Tree Health to contact you about care. Please do not include medical details in this website form.</p>

          {/* Honeypot: hidden from humans, catches bots */}
          <div class="hp" aria-hidden="true">
            <label for="hp_field">Leave this field empty</label>
            <input id="hp_field" name="hp_field" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <input type="hidden" id="session_id" name="session_id" value="" />

          {turnstileKey && <div id="cf-turnstile" class="cf-turnstile-box"></div>}

          <button type="submit" class="btn form__submit">Start the conversation <span class="btn__arrow">→</span></button>
          <p class="form__note">Prefer to talk now? Call <a href="tel:+19193355053" class="form__note-link">(919) 335-5053</a>.</p>
        </form>
      </div>
    </div>
  </section>
</Base>

{turnstileKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
)}
<script>
  import '../lib/inquiry';
</script>

<style>
  .admissions-hero-art { position: absolute; inset: 0; isolation: isolate; }
  .admissions-hero-art img { position: absolute; max-width: none; }
  .admissions-hero-art__wash { z-index: -1; width: 112%; left: 50%; top: 5%; opacity: .48; transform: translateX(-50%); }
  .admissions-hero-art__scene { z-index: 2; width: 103%; left: 50%; bottom: -2%; transform: translateX(-50%); }
  .admissions-hero-art__tape { z-index: 3; width: 28%; right: 3%; top: 8%; transform: rotate(12deg); }
  .admissions-hero-art__mark { z-index: 4; width: 15%; left: 2%; top: 7%; transform: rotate(-8deg); }

  .admissions-steps { background: var(--color-cream); }
  .admissions-steps__layout { display: grid; grid-template-columns: minmax(280px, .8fr) minmax(0, 1.2fr); gap: clamp(3rem, 7vw, 8rem); align-items: start; }
  .admissions-steps__layout .section-head { position: sticky; top: 110px; }
  .admissions-steps__grid { margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--color-line-strong); }
  .admission-step { display: grid; grid-template-columns: 5.5rem minmax(170px, .7fr) minmax(0, 1fr); gap: 1.5rem; align-items: baseline; padding: 1.8rem 0; border-bottom: 1px solid var(--color-line-strong); }
  .admission-step .step__num { font-family: var(--font-display); font-size: 2.8rem; font-weight: 700; line-height: 1; letter-spacing: -.05em; color: var(--color-lavender-deep); }
  .admission-step .step__title { font-size: 1.28rem; line-height: .98; text-transform: uppercase; letter-spacing: .02em; }
  .admission-step .step__body { font-family: var(--font-sans); font-size: 1.05rem; }

  .ready-note { margin-top: 1.1rem; font-size: 1.05rem; line-height: 1.55; color: var(--color-ink-soft); }
  .ready-facts { display: grid; gap: 1.75rem; align-content: start; }
  .ready-fact h3 { font-size: 1.12rem; line-height: 1.1; text-transform: uppercase; letter-spacing: .02em; color: var(--color-deep-green); margin-bottom: .5rem; }
  .ready-fact p { font-size: 1.05rem; line-height: 1.6; color: var(--color-ink-soft); }
  .ready-fact a { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }

  .admissions { display: grid; grid-template-columns: 1fr; gap: clamp(3rem, 6vw, 7rem); align-items: start; }
  .admissions__intro { position: sticky; top: 110px; }
  .admissions__punct { width: 76px; margin-bottom: 1.4rem; transform: rotate(-8deg); }
  .admissions__assure { margin-top: 1.6rem; }
  .admissions__formwrap { overflow: hidden; background: var(--color-cream-card); border: 1px solid var(--color-line-strong); box-shadow: 0 28px 60px -32px rgba(30, 61, 52, .32); }
  .admissions__formhead { display: flex; align-items: baseline; justify-content: space-between; gap: 1.5rem; padding: 1.25rem clamp(1.5rem, 3vw, 2.5rem); background: var(--color-deep-green); color: var(--color-cream); }
  .admissions__formhead p { font-family: var(--font-head); font-size: 1rem; line-height: 1.14; letter-spacing: .025em; text-transform: uppercase; }
  .admissions__formhead span { color: var(--color-cream-dim); font-size: 1rem; line-height: 1.45; }
  .admissions__formwrap .form { padding: clamp(1.5rem, 3vw, 2.5rem); }

  .form-error-banner { display: none; padding: 0.8rem 1rem; border-radius: var(--radius); background: #efe5ed; border: 1px solid #c9a9bf; color: #6f3158; font-size: 0.95rem; }
  .form-error-banner.is-visible { display: block; }
  .jth-field-error { font-size: 0.9rem; line-height: 1.4; color: #78355f; min-height: 0; }
  .jth-field-error:empty { display: none; }
  .field [aria-invalid="true"] { border-color: #874268; box-shadow: 0 0 0 3px rgba(135, 66, 104, .12); }
  .form__note-link { color: var(--color-pine); border-bottom: 1.5px solid var(--color-lime); }
  .field__opt { font-family: "Batica Sans", Arial, sans-serif; font-weight: 400; color: var(--color-ink-faint); font-size: 0.9rem; letter-spacing: 0; text-transform: none; }
  .form__disclaimer { font-size: 0.95rem; color: var(--color-ink-faint); line-height: 1.58; margin: 0; }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .cf-turnstile-box { min-height: 65px; }
  .btn.is-loading { opacity: 0.85; cursor: progress; }

  @media (min-width: 880px) { .admissions { grid-template-columns: .82fr 1.18fr; } }

  @media (max-width: 980px) {
    .admissions-hero-art { max-width: 660px; margin-inline: auto; }
    .admissions-steps__layout { grid-template-columns: 1fr; }
    .admissions-steps__layout .section-head, .admissions__intro { position: static; }
  }

  @media (max-width: 700px) {
    .admissions-hero-art__scene { width: 112%; }
    .admissions-hero-art__wash { width: 124%; }
    .admission-step { grid-template-columns: 4rem minmax(0, 1fr); gap: 1rem; }
    .admission-step .step__body { grid-column: 2; }
    .admissions__formhead { align-items: flex-start; flex-direction: column; gap: .5rem; }
  }
</style>
