---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const sections = [
  {
    id: 'not-overreacting',
    title: "You're not overreacting.",
    body: "If you're here, something has shifted. Maybe it's been building for a while. Maybe it happened fast. Whatever brought you to this page, trust that instinct. We're here to help you make sense of what your teen needs and what the options are.",
  },
  {
    id: 'what-to-expect',
    title: 'What to expect.',
    body: 'We offer PHP and IOP for adolescents ages 10–17. Both programs are structured and evidence-based, designed to build skills that last beyond the program itself. Programs run during the day or after school, so teens can stay at home and maintain family connection throughout treatment.',
  },
  {
    id: 'family-part-of-treatment',
    title: 'Family is part of the treatment — not a bystander to it.',
    body: "We don't just treat your teen. Family involvement is one of the strongest predictors of how well teens do during and after treatment. That's why family sessions are built into every treatment plan from day one. You'll be informed about how things are going, involved in setting goals, and given concrete tools to support your teen at home. You're not dropping your teen off and waiting to hear back.",
  },
  {
    id: 'clinically-rigorous',
    title: 'Clinically rigorous. Human throughout.',
    body: 'Our clinicians specialize in adolescent behavioral health. We take the severity of what teens are going through seriously, communicate clearly, and are here for your whole family, not just your teen.',
  },
];

const faqs = [
  {
    q: 'How do I know if my teen needs PHP vs. IOP?',
    a: "That's exactly what an admissions call is for. We'll ask about what's been going on, and together we'll figure out the right level of care, without pressure to commit to anything on the call.",
  },
  {
    q: 'Will I be kept in the loop during treatment?',
    a: "Yes. You'll have regular contact with your teen's treatment team throughout. You're not dropping your teen off and waiting to hear back — family involvement is built into how we work.",
  },
  {
    q: "What if my teen doesn't want to come?",
    a: "A lot of teens start there. The first step is the conversation with us — you don't need your teen to be on board before you make that call. We can help you think through how to approach it with them.",
  },
  {
    q: 'What happens after the program ends?',
    a: "We don't just discharge. We work with you and any outpatient providers on a clear handoff plan so your teen has support in place when they leave.",
  },
];
---
<Base
  title="For Parents — Joshua Tree Health"
  description="Serious PHP and IOP care for teens ages 10–17, with families involved from day one. Here's what to expect, and how we'll help you decide if Joshua Tree is the right fit."
>
  <PageHero
    title="Serious care for teens.<br>Support for <em>families</em>."
    sub="More support than weekly therapy. Less restrictive than hospitalization. We'll help you figure out if Joshua Tree is the right fit."
    primaryCta={{ label: 'Talk to Our Admissions Team', href: '/admissions' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <!-- ===== FOR PARENTS — FOUR CONTENT SECTIONS ===== -->
  <section class="section" aria-labelledby="not-overreacting-title">
    <div class="container-x">
      <div class="prose" data-reveal-group>
        {sections.map((s) => (
          <div data-reveal-item>
            <h2 class="section-title font-display" id={`${s.id}-title`}>{s.title}</h2>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section surface-cream-deep" aria-labelledby="parent-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="parent-faq-title">Questions parents ask.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="parent-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="parent-cta-title">Talk it through with us.</h2>
        <p class="section-sub">One call is enough to find out if Joshua Tree is the right fit. No commitment, no pressure.</p>
        <div class="parent-cta__actions">
          <a class="btn btn--on-dark" href="/admissions">Talk to Our Admissions Team <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .parent-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
