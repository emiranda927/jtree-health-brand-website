---
import Base from '../layouts/Base.astro';

// Condition cards follow the founder guide's format (EHR order), filtered
// through docs/CLAIM_REGISTER.md.
// TODO: VERIFY scope of staff trauma-informed and nervous-system-regulation training before
// restoring the guide's "every member of our clinical team is trained" line.
// The trauma card below describes the practice instead of the credential.
const conditions: { title: string; mark: string; bullets: string[]; help: string }[] = [
  {
    title: 'Depression & low mood',
    mark: 'element-11-colorway.svg',
    bullets: [
      'Persistent sadness, irritability, or hopelessness that doesn’t lift',
      'Pulling away from friends, family, or activities they used to enjoy',
      'Loss of energy or motivation that has lasted weeks',
      'Difficulty sleeping, eating, or getting through daily tasks',
      'Feeling like nothing matters or things won’t get better',
    ],
    help: 'Depression can make effort feel unavailable. A consistent week, connection with peers, and skills practiced in session give teens support they do not have to generate alone.',
  },
  {
    title: 'Anxiety & panic',
    mark: 'element-1-forest.svg',
    bullets: [
      'Worry that doesn’t turn off, even when there’s no clear reason for it',
      'Panic attacks or intense physical symptoms like a racing heart or trouble breathing',
      'Avoiding situations, places, or people to manage the fear',
      'Intense worry about social situations, school performance, or the future',
      'Difficulty sleeping or concentrating',
    ],
    help: 'Teens learn to recognize what happens in their body as anxiety rises and practice tools early enough to change what happens next.',
  },
  {
    title: 'ADHD & executive functioning',
    mark: 'element-13-deep-sage.svg',
    bullets: [
      'Difficulty paying attention or staying on task, even for things they care about',
      'Acting before thinking, or difficulty sitting still',
      'Forgetting things, losing track of time, or stalling out on tasks',
      'Emotional sensitivity, with big reactions to frustration or perceived failure',
      'Falling behind at school despite effort and ability',
    ],
    help: 'Years of working hard and still falling behind can wear down a teen’s confidence. We address the anxiety, low mood, impulsivity, and intense frustration that can make ADHD harder to live with.',
  },
  {
    title: 'Trauma & PTSD',
    mark: 'element-2-forest.svg',
    bullets: [
      'Flashbacks, nightmares, or intrusive memories',
      'Being on high alert, startling easily, or finding it hard to feel safe',
      'Emotional numbness or disconnection from people and activities',
      'Big reactions that seem out of proportion to what’s happening now',
      'Avoiding people, places, or situations tied to painful experiences',
    ],
    help: 'Care moves at the teen’s pace. We pay attention to what helps them stay present and never push for disclosure before they are ready.',
  },
  {
    title: 'Autism & social communication',
    mark: 'element-8-forest.svg',
    bullets: [
      'Difficulty reading social cues or navigating peer relationships',
      'Anxiety or meltdowns in social or sensory-heavy situations',
      'Rigid thinking patterns or difficulty with transitions',
      'Masking exhaustion: performing neurotypically in public and crashing at home',
      'Anxiety or depression occurring alongside autism',
    ],
    help: 'Care focuses on the anxiety, low mood, overload, and relationship stress that can make daily life harder. Group gives teens a lower-pressure place to practice connection.',
  },
  {
    title: 'Emotional dysregulation & mood',
    mark: 'element-9-colorway.svg',
    bullets: [
      'Big emotional reactions that feel uncontrollable or come out of nowhere',
      'Difficulty calming down after frustration or conflict',
      'Rapid mood shifts',
      'Impulsive decisions or behaviors during emotional moments',
      'Intense conflict in relationships that keep turning chaotic',
    ],
    help: 'DBT gives teens concrete ways to get through intense moments, understand what set them off, and handle conflict with more choice.',
  },
  {
    title: 'OCD & intrusive thoughts',
    mark: 'element-5-forest.svg',
    bullets: [
      'Intrusive, repetitive thoughts that are hard to dismiss',
      'Compulsive behaviors or rituals that take up significant time',
      'Needing things to feel exactly right before moving forward',
      'Avoiding situations that trigger obsessive thoughts',
      'Reassurance-seeking that never relieves the anxiety for long',
    ],
    help: 'Skills-based group and individual therapy help teens recognize and interrupt the OCD cycle, so intrusive thoughts have less power over daily life.',
  },
  {
    title: 'School avoidance & academic decline',
    mark: 'element-4-forest.svg',
    bullets: [
      'Frequent absences or refusal to attend school',
      'Stomachaches or headaches that show up before school',
      'Difficulty concentrating or a sudden drop in performance',
      'Intense worry about social situations or academic pressure',
      'Missing so much school that catching up feels impossible',
    ],
    help: 'We work with teens and families to understand what’s underneath the avoidance, whether that’s anxiety, depression, trauma, or burnout, and build the skills and confidence to re-engage, one step at a time.',
  },
];

// TODO: VERIFY current practice for school coordination while a teen is in PHP
// (the school FAQ promises planning help only, no coordination guarantee).
// TODO: VERIFY scope of care coordination with outside providers at discharge
// (register: describe as "as clinically indicated" only).
const faqs = [
  {
    question: 'What ages do you serve?',
    answer: 'Adolescents ages 10–17. Programming is developmentally appropriate across that range, and our admissions team can explain how groups are organized for your child’s age.',
  },
  {
    question: 'Does my teen need a formal diagnosis to start?',
    answer: 'No. During the assessment with a licensed therapist, we get to know your teen’s history and what’s been going on. That’s how we figure out whether our level of care is a good fit.',
  },
  {
    question: 'How do I know if my teen needs IOP or PHP?',
    answer: 'You’ll find out through the assessment. Call our admissions team and describe the situation. If it seems like a match, we’ll schedule a clinical assessment with a licensed therapist, and that assessment determines which level fits.',
  },
  {
    question: 'Will my teen have to be hospitalized?',
    answer: 'No. IOP and PHP are outpatient, so teens go home every evening. We’re designed for teens who need more than weekly therapy but don’t require inpatient care.',
  },
  {
    question: 'Can my teen stay in school during the program?',
    answer: 'Yes. IOP meets Monday, Wednesday, and Thursday, with an afternoon group (3:30–6:30pm) after school or a morning group (9am–12pm). PHP runs during the day, so school attendance is paused while a teen is in PHP. Admissions will help you plan for this.',
  },
  {
    question: 'How involved will I be as a parent?',
    answer: 'Very. Family therapy is built into treatment, and parents build the same skills their teen is practicing as part of that work. Admissions will explain how family involvement is structured.',
  },
  {
    question: 'What if my teen doesn’t want to come?',
    answer: 'Many teens start there. Call before you’ve figured that part out. We can help you think through how to approach it with them.',
  },
  {
    question: 'What happens when the program ends?',
    answer: 'Transition planning starts during treatment. We coordinate with outside providers, as clinically indicated, so there’s a clear plan for what comes next. Your teen doesn’t leave without a next step.',
  },
  {
    question: 'Does insurance cover this?',
    answer: 'Coverage depends on your specific plan. We’ll verify your insurance benefits and walk you through expected costs before care begins.',
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<Base
  bodyClass="brand-page treat-page"
  title="Teen Depression, Anxiety & Trauma Care | Joshua Tree Health"
  description="What we treat at Joshua Tree Health in Apex, NC: teen depression, anxiety, ADHD, trauma, OCD, autism, and school avoidance. PHP and IOP for ages 10–17."
  jsonLd={faqSchema}
>
  {/* Hero imported from Claude Design (WhatWeTreat.dc.html) — collage moment + facts strip.
      --jt-* tokens defined on the wrapper map to the site's brand-page values. */}
  <div
    class="treat-dc-hero"
    style="--jt-forest:#1e3d34;--jt-deep-sage:#2c5f52;--jt-cyber-lime:#b8e04a;--jt-digital-lavender:#a89fd8;--jt-cream:#fffaf3;--jt-cream-card:#fffdf8;--jt-ink-soft:#4d625b;--jt-ink-faint:#667970;--jt-line:rgba(30,61,52,.16);--shadow-lg:0 30px 60px -22px rgba(30,61,52,.28),0 12px 24px -14px rgba(30,61,52,.12);--font-display:'Batica Sans',Arial,sans-serif;--font-label:'Misoka','Batica Sans',Arial,sans-serif;--font-editorial:'Fraunces SuperSoft',Georgia,serif;font-family:var(--font-editorial);background:var(--jt-cream);color:var(--jt-ink-soft)"
  >
    <!-- ============ HERO — collage moment ============ -->
    <section style="position:relative;overflow:hidden;padding:clamp(1.75rem,1rem + 2.5vw,3.25rem) clamp(1.25rem,2.75vw,2.75rem) clamp(2.25rem,1.5rem + 3vw,4rem)">
      <div class="treat-dc-hero__grid" style="position:relative;max-width:78rem;margin-inline:auto;display:grid;grid-template-columns:minmax(0,1.02fr) minmax(0,1fr);gap:clamp(1.5rem,3vw,3.25rem);align-items:center">
        <div style="position:relative;z-index:2">
          <h1 style="font-family:var(--font-display);font-weight:700;font-size:clamp(2.9rem,1.4rem + 6.2vw,5.3rem);line-height:.9;letter-spacing:-.038em;margin:0;color:var(--jt-forest);text-wrap:balance">What we <span style="color:var(--jt-deep-sage)">treat.</span></h1>
          <p style="font-size:clamp(1.05rem,1rem + .45vw,1.32rem);line-height:1.6;color:var(--jt-ink-soft);max-width:31rem;margin:1.35rem 0 0;text-wrap:pretty">Maybe school has become impossible. Maybe your teen cannot settle, sleep, or let anyone close. Start with what you see. We’ll work from there.</p>
          <div style="display:flex;flex-wrap:wrap;gap:.85rem;margin-top:1.9rem">
            <a href="/get-started" class="btn">Start the conversation <span class="btn__arrow">→</span></a>
            <a href="tel:+19193355053" class="btn btn--ghost">Call (919) 335-5053</a>
          </div>
          <div style="display:flex;align-items:center;gap:.65rem;margin-top:1.5rem">
            <span style="width:13px;height:13px;background:var(--jt-digital-lavender);transform:rotate(45deg);flex:none"></span>
            <span style="font-size:1rem;color:var(--jt-ink-soft)">You don’t need a diagnosis before you call.</span>
          </div>
        </div>
        <div class="treat-dc-hero__artcell">
        <div class="treat-dc-hero__art" style="position:relative;min-height:clamp(490px,38vw,580px)">
          <img src="/brand-v2/washes/wash-01.webp" alt="" style="position:absolute;z-index:1;top:-10px;left:18px;width:72%;transform:rotate(-7deg);opacity:.9;pointer-events:none" />
          <img src="/brand-v2/washes/wash-03.webp" alt="" style="position:absolute;z-index:1;top:-2%;right:2%;width:46%;transform:rotate(6deg);opacity:.75;pointer-events:none" />
          <img src="/brand-v2/collage/joshua-tree-cut-collage.webp" alt="A Joshua tree framed inside torn paper" style="position:absolute;z-index:2;top:-69px;left:106px;width:438px;height:406px;filter:drop-shadow(0 26px 42px rgba(30,61,52,.22))" />
          <div style="position:absolute;z-index:4;width:min(465px,82%);background:var(--jt-cream-card);box-shadow:var(--shadow-lg);padding:1.35rem 1.5rem 1.25rem;transform:rotate(-1.2deg);left:90px;top:300px">
            <div style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:.08em;font-size:.72rem;color:var(--jt-deep-sage)">Some things we help families with</div>
            <div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:.55rem 1rem;margin-top:.95rem">
              <div style="display:flex;align-items:center;gap:.5rem;min-width:0"><span style="width:7px;height:7px;border-radius:50%;background:var(--jt-digital-lavender);flex:none"></span><span style="font-family:var(--font-display);font-weight:700;font-size:1.02rem;color:var(--jt-forest)">Depression</span></div>
              <div style="display:flex;align-items:center;gap:.5rem;min-width:0"><span style="width:7px;height:7px;border-radius:50%;background:var(--jt-digital-lavender);flex:none"></span><span style="font-family:var(--font-display);font-weight:700;font-size:1.02rem;color:var(--jt-forest)">Anxiety</span></div>
              <div style="display:flex;align-items:center;gap:.5rem;min-width:0"><span style="width:7px;height:7px;border-radius:50%;background:var(--jt-digital-lavender);flex:none"></span><span style="font-family:var(--font-display);font-weight:700;font-size:1.02rem;color:var(--jt-forest)">ADHD</span></div>
              <div style="display:flex;align-items:center;gap:.5rem;min-width:0"><span style="width:7px;height:7px;border-radius:50%;background:var(--jt-digital-lavender);flex:none"></span><span style="font-family:var(--font-display);font-weight:700;font-size:1.02rem;color:var(--jt-forest)">Neurodivergence</span></div>
            </div>
            <div style="border-top:1px solid var(--jt-line);margin-top:1rem;padding-top:.8rem;font-size:.9rem;color:var(--jt-ink-faint);font-style:italic">School avoidance, mood changes, and more →</div>
          </div>
          <svg viewBox="0 0 1000 1000" aria-hidden="true" style="display:block;width:68px;height:72px"><path d="M603.09,358.87c54.12-74.78,131.03-252.93,195.36-307.92,43.03-36.63,121.01-38.98,124.21,30.7,2.98,64.57-137.63,232.25-165.54,300.68,327.88-124.05,250.11,149.14-11.72,148.1,41.12,56.45,189.19,150.65,175.55,222.02-30.47,159.82-259.49-100.14-329.37-109.51-21.94,68.82-29.19,318.98-95.02,349.03-30.68,14.06-59.02,11.09-73.93-20.44-31.32-66.5,40.48-312.4,38.56-399.57-14.91-14.27-309.98,96.34-331.5-30.26-18.32-108.68,115.68-84.15,165.75-135.32-53.05-28.98-243.94-112.51-263.54-157.24-22.37-51.58,26.42-89.52,77.12-77.36l316.37,151.72c5.75-78.63-153.39-250.17-77.98-308.78,67.11-52,100.98,46.9,123.78,91.63,29.61,58.4,71.37,199.03,103.12,240.17,9.16,11.92,12.36,15.75,28.76,12.58v-.24Z" fill="var(--jt-cyber-lime)" stroke="var(--jt-forest)" stroke-width="34" stroke-linejoin="round"></path></svg>
          <img src="/brand/collage-dot-grid-sparse.svg" alt="" style="position:absolute;z-index:1;top:-80px;left:265px;width:299px;height:310px;opacity:.5;pointer-events:none" />
          <img src="/brand-v2/washes/wash-09.webp" alt="" style="position:absolute;z-index:1;left:32px;top:259px;width:255px;height:193px;opacity:.8;pointer-events:none" />
        </div>
        <div class="treat-dc-hero__art-mobile" aria-hidden="true">
          <div class="treat-dc-hero__tree-wrap">
            <img class="wash" src="/brand-v2/washes/wash-03.webp" alt="" />
            <img class="tree" src="/brand-v2/collage/joshua-tree-cut-collage.webp" alt="A Joshua tree framed inside torn paper" />
          </div>
          <div class="treat-dc-hero__card-m">
            <div class="card-label">Some things we help families with</div>
            <ul class="card-list">
              <li>Depression</li>
              <li>Anxiety</li>
              <li>ADHD</li>
              <li>Neurodivergence</li>
            </ul>
            <div class="card-foot">School avoidance, mood changes, and more →</div>
          </div>
        </div>
        </div>
      </div>
    </section>

    <!-- ============ Facts strip ============ -->
    <section style="padding:0 clamp(1.25rem,2.75vw,2.75rem) clamp(2.25rem,1.5rem + 3vw,3.75rem)">
      <div class="treat-dc-hero__facts" style="max-width:78rem;margin-inline:auto;border-top:1px solid var(--jt-line);display:grid;grid-template-columns:repeat(3,1fr)">
        <div style="padding:1.3rem 1.5rem 0 0;border-right:1px solid var(--jt-line)">
          <div style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:.04em;font-size:1rem;color:var(--jt-forest)">Ages 10–17</div>
          <div style="font-size:1.02rem;color:var(--jt-ink-soft);margin-top:.35rem">Adolescent-focused care</div>
        </div>
        <div style="padding:1.3rem 1.5rem 0;border-right:1px solid var(--jt-line)">
          <div style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:.04em;font-size:1rem;color:var(--jt-forest)">PHP • IOP</div>
          <div style="font-size:1.02rem;color:var(--jt-ink-soft);margin-top:.35rem">Care matched to clinical need</div>
        </div>
        <div style="padding:1.3rem 0 0 1.5rem">
          <div style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:.04em;font-size:1rem;color:var(--jt-forest)">Whole family</div>
          <div style="font-size:1.02rem;color:var(--jt-ink-soft);margin-top:.35rem">Parents involved from day one</div>
        </div>
      </div>
    </section>
  </div>

  <section class="section treat-intro" aria-labelledby="intro-title">
    <div class="container-x treat-intro__layout">
      <div data-reveal>
        <p class="eyebrow">Start with what you see</p>
        <h2 class="section-title font-display" id="intro-title">You don’t need a diagnosis before you call.</h2>
      </div>
      <div class="treat-intro__copy" data-reveal data-reveal-delay="0.08">
        <p>Maybe your teen has a diagnosis. Maybe you only know that something has changed: school feels impossible, emotions are harder to manage, or they’re pulling away from the life they used to have.</p>
        <p>Many of the teens we support arrive looking like the descriptions below. If any of this feels familiar, tell us what you’re seeing. We’ll help you understand whether this level of care fits and what the next step should be.</p>
      </div>
    </div>
  </section>

  <section class="section condition-index" aria-labelledby="conditions-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What we work with</p>
        <h2 class="section-title font-display" id="conditions-title">The concerns families bring us most often.</h2>
      </div>

      <div class="condition-index__list" data-reveal-group>
        {conditions.map((condition, index) => (
          <article class="condition-row" data-reveal-item>
            <span class="condition-row__index">{String(index + 1).padStart(2, '0')}</span>
            <img class="condition-row__mark" src={`/brand-v2/graphics/${condition.mark}`} alt="" aria-hidden="true" />
            <h2>{condition.title}</h2>
            <div class="condition-row__content">
              <p class="condition-row__label">What it looks like</p>
              <ul>
                {condition.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <div class="condition-row__help">
                <p class="condition-row__label">How we help</p>
                <p>{condition.help}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="condition-index__note" data-reveal>We also work with teens navigating grief and loss, life transitions, behavior challenges, and other concerns not listed here. If you’re not sure whether what your teen is going through fits, call us. We’ll help you figure it out.</p>
    </div>
  </section>

  <section class="section treat-approach" aria-labelledby="approach-title">
    <div class="container-x treat-approach__layout">
      <div class="treat-approach__art" data-reveal>
        <img class="treat-approach__wash" src="/brand-v2/washes/wash-09.webp" alt="" aria-hidden="true" />
        <img class="treat-approach__spot" src="/brand-v2/spots/art-therapy.svg" alt="Illustration representing creative expression in treatment" loading="lazy" />
        <img class="treat-approach__punct" src="/brand-v2/halos/halo-9-lavender.svg" alt="" aria-hidden="true" />
      </div>
      <div data-reveal data-reveal-delay="0.08">
        <p class="eyebrow">Our approach</p>
        <h2 class="section-title font-display" id="approach-title">Care should fit the teen, not the label.</h2>
        <p class="section-sub">We build each plan around what is happening in daily life, what your teen needs now, and what they are ready to work on.</p>
        <a href="/what-we-offer/our-approach" class="link-arrow">See how we work →</a>
      </div>
    </div>
  </section>

  <section class="section treat-steps" aria-labelledby="steps-title">
    <div class="container-x treat-steps__layout">
      <div class="section-head" data-reveal>
        <p class="eyebrow">For parents</p>
        <h2 class="section-title font-display" id="steps-title">What to expect when you reach out.</h2>
      </div>
      <div>
        <ol class="treat-steps__grid" data-reveal-group>
          <li class="treat-step" data-reveal-item>
            <span class="step__num">01</span>
            <h3 class="step__title">Call our admissions team.</h3>
            <p class="step__body">One call is enough to start figuring out whether Joshua Tree is the right fit. No commitment, no pressure. We’ll ask about what’s been going on and answer your questions.</p>
          </li>
          <li class="treat-step" data-reveal-item>
            <span class="step__num">02</span>
            <h3 class="step__title">Assessment with a licensed therapist.</h3>
            <p class="step__body">If it looks like a match, we’ll schedule a clinical assessment with one of our licensed therapists. That assessment determines whether IOP or PHP fits and begins the treatment plan.</p>
          </li>
          <li class="treat-step" data-reveal-item>
            <span class="step__num">03</span>
            <h3 class="step__title">The program begins.</h3>
            <p class="step__body">Your teen starts in groups, with individual therapy alongside the group program, and family involvement is built in from the start. A typical start is three to five days from first contact, and there’s no waitlist.</p>
          </li>
        </ol>
        <a href="/get-started" class="btn" data-reveal>Start the conversation <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>

  <section class="section treat-faq surface-cream-deep" aria-labelledby="faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Common questions</p>
        <h2 class="section-title font-display" id="faq-title">Questions parents ask first.</h2>
      </div>
      <div data-reveal>
        <div class="faq">
          {faqs.map((faq) => (
            <details class="faq__item">
              <summary>{faq.question}</summary>
              <div class="faq__answer"><p>{faq.answer}</p></div>
            </details>
          ))}
        </div>
        <a href="/insurance" class="link-arrow">See insurance details →</a>
      </div>
    </div>
  </section>

  <section class="treat-cta" aria-labelledby="fit-title">
    <div class="container-x treat-cta__inner" data-reveal>
      <img src="/brand-v2/graphics/element-2-forest.svg" alt="" aria-hidden="true" />
      <div>
        <p class="eyebrow">Not sure where this fits?</p>
        <h2 class="font-display" id="fit-title">Tell us what has changed.</h2>
      </div>
      <div>
        <p>We’ll talk it through. If another level of care makes more sense, we’ll say so clearly and help you understand the options.</p>
        <a href="/get-started" class="btn btn--on-dark">Start the conversation <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero imported from Claude Design (WhatWeTreat.dc.html); its styles are inline on the markup.
     Desktop shows the exact fixed-position collage; below 800px it swaps to a reflowing
     mobile variant (.treat-dc-hero__art-mobile) so nothing overlaps or clips. */
  .treat-dc-hero__art-mobile { display: none; }
  .treat-dc-hero__tree-wrap { position: relative; width: 100%; max-width: 360px; margin: 0 auto; }
  .treat-dc-hero__tree-wrap .wash { position: absolute; z-index: 0; top: -6%; left: -8%; width: 86%; opacity: .62; transform: rotate(-6deg); pointer-events: none; }
