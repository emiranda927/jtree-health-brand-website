  .treat-dc-hero__card-m { position: relative; z-index: 2; width: 100%; max-width: 380px; margin: -1.75rem auto 0; background: var(--jt-cream-card); box-shadow: var(--shadow-lg); padding: 1.2rem 1.35rem; transform: rotate(-1deg); }
