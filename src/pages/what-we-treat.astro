---
import Base from '../layouts/Base.astro';
import BrandPageHero from '../components/BrandPageHero.astro';

const conditions = [
  { title: 'Anxiety & panic', body: 'Overwhelming worry, panic attacks, and the avoidance that builds up around them.', mark: 'element-1-forest.svg' },
  { title: 'Depression', body: 'Low mood, hopelessness, withdrawal, and the heaviness that makes daily life hard.', mark: 'element-11-colorway.svg' },
  { title: 'Trauma & PTSD', body: 'The lasting weight of frightening or painful experiences, met with trauma-informed care.', mark: 'element-2-forest.svg' },
  { title: 'Self-harm & safety', body: 'Self-harming behaviors and safety concerns, addressed with structure and without judgment.', mark: 'element-13-deep-sage.svg', crisis: true },
  { title: 'Suicidal ideation', body: 'Suicidal thoughts that need more support than weekly therapy, but do not require hospitalization.', mark: 'element-8-forest.svg', crisis: true },
  { title: 'School avoidance', body: 'School refusal and the anxiety, perfectionism, or burnout underneath it.', mark: 'element-4-forest.svg' },
  { title: 'Emotional dysregulation', body: 'Big emotions and impulsive reactions, and the skills to manage them.', mark: 'element-9-colorway.svg' },
  { title: 'OCD & related', body: 'Intrusive thoughts and compulsions that have taken up too much room.', mark: 'element-5-forest.svg' },
  { title: 'Grief & loss', body: 'Loss, life change, and grief that does not follow a straight line.', mark: 'element-14-colorway.svg' },
];
---

<Base
  bodyClass="brand-page treat-page"
  title="What We Treat — Joshua Tree Health"
  description="Anxiety, depression, trauma, self-harm, school avoidance and more — evidence-based PHP and IOP care for teens ages 10–17 in Apex, NC."
>
  <BrandPageHero
    eyebrow="What we treat"
    title="Support for what is taking up <em>too much room.</em>"
    sub="We help teens work through anxiety, depression, trauma, safety concerns, and other struggles that are disrupting school, relationships, or daily life."
    primaryCta={{ label: 'Start the conversation', href: '/admissions' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
    facts={[
      { label: 'Ages 10–17', detail: 'Adolescent-focused care' },
      { label: 'PHP + IOP', detail: 'Care matched to clinical need' },
      { label: 'Whole family', detail: 'Parents involved from day one' },
    ]}
  >
    <div class="treat-hero-art">
      <img class="treat-hero-art__wash treat-hero-art__wash--lavender" src="/brand-v2/washes/wash-03.webp" alt="" aria-hidden="true" />
      <img class="treat-hero-art__wash treat-hero-art__wash--lime" src="/brand-v2/washes/wash-09.webp" alt="" aria-hidden="true" />
      <img class="treat-hero-art__anxious" src="/brand-v2/spots/anxious.svg" alt="Illustration of a character surrounded by many thoughts" />
      <img class="treat-hero-art__happy" src="/brand-v2/spots/happy.svg" alt="Illustration of a character expressing relief and hope" />
      <img class="treat-hero-art__mark" src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
    </div>
  </BrandPageHero>

  <section class="section treat-intro" aria-labelledby="intro-title">
    <div class="container-x treat-intro__layout">
      <div data-reveal>
        <p class="eyebrow">Start with what you see</p>
        <h2 class="section-title font-display" id="intro-title">You do not need the diagnosis before you call.</h2>
      </div>
      <div class="treat-intro__copy" data-reveal data-reveal-delay="0.08">
        <p>Maybe your teen has a diagnosis. Maybe you only know that something has changed: school feels impossible, emotions are harder to manage, or they are pulling away from the life they used to have.</p>
        <p>Tell us what you are seeing. We will help you understand whether this level of care fits and what the next step should be.</p>
      </div>
    </div>
  </section>

  <section class="section condition-index" aria-labelledby="conditions-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What we work with</p>
        <h2 class="section-title font-display" id="conditions-title">The struggles that walk through our door.</h2>
      </div>

      <div class="condition-index__list" data-reveal-group>
        {conditions.map((condition, index) => (
          <article class="condition-row" data-reveal-item>
            <span class="condition-row__index">{String(index + 1).padStart(2, '0')}</span>
            <img class="condition-row__mark" src={`/brand-v2/graphics/${condition.mark}`} alt="" aria-hidden="true" />
            <h3>{condition.title}</h3>
            <div>
              <p>{condition.body}</p>
              {condition.crisis && <a href="/crisis">Need immediate help? View crisis resources →</a>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section treat-approach" aria-labelledby="approach-title">
    <div class="container-x treat-approach__layout">
      <div class="treat-approach__art" data-reveal>
        <img class="treat-approach__wash" src="/brand-v2/washes/wash-09.webp" alt="" aria-hidden="true" />
        <img class="treat-approach__spot" src="/brand-v2/spots/art-therapy.svg" alt="Illustration representing creative expression in treatment" loading="lazy" />
        <img class="treat-approach__punct" src="/brand-v2/halos/halo-9-lavender.svg" alt="" aria-hidden="true" />
      </div>
      <div data-reveal data-reveal-delay="0.08">
        <p class="eyebrow">Our approach</p>
        <h2 class="section-title font-display" id="approach-title">Treat the person, not just the diagnosis.</h2>
        <p class="section-sub">Evidence guides the plan. The teen in front of us shapes how that plan is delivered. We combine structured treatment, practical skills, and family involvement without reducing someone to a list of symptoms.</p>
        <a href="/what-we-offer/our-approach" class="link-arrow">See our full approach →</a>
      </div>
    </div>
  </section>

  <section class="treat-cta" aria-labelledby="fit-title">
    <div class="container-x treat-cta__inner" data-reveal>
      <img src="/brand-v2/graphics/element-2-forest.svg" alt="" aria-hidden="true" />
      <div>
        <p class="eyebrow">Not sure where this fits?</p>
        <h2 class="font-display" id="fit-title">Tell us what is happening at home.</h2>
      </div>
      <div>
        <p>We will talk it through. If another level of care makes more sense, we will say so clearly and help you understand the options.</p>
        <a href="/admissions" class="btn btn--on-dark">Start the conversation <span class="btn__arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  .treat-hero-art { position: absolute; inset: 0; isolation: isolate; }
  .treat-hero-art img { position: absolute; max-width: none; }
  .treat-hero-art__wash--lavender { z-index: -2; width: 105%; left: 50%; top: 8%; opacity: .76; transform: translateX(-50%) rotate(-3deg); }
  .treat-hero-art__wash--lime { z-index: -1; width: 52%; right: -8%; bottom: 0; opacity: .7; transform: rotate(7deg); }
  .treat-hero-art__anxious { z-index: 2; width: 70%; left: -7%; bottom: -1%; }
  .treat-hero-art__happy { z-index: 3; width: 52%; right: -4%; top: 2%; transform: rotate(2deg); }
  .treat-hero-art__mark { z-index: 4; width: 13%; right: 2%; bottom: 3%; transform: rotate(9deg); }

  .treat-intro { background: var(--color-cream); }
  .treat-intro__layout { display: grid; grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr); gap: clamp(3rem, 8vw, 9rem); align-items: start; }
  .treat-intro__copy { max-width: 46rem; display: grid; gap: 1.3rem; font-size: clamp(1.15rem, 1.5vw, 1.4rem); line-height: 1.58; color: var(--color-ink-soft); }

  .condition-index { background: var(--color-cream-deep); }
  .condition-index .section-head { max-width: 840px; }
  .condition-index__list { border-top: 1px solid var(--color-line-strong); }
  .condition-row { display: grid; grid-template-columns: 4.2rem 4.5rem minmax(210px, .72fr) minmax(0, 1.28fr); gap: clamp(1rem, 2.5vw, 2.5rem); align-items: center; padding: 1.55rem 0; border-bottom: 1px solid var(--color-line-strong); }
  .condition-row__index { font-family: var(--font-display); font-size: 2.35rem; font-weight: 700; line-height: 1; letter-spacing: -.05em; color: var(--color-lavender-deep); }
  .condition-row__mark { width: 58px; height: 58px; object-fit: contain; }
  .condition-row h3 { font-family: var(--font-head); font-size: clamp(1.05rem, 1.4vw, 1.32rem); font-weight: 900; line-height: .98; letter-spacing: .02em; text-transform: uppercase; }
  .condition-row p { max-width: 48rem; font-size: 1.1rem; line-height: 1.58; color: var(--color-ink-soft); }
  .condition-row a { display: inline-block; margin-top: .65rem; border-bottom: 2px solid var(--color-lavender); font-family: var(--font-head); font-size: 1rem; line-height: 1.25; letter-spacing: .015em; text-transform: uppercase; color: var(--color-deep-green); }

  .treat-approach { overflow: hidden; background: var(--color-lavender-soft); }
  .treat-approach__layout { display: grid; grid-template-columns: minmax(0, .9fr) minmax(0, 1.1fr); gap: clamp(3rem, 8vw, 9rem); align-items: center; }
  .treat-approach__art { position: relative; min-height: 520px; isolation: isolate; }
  .treat-approach__wash { position: absolute; z-index: -1; width: 110%; max-width: none; left: 50%; top: 4%; opacity: .62; transform: translateX(-50%) rotate(-4deg); }
  .treat-approach__spot { position: absolute; width: 100%; max-width: none; left: 50%; bottom: 0; transform: translateX(-50%); }
  .treat-approach__punct { position: absolute; width: 16%; right: 1%; top: 2%; transform: rotate(8deg); }
  .treat-approach .link-arrow { margin-top: 1.8rem; }

  .treat-cta { padding-block: clamp(5rem, 9vw, 9rem); background: var(--color-deep-green); color: var(--color-cream); }
  .treat-cta__inner { display: grid; grid-template-columns: 6rem minmax(0, 1fr) minmax(280px, .72fr); gap: clamp(2rem, 5vw, 5rem); align-items: center; }
  .treat-cta__inner > img { width: 82px; filter: brightness(0) saturate(100%) invert(91%) sepia(35%) saturate(943%) hue-rotate(27deg) brightness(101%); }
  .treat-cta h2 { max-width: 12ch; margin-top: 1rem; color: var(--color-cream); font-size: clamp(3rem, 5vw, 5.4rem); }
  .treat-cta__inner > div:last-child p { max-width: 34rem; color: var(--color-cream-dim); font-size: 1.15rem; line-height: 1.55; }
  .treat-cta .btn { margin-top: 1.7rem; }
  .treat-cta .eyebrow { color: var(--color-lime); }

  @media (max-width: 980px) {
    .treat-hero-art { max-width: 680px; margin-inline: auto; }
    .treat-intro__layout, .treat-approach__layout { grid-template-columns: 1fr; }
    .treat-approach__art { max-width: 620px; }
    .treat-cta__inner { grid-template-columns: 5rem 1fr; }
    .treat-cta__inner > div:last-child { grid-column: 2; }
  }

  @media (max-width: 700px) {
    .treat-hero-art__anxious { width: 78%; left: -11%; }
    .treat-hero-art__happy { width: 58%; right: -8%; }
    .condition-row { grid-template-columns: 3rem 3.5rem minmax(0, 1fr); align-items: start; }
    .condition-row__index { font-size: 1.8rem; }
    .condition-row__mark { width: 44px; height: 44px; }
    .condition-row > div { grid-column: 3; }
    .treat-approach__art { min-height: 390px; }
    .treat-cta__inner { grid-template-columns: 1fr; }
    .treat-cta__inner > img { width: 68px; }
    .treat-cta__inner > div:last-child { grid-column: auto; }
  }
</style>
