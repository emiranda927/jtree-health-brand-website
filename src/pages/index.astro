---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import heroImg from '../assets/images/joshua-tree-hero.webp';

const referrers = ['UNC Health', 'WakeMed', 'Duke Health', 'Triangle Pediatrics'];
---
<Base>
  <!-- ============================ HERO — cinematic full-bleed ============================ -->
  <section class="hero" data-hero-scope aria-labelledby="hero-title">
    <div class="hero__media" data-parallax="0.18">
      <Image
        src={heroImg}
        alt="Five teens sitting together under a Joshua tree at golden hour on a desert ridge"
        widths={[768, 1280, 1760, 2200]}
        sizes="100vw"
        class="hero__img"
        data-hero-zoom
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__scrim" aria-hidden="true"></div>
    </div>

    <div class="container-x hero__content">
      <p class="eyebrow" data-hero>Adolescent PHP &amp; IOP · Apex, NC</p>
      <h1 class="hero__title font-display" id="hero-title" data-hero>
        Grow in a shape that is <em>entirely your own.</em>
      </h1>
      <p class="hero__lede" data-hero>
        Trauma-informed PHP &amp; IOP for teens ages 10–17 — structured daily care that
        fits your family's life, with results you can track from week one.
      </p>
      <div class="hero__actions" data-hero>
        <a href="/admissions" class="btn">Start the Conversation <span class="btn__arrow">→</span></a>
        <a href="/programs" class="btn btn--ghost">Explore Programs</a>
      </div>
      <p class="hero__trust" data-hero>
        <span>No waitlist</span><span class="hero__trust-dot" aria-hidden="true">·</span>
        <span>1-business-day response</span><span class="hero__trust-dot" aria-hidden="true">·</span>
        <span>In-network with major insurers</span>
      </p>
    </div>
  </section>

  <!-- ============================ TRUST STRIP ============================ -->
  <section class="trust" aria-label="Referral partners">
    <div class="container-x trust__inner" data-reveal>
      <p class="trust__label">Referred by clinicians across the&nbsp;Triangle</p>
      <ul class="trust__logos">
        {referrers.map((r) => <li class="trust__logo">{r}</li>)}
      </ul>
    </div>
  </section>

  <!-- ============================ MANIFESTO ============================ -->
  <section class="manifesto surface-green" aria-labelledby="manifesto-title">
    <div class="container-x manifesto__inner">
      <p class="eyebrow manifesto__eyebrow" data-reveal>Why we exist</p>
      <p class="manifesto__lead font-display" id="manifesto-title" data-reveal data-reveal-delay="0.05">
        Adolescence is not a problem to be solved. It's a desert to be navigated.
      </p>
      <p class="manifesto__body" data-reveal data-reveal-delay="0.12">
        We meet teens in everyday moments — with care, respect, and clinical excellence.
        Never judgment. Structured help that fits real life, so growth has room to take root.
      </p>
    </div>
  </section>

  <!-- ============================ PROGRAMS ============================ -->
  <section class="section programs" id="programs" aria-labelledby="programs-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Our programs</p>
        <h2 class="section-title font-display" id="programs-title">Two programs. One team. Zero waitlists.</h2>
        <p class="section-sub">PHP for full-day structured care. IOP for after-school intensive support. Both evidence-based. Both built for how teens actually live.</p>
      </div>

      <div class="programs__grid" data-reveal-group>
        <article class="program-card" data-reveal-item>
          <p class="program-card__tag">Partial Hospitalization · PHP</p>
          <h3 class="program-card__title font-display">Full-day care. Home each evening.</h3>
          <p class="program-card__sched"><span>Five days a week</span><span class="dot">·</span><span>9am – 3pm</span></p>
          <p class="program-card__body">Structured daily care for teens who need more than therapy — and can still go home each night.</p>
          <ul class="program-card__list">
            <li>Group &amp; individual therapy</li>
            <li>Family sessions</li>
            <li>Academic support</li>
            <li>Integrated psychiatric care</li>
          </ul>
          <a href="/programs" class="link-arrow">Learn about PHP →</a>
        </article>

        <article class="program-card program-card--accent" data-reveal-item>
          <p class="program-card__tag">Intensive Outpatient · IOP</p>
          <h3 class="program-card__title font-display">After school. Life stays intact.</h3>
          <p class="program-card__sched"><span>Three afternoons a week</span><span class="dot">·</span><span>3 – 6pm</span></p>
          <p class="program-card__body">Teens stay in school, stay at home, and stay connected to their lives — while getting the intensive support they actually need.</p>
          <ul class="program-card__list">
            <li>After-school scheduling</li>
            <li>Group &amp; individual therapy</li>
            <li>Skills for real life (DBT)</li>
            <li>Integrated psychiatric care</li>
          </ul>
          <a href="/programs" class="link-arrow">Learn about IOP →</a>
        </article>
      </div>

      <p class="programs__insurance" data-reveal>
        Covered by most major insurance plans — in-network with BCBS, Cigna, Aetna, UHC, and Tricare.
        We verify your benefits before you start, so there are no surprises.
      </p>
    </div>
  </section>

  <!-- ============================ OUTCOMES ============================ -->
  <section class="section stats surface-cream-deep" aria-labelledby="stats-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <p class="eyebrow eyebrow--plain">What we track</p>
        <h2 class="section-title font-display" id="stats-title">82% of teens. 78% of families.</h2>
        <p class="section-sub">We measure what matters — and we share it with you.</p>
      </div>

      <div class="stats__grid" data-reveal-group>
        <div class="stat" data-reveal-item>
          <span class="stat__num font-display">82%</span>
          <span class="stat__label">of teens show clinically significant symptom improvement by week 8.</span>
        </div>
        <div class="stat" data-reveal-item>
          <span class="stat__num font-display">78%</span>
          <span class="stat__label">of families report meaningfully improved communication at home.</span>
        </div>
        <div class="stat" data-reveal-item>
          <span class="stat__num font-display">3–5<span class="stat__unit">days</span></span>
          <span class="stat__label">typical time from your first call to starting care.</span>
        </div>
        <div class="stat" data-reveal-item>
          <span class="stat__num font-display">Zero</span>
          <span class="stat__label">waitlist. When your teen is ready, we're ready.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ PROCESS ============================ -->
  <section class="section process" aria-labelledby="process-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">How it works</p>
        <h2 class="section-title font-display" id="process-title">Three steps. Then a plan.</h2>
      </div>
      <ol class="process__steps" data-reveal-group>
        <li class="step" data-reveal-item>
          <span class="step__num">01</span>
          <h3 class="step__title">Fill out the form</h3>
          <p class="step__body">A two-minute form. No medical details — we'll cover those by phone.</p>
        </li>
        <li class="step" data-reveal-item>
          <span class="step__num">02</span>
          <h3 class="step__title">We call you</h3>
          <p class="step__body">A real conversation about what your teen needs — within one business day.</p>
        </li>
        <li class="step" data-reveal-item>
          <span class="step__num">03</span>
          <h3 class="step__title">Start within 3–5 days</h3>
          <p class="step__body">We recommend the right level of care and build a plan together. No pressure.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ============================ TESTIMONIAL ============================ -->
  <section class="quote surface-lavender" aria-label="Parent testimonial">
    <div class="container-x quote__inner">
      <p class="quote__mark font-display" aria-hidden="true">“</p>
      <blockquote class="quote__text font-display" data-reveal>
        I didn't know if this was the right level of care. It was. They met my son exactly where he was.
      </blockquote>
      <p class="quote__cite" data-reveal data-reveal-delay="0.08">Parent of a JTree Health teen</p>
    </div>
  </section>

  <!-- ============================ LOCATION ============================ -->
  <section class="section location" aria-labelledby="location-title">
    <div class="container-x location__grid">
      <div class="location__info" data-reveal>
        <p class="eyebrow">Visit us</p>
        <h2 class="section-title font-display" id="location-title">Apex, NC — easy access from across the Triangle.</h2>
        <p class="section-sub">Serving families across Raleigh, Cary, Durham, and Chapel Hill.</p>
        <address class="location__address">
          800 West Williams St, STE 203<br />
          Apex, NC 27502
        </address>
        <div class="location__actions">
          <a class="btn btn--ghost" href="https://maps.google.com/?q=800+West+Williams+St+STE+203+Apex+NC+27502" target="_blank" rel="noopener">Get directions →</a>
          <a class="link-arrow" href="tel:+19193355053">(919) 335-5053</a>
        </div>
      </div>
      <div class="location__map" data-reveal data-reveal-delay="0.08">
        <iframe
          title="Map to Joshua Tree Health in Apex, NC"
          src="https://maps.google.com/maps?q=800%20West%20Williams%20St%20Apex%20NC%2027502&t=&z=14&ie=UTF8&iwloc=&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(600px, 90vh, 900px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-deep-green-900, #0c1f18);
  }
  .hero__media { position: absolute; inset: -7% 0; z-index: 0; will-change: transform; }
  .hero__img { width: 100%; height: 100%; object-fit: cover; object-position: 70% 50%; }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(246, 244, 236, 0) 32%, rgba(246, 244, 236, 0.55) 72%, rgba(246, 244, 236, 0.95) 100%),
      linear-gradient(96deg, rgba(246, 244, 236, 0.96) 0%, rgba(246, 244, 236, 0.78) 26%, rgba(246, 244, 236, 0.32) 48%, rgba(246, 244, 236, 0) 62%);
  }

  .hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    padding-bottom: clamp(3rem, 2rem + 5vw, 6rem);
  }
  .hero__title {
    font-size: clamp(2.5rem, 1.4rem + 4vw, 4.7rem);
    line-height: 1.02;
    margin: 0.85rem 0 1.35rem;
    max-width: 16ch;
    color: var(--color-deep-green);
  }
  .hero__title em { font-style: italic; color: var(--color-lime-deep); }
  .hero__lede {
    font-size: var(--text-body-l);
    color: var(--color-ink-soft);
    max-width: 33rem;
    line-height: 1.6;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; }
  .hero__trust {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
    margin-top: 1.8rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--color-sage);
  }
  .hero__trust-dot { opacity: 0.45; }

  /* ---------- TRUST STRIP ---------- */
  .trust {
    padding-block: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    border-bottom: 1px solid var(--color-line);
    background: var(--color-cream);
  }
  .trust__inner { display: flex; flex-direction: column; gap: 1.1rem; align-items: center; text-align: center; }
  .trust__label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .trust__logos {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: clamp(1.25rem, 0.5rem + 3vw, 3rem);
    list-style: none; margin: 0; padding: 0;
  }
  .trust__logo {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: clamp(1rem, 0.9rem + 0.5vw, 1.3rem);
    color: var(--color-sage);
    opacity: 0.85;
  }

  @media (min-width: 700px) {
    .trust__inner { flex-direction: row; justify-content: space-between; text-align: left; }
  }

  @media (max-width: 680px) {
    .hero { align-items: flex-end; min-height: 88vh; }
    .hero__img { object-position: 64% 50%; }
    .hero__scrim {
      background:
        linear-gradient(180deg, rgba(246, 244, 236, 0) 30%, rgba(246, 244, 236, 0.7) 60%, rgba(246, 244, 236, 0.97) 88%);
    }
    .hero__title { max-width: 14ch; }
  }

  /* ---------- MANIFESTO ---------- */
  .manifesto { padding-block: clamp(4.5rem, 3rem + 7vw, 9rem); }
  .manifesto__inner { max-width: 54rem; }
  .manifesto__eyebrow { color: var(--color-lime); }
  .manifesto__lead {
    font-size: clamp(1.9rem, 1.1rem + 3vw, 3.4rem);
    line-height: 1.12;
    color: var(--color-cream);
    margin: 1.2rem 0 1.6rem;
    max-width: 20ch;
  }
  .manifesto__body { font-size: var(--text-body-l); line-height: 1.6; color: var(--color-cream-dim); max-width: 42rem; }

  /* ---------- PROGRAMS ---------- */
  .programs__grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  .program-card {
    background: var(--color-cream-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-xl);
    padding: clamp(1.6rem, 1rem + 2vw, 2.5rem);
    display: flex; flex-direction: column; gap: 0.9rem;
    transition: box-shadow var(--dur) var(--ease-soft), transform var(--dur) var(--ease-soft), border-color var(--dur) var(--ease-soft);
  }
  .program-card:hover { box-shadow: var(--shadow); transform: translateY(-3px); border-color: var(--color-line-strong); }
  .program-card--accent { background: var(--color-deep-green); border-color: transparent; }
  .program-card--accent .program-card__title { color: var(--color-cream); }
  .program-card--accent .program-card__body { color: var(--color-cream-dim); }
  .program-card--accent .program-card__sched { color: var(--color-lime); }
  .program-card--accent .program-card__tag { color: var(--color-lime); }
  .program-card--accent .program-card__list li { color: var(--color-cream-dim); }
  .program-card--accent .program-card__list li::before { color: var(--color-lime); }
  .program-card--accent .link-arrow { color: var(--color-lime); }
  .program-card--accent .link-arrow:hover { border-color: var(--color-lime); }
  .program-card__tag { font-family: var(--font-mono); font-size: var(--text-label); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-sage); }
  .program-card__title { font-size: clamp(1.5rem, 1.1rem + 1.4vw, 2rem); color: var(--color-deep-green); line-height: 1.08; }
  .program-card__sched { font-family: var(--font-mono); font-size: 0.84rem; color: var(--color-pine); display: flex; gap: 0.5em; align-items: center; }
  .program-card__sched .dot { opacity: 0.4; }
  .program-card__body { color: var(--color-ink-soft); }
  .program-card__list { list-style: none; margin: 0.3rem 0 0.6rem; padding: 0; display: grid; gap: 0.55rem; }
  .program-card__list li { position: relative; padding-left: 1.4rem; font-size: 0.95rem; color: var(--color-ink-soft); }
  .program-card__list li::before { content: "→"; position: absolute; left: 0; color: var(--color-lime-deep); }
  .program-card .link-arrow { margin-top: auto; }
  .programs__insurance {
    margin-top: clamp(1.75rem, 1rem + 2vw, 2.75rem);
    font-size: 0.96rem; line-height: 1.55; color: var(--color-ink-soft);
    max-width: 54rem; padding: 1.1rem 1.4rem;
    border-left: 3px solid var(--color-lime);
    background: var(--color-cream-deep);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  @media (min-width: 820px) { .programs__grid { grid-template-columns: 1fr 1fr; } }

  /* ---------- OUTCOMES ---------- */
  .stats__grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 1rem + 3vw, 3rem) clamp(1rem, 0.5rem + 2vw, 2.5rem);
  }
  .stat { text-align: center; display: flex; flex-direction: column; gap: 0.7rem; }
  .stat__num {
    font-size: clamp(2.7rem, 1.6rem + 4vw, 4.6rem);
    line-height: 0.95; color: var(--color-deep-green); font-weight: 600;
    display: inline-flex; align-items: baseline; justify-content: center; gap: 0.16em;
  }
  .stat__unit { font-size: 0.3em; font-family: var(--font-mono); color: var(--color-sage); text-transform: uppercase; letter-spacing: 0.08em; }
  .stat__label { font-size: 0.92rem; line-height: 1.45; color: var(--color-ink-soft); max-width: 24ch; margin-inline: auto; }
  @media (min-width: 860px) { .stats__grid { grid-template-columns: repeat(4, 1fr); } }

  /* ---------- PROCESS ---------- */
  .process__steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: clamp(1.6rem, 1rem + 2vw, 2.75rem); }
  .step { display: flex; flex-direction: column; gap: 0.6rem; padding-top: 1.5rem; border-top: 2px solid var(--color-line-strong); }
  .step__num { font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.1em; color: var(--color-lime-deep); font-weight: 600; }
  .step__title { font-family: var(--font-head); font-size: 1.3rem; font-weight: 600; color: var(--color-deep-green); }
  .step__body { color: var(--color-ink-soft); font-size: 0.98rem; line-height: 1.55; }
  @media (min-width: 760px) { .process__steps { grid-template-columns: repeat(3, 1fr); } }

  /* ---------- TESTIMONIAL ---------- */
  .quote { padding-block: clamp(4rem, 3rem + 6vw, 7.5rem); }
  .quote__inner { max-width: 50rem; margin-inline: auto; text-align: center; }
  .quote__mark { font-size: 5rem; line-height: 0.5; color: var(--color-lavender-deep); height: 0.45em; }
  .quote__text { font-size: clamp(1.5rem, 1.1rem + 2.2vw, 2.55rem); line-height: 1.3; color: var(--color-deep-green); letter-spacing: -0.01em; font-weight: 500; }
  .quote__cite { margin-top: 1.6rem; font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-pine); }

  /* ---------- LOCATION ---------- */
  .location__grid { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 1rem + 3vw, 3.5rem); align-items: center; }
  .location__address { font-style: normal; font-size: var(--text-body-l); line-height: 1.6; color: var(--color-deep-green); margin: 1.5rem 0; font-family: var(--font-head); font-weight: 500; }
  .location__actions { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; }
  .location__map { border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow); border: 1px solid var(--color-line); aspect-ratio: 4 / 3; }
  .location__map iframe { width: 100%; height: 100%; border: 0; filter: grayscale(0.15) contrast(1.02); }
  @media (min-width: 880px) { .location__grid { grid-template-columns: 1fr 1.1fr; } }
</style>
