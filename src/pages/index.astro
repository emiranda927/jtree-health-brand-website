---
import Base from '../layouts/Base.astro';
import FigmaHeroArt from '../components/brand/FigmaHeroArt.astro';
import { getEntry } from 'astro:content';

const homeEntry = await getEntry('homePage', 'home');
if (!homeEntry) throw new Error('Missing CMS content: home page');
const content = homeEntry.data;

const conditionVisuals = [
  {
    image: '/brand-v2/spots/depression.svg',
    scale: 1,
  },
  {
    image: '/brand-v2/spots/anxious.svg',
    scale: 1,
  },
  {
    image: '/brand-v2/spots/dbt-cbt-reframing.svg',
    scale: 1,
  },
  {
    image: '/brand-v2/spots/nature-walking.svg',
    scale: 1.07,
  },
  {
    image: '/brand-v2/spots/happy.svg',
    scale: 1.08,
  },
  {
    image: '/brand-v2/spots/mindfulness-meditation.svg',
    scale: 1,
  },
];

const conditions = content.pathways.conditions.map((condition, index) => ({
  ...condition,
  ...conditionVisuals[index],
}));
---
<Base
  bodyClass="home-v2"
  title={content.seo.title}
  description={content.seo.description}
>
  <section class="hero" data-hero-scope aria-labelledby="hero-title">
    <FigmaHeroArt />
    <div class="container-x hero__grid">
      <div class="hero__copy">
        <h1 class="hero__title font-display" id="hero-title" data-hero>
          <span>{content.hero.lineOne}</span>
          <span><span class="hero__accent">{content.hero.lineTwo}</span></span>
          <span class="hero__accent">{content.hero.lineThree}</span>
        </h1>
        <p class="hero__lede" data-hero>
          {content.hero.ledeOne}<br />{content.hero.ledeTwo}
        </p>
        <div class="hero__actions" data-hero>
          <a href="/get-started" class="btn">{content.hero.primaryCta}</a>
          <a href="/what-we-offer" class="btn btn--ghost">{content.hero.secondaryCta}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="trust" aria-label="Program facts">
    <ul class="container-x trust__inner" data-reveal>
      {content.trustFacts.map((fact) => <li>{fact}</li>)}
    </ul>
  </section>

  <section class="manifesto" aria-labelledby="manifesto-title">
    <div class="container-x manifesto__grid">
      <div class="manifesto__copy">
        <img class="section-punct section-punct--light" src="/brand-v2/halos/halo-10-lime.svg" alt="" aria-hidden="true" />
        <h2 class="manifesto__lead font-display" id="manifesto-title" data-reveal>
          {content.manifesto.title}
        </h2>
        <p class="manifesto__body" data-reveal data-reveal-delay="0.08">
          {content.manifesto.paragraphs[0]}
        </p>
        {/* TODO: VERIFY before adding guide claims here: separate pre-teen/teen tracks, Parent DBT Skills Group, weekly 1:1 family therapy cadence (all pending in docs/CLAIM_REGISTER.md) */}
        <p class="manifesto__body" data-reveal data-reveal-delay="0.13">
          {content.manifesto.paragraphs[1]}
        </p>
        <p class="manifesto__body" data-reveal data-reveal-delay="0.18">
          {content.manifesto.paragraphs[2]}
        </p>
        <div class="manifesto__action" data-reveal data-reveal-delay="0.22">
          <a href="/get-started" class="btn btn--on-dark">{content.manifesto.primaryCta} <span class="btn__arrow">→</span></a>
          <a class="manifesto__link" href="/what-we-offer/our-approach">{content.manifesto.secondaryCta}</a>
        </div>
      </div>
      <div class="manifesto__art" data-reveal data-reveal-delay="0.08">
        <img class="manifesto__growth" src="/brand-v2/collage/tree-growth-halo.webp" alt="A Joshua tree surrounded by watercolor, hand-drawn symbols, and a seated character" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section pathways" aria-labelledby="pathways-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <img class="section-punct" src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
        {content.pathways.eyebrow && <p class="eyebrow">{content.pathways.eyebrow}</p>}
        <h2 class="section-title font-display" id="pathways-title">{content.pathways.title}</h2>
      </div>
      <div class="pathways__grid" data-reveal-group>
        {conditions.map((condition) => (
          <a class="pathway" href="/what-we-treat" data-reveal-item>
            <img class="pathway__art" style={`--art-scale: ${condition.scale}`} src={condition.image} alt="" aria-hidden="true" loading="lazy" />
            <div class="pathway__copy">
              <h3>{condition.title}</h3>
              <p>{condition.body}</p>
              <span>{content.pathways.cardCta}</span>
            </div>
          </a>
        ))}
      </div>
      <p class="pathways__more" data-reveal><a class="link-arrow" href="/what-we-treat">{content.pathways.allCta}</a></p>
    </div>
  </section>

  <section class="section programs" id="programs" aria-labelledby="programs-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">{content.programs.eyebrow}</p>
        <h2 class="section-title font-display" id="programs-title">{content.programs.title}</h2>
        <p class="section-sub">{content.programs.intro}</p>
      </div>

      <div class="programs__grid" data-reveal-group>
        <article class="program-card" data-reveal-item>
          <img class="program-card__mark" src="/brand-v2/graphics/element-13-deep-sage.svg" alt="" aria-hidden="true" />
          <div class="program-card__identity">
            <span class="program-card__code" aria-hidden="true">PHP</span>
            <p class="program-card__tag">{content.programs.php.tag}</p>
          </div>
          <h3 class="program-card__title">{content.programs.php.title}</h3>
          {/* TODO: VERIFY PHP exact hours and weekly day count before publishing schedule specifics (register: pending) */}
          <p class="program-card__sched">{content.programs.php.schedule}</p>
          <p class="program-card__body">{content.programs.php.body}</p>
          <ul class="program-card__list">
            {content.programs.php.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <a href="/what-we-offer/php" class="link-arrow">{content.programs.php.cta}</a>
        </article>

        <article class="program-card program-card--dark" data-reveal-item>
          <img class="program-card__mark" src="/brand-v2/halos/halo-10-lime.svg" alt="" aria-hidden="true" />
          <div class="program-card__identity">
            <span class="program-card__code" aria-hidden="true">IOP</span>
            <p class="program-card__tag">{content.programs.iop.tag}</p>
          </div>
          <h3 class="program-card__title">{content.programs.iop.title}</h3>
          <p class="program-card__sched">{content.programs.iop.schedule}</p>
          <p class="program-card__body">{content.programs.iop.body}</p>
          <ul class="program-card__list">
            {content.programs.iop.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <a href="/what-we-offer/iop" class="link-arrow">{content.programs.iop.cta}</a>
        </article>
      </div>

      <p class="programs__insurance" data-reveal>
        {content.programs.insuranceNote}
      </p>
    </div>
  </section>

  <section class="section measure" aria-labelledby="measure-title">
    <div class="container-x measure__layout">
      <div class="measure__art" data-reveal>
        <img class="measure__wash" src="/brand-v2/washes/wash-03.webp" alt="" aria-hidden="true" />
        <img class="measure__spot" src="/brand-v2/spots/art-therapy.svg" alt="Illustration representing creative expression in treatment" loading="lazy" />
        <img class="measure__punct" src="/brand-v2/halos/halo-9-lavender.svg" alt="" aria-hidden="true" />
      </div>
      <div class="measure__copy">
        <div class="section-head" data-reveal>
          <p class="eyebrow">{content.measure.eyebrow}</p>
          <h2 class="section-title font-display" id="measure-title">{content.measure.title}</h2>
          <p class="section-sub">{content.measure.intro}</p>
        </div>
        <div class="measure__points" data-reveal-group>
          {content.measure.points.map((point) => <article data-reveal-item><h3>{point.title}</h3><p>{point.body}</p></article>)}
        </div>
        <p class="measure__more" data-reveal><a class="link-arrow" href="/about/outcomes">{content.measure.cta}</a></p>
      </div>
    </div>
  </section>

  <section class="section process" aria-labelledby="process-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">{content.process.eyebrow}</p>
        <h2 class="section-title font-display" id="process-title">{content.process.title}</h2>
      </div>
      <ol class="process__steps" data-reveal-group>
        {content.process.steps.map((step, index) => (
          <li class="step" data-reveal-item><span class="step__num">{String(index + 1).padStart(2, '0')}</span><h3>{step.title}</h3><p>{step.body}</p></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section location" aria-labelledby="location-title">
    <div class="container-x location__grid">
      <div class="location__info" data-reveal>
        <p class="eyebrow">{content.location.eyebrow}</p>
        <h2 class="section-title font-display" id="location-title">{content.location.title}</h2>
        <p class="section-sub">{content.location.intro}</p>
        <address class="location__address">800 West Williams St, STE 203<br />Apex, NC 27502</address>
        <div class="location__actions">
          <a class="btn btn--ghost" href="https://maps.google.com/?q=800+West+Williams+St+STE+203+Apex+NC+27502" target="_blank" rel="noopener">{content.location.directionsCta}</a>
          <a class="link-arrow" href="tel:+19193355053">(919) 335-5053</a>
        </div>
      </div>
      <div class="location__map" data-reveal data-reveal-delay="0.08">
        <img class="location__wash location__wash--lime" src="/brand-v2/washes/wash-09.webp" alt="" aria-hidden="true" />
        <img class="location__wash location__wash--lavender" src="/brand-v2/washes/wash-03.webp" alt="" aria-hidden="true" />
        <img class="location__mark" src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
        <div class="location__map-frame">
          <iframe title="Map to Joshua Tree Health in Apex, NC" src="https://maps.google.com/maps?q=800%20West%20Williams%20St%20Apex%20NC%2027502&t=&z=14&ie=UTF8&iwloc=&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </section>

  <section class="closing" aria-labelledby="home-cta-title">
    <div class="container-x closing__inner" data-reveal>
      <img class="section-punct section-punct--light" src="/brand-v2/halos/halo-10-lime.svg" alt="" aria-hidden="true" />
      <p class="eyebrow eyebrow--light">{content.closing.eyebrow}</p>
      <h2 class="font-display" id="home-cta-title">{content.closing.title}</h2>
      <p>{content.closing.body}</p>
      <div class="closing__actions">
        <a href="/get-started" class="btn btn--on-dark">{content.closing.primaryCta} <span class="btn__arrow">→</span></a>
        <a class="closing__call" href="tel:+19193355053">Call (919) 335-5053</a>
      </div>
    </div>
  </section>
</Base>

<style>
  :global(body.home-v2) {
    --color-deep-green: #1e3d34;
    --color-deep-green-900: #132a24;
    --color-pine: #2c5f52;
    --color-sage: #2c5f52;
    --color-lime: #b8e04a;
    --color-lime-deep: #8daf2e;
    --color-lavender: #a89fd8;
    --color-lavender-soft: #d9d4ee;
    --color-lavender-deep: #756ca8;
    --color-cream: #fffaf3;
    --color-cream-deep: #f7f2e8;
    --color-cream-card: #fffdf8;
    --color-line: rgba(30, 61, 52, .16);
    --color-line-strong: rgba(30, 61, 52, .28);
    --color-charcoal: #28473e;
    --color-ink-soft: #4d625b;
    --color-ink-faint: #667970;
    --color-cream-dim: rgba(255, 250, 243, .76);
    --font-display: "Batica Sans", Arial, sans-serif;
    --font-head: "Sigmar", "Batica Sans", Arial, sans-serif;
    --font-sans: "Volkhov", Georgia, serif;
    --font-mono: "Sigmar", "Batica Sans", Arial, sans-serif;
    background: var(--color-cream);
    font-family: var(--font-sans);
  }

  :global(.home-v2 .font-display) {
    font-family: var(--font-display);
    font-weight: 700;
    font-variation-settings: normal;
    letter-spacing: -.04em;
    line-height: .96;
  }

  :global(.home-v2 .eyebrow) {
    font-family: var(--font-head);
    font-size: .98rem;
    font-weight: 900;
    letter-spacing: .04em;
    line-height: 1.14;
  }
  :global(.home-v2 .eyebrow::before) { display: none; }
  :global(.home-v2 .btn), :global(.home-v2 .link-arrow) {
    font-family: var(--font-head);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .025em;
  }
  :global(.home-v2 .btn) { font-size: 1rem; line-height: 1.08; }
  :global(.home-v2 .link-arrow) {
    width: fit-content;
    font-size: .98rem;
    line-height: 1.2;
    border-bottom: 2px solid var(--color-lavender);
    padding-bottom: .16rem;
  }
  :global(.home-v2 .nav.is-scrolled) { background: rgba(255, 250, 243, .9); }
  #manifesto-title, #pathways-title, #programs-title, #measure-title, #process-title, #location-title, #home-cta-title { scroll-margin-top: 92px; }

  .hero {
    position: relative;
    overflow: hidden;
    background: var(--color-cream);
  }
  .hero__grid {
    position: relative;
    z-index: 2;
    min-height: clamp(760px, calc(100dvh - 72px), 1100px);
    display: flex;
    align-items: center;
    padding-block: clamp(5rem, 8vw, 8.5rem);
  }
  .hero__copy { position: relative; z-index: 2; width: min(50.5%, 810px); min-width: 0; }
  .hero__title {
    margin: 0;
    font-size: clamp(4.2rem, 5.35vw, 6.35rem);
    color: var(--color-deep-green);
  }
  .hero__title > span { display: block; }
  .hero__accent { color: var(--color-pine); }
  .hero__lede { max-width: 39rem; margin-top: 2.8rem; color: var(--color-deep-green); font-size: clamp(1.35rem, 1.7vw, 2rem); line-height: 1.45; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 1.4rem; margin-top: 2.8rem; }
  .hero__actions .btn { min-width: 210px; justify-content: center; }

  .trust { background: #8fbfb0; color: var(--color-deep-green); } /* Mist Sage — calmer than the lime accent */
  .trust__inner { min-height: 96px; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); align-items: center; margin: 0 auto; padding-block: 1.35rem; list-style: none; }
  .trust li { min-width: 0; padding-inline: 1.25rem; font-family: var(--font-head); font-size: clamp(.95rem, 1.15vw, 1.08rem); line-height: 1.12; text-align: center; text-transform: uppercase; letter-spacing: .02em; }
  .trust li + li { border-left: 1px solid rgba(30, 61, 52, .34); }

  .manifesto { overflow: hidden; background: var(--color-deep-green); color: var(--color-cream); }
  .manifesto__grid { min-height: 810px; display: grid; grid-template-columns: minmax(0, .98fr) minmax(0, 1.02fr); align-items: center; gap: clamp(2rem, 4vw, 4.5rem); }
  .manifesto__copy { padding-block: clamp(5rem, 8vw, 8rem); }
  .eyebrow--light { color: var(--color-lime); }
  .manifesto__lead { max-width: 13ch; margin-top: 1.25rem; color: var(--color-cream); font-size: clamp(3rem, 5.2vw, 5.5rem); }
  .manifesto__body { max-width: 43rem; margin-top: 1.35rem; color: var(--color-cream-dim); font-size: clamp(1.05rem, 1.25vw, 1.2rem); line-height: 1.58; }
  .manifesto__action { display: flex; flex-wrap: wrap; align-items: center; gap: 1.6rem; margin-top: 2.2rem; }
  .manifesto__link { font-family: var(--font-head); font-weight: 900; font-size: .98rem; line-height: 1.2; text-transform: uppercase; letter-spacing: .025em; color: var(--color-lime); border-bottom: 2px solid var(--color-lime); padding-bottom: .12rem; }
  .manifesto__art { position: relative; width: 100%; max-width: 760px; min-height: 760px; justify-self: end; align-self: center; isolation: isolate; }
  .manifesto__growth { position: absolute; width: 118%; max-width: none; left: 50%; top: 50%; transform: translate(-50%, -49%); filter: drop-shadow(0 24px 32px rgba(8, 26, 19, .18)); }

  .section-punct { width: 66px; margin-bottom: 1.2rem; transform: rotate(-9deg); }
  .section-punct--light { width: 78px; }
  .section-head { max-width: 760px; }
  .section-title { margin-top: 1rem; font-size: clamp(2.8rem, 5vw, 5.2rem); }
  .section-sub { font-size: clamp(1.05rem, 1.25vw, 1.2rem); }

  .pathways { background: var(--color-cream); }
  .pathways__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 2.3vw, 2.5rem); margin-top: clamp(3rem, 6vw, 6rem); }
  .pathways__more { margin-top: clamp(2.5rem, 4vw, 3.5rem); }
  .pathway { display: grid; grid-template-rows: 245px auto; color: inherit; text-decoration: none; }
  .pathway__art { width: 100%; height: 235px; object-fit: contain; transform: scale(var(--art-scale, 1)); transition: transform var(--dur) var(--ease-soft); }
  .pathway:hover .pathway__art { transform: scale(var(--art-scale, 1)) translateY(-7px) rotate(-1deg); }
  .pathway__copy { padding-top: 1.25rem; border-top: 1px solid var(--color-line); }
  .pathway:nth-child(2) .pathway__copy { border-top-color: var(--color-lavender); }
  .pathway:nth-child(3) .pathway__copy { border-top-color: var(--color-lime-deep); }
  .pathway h3 { font-family: var(--font-head); font-size: clamp(1.05rem, 1.5vw, 1.35rem); line-height: .96; text-transform: uppercase; letter-spacing: .015em; }
  .pathway p { margin-top: .8rem; color: var(--color-ink-soft); font-size: 1.0625rem; line-height: 1.58; }
  .pathway span { display: inline-block; margin-top: 1.3rem; padding-bottom: .12rem; border-bottom: 2px solid var(--color-lavender); font-family: var(--font-head); font-size: .98rem; line-height: 1.2; text-transform: uppercase; letter-spacing: .02em; }

  .programs { background: var(--color-cream-deep); }
  .programs__grid { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; gap: clamp(1.25rem, 2.5vw, 2.5rem); }
  .program-card { position: relative; min-height: 620px; height: 100%; display: flex; flex-direction: column; padding: clamp(2rem, 4vw, 3.5rem); background: var(--color-cream-card); border: 1px solid var(--color-line); overflow: hidden; }
  .program-card--dark { margin-top: 0; background: var(--color-deep-green); color: var(--color-cream); border-color: transparent; }
  .program-card__mark { position: absolute; width: 88px; right: 1.6rem; top: 1.6rem; transform: rotate(8deg); }
  .program-card__identity { max-width: calc(100% - 6rem); }
  .program-card__code { display: block; font-family: var(--font-display); font-size: clamp(3.5rem, 6vw, 6rem); font-weight: 700; line-height: .78; letter-spacing: -.06em; color: var(--color-deep-green); }
  .program-card__tag, .program-card__sched { font-family: var(--font-head); font-size: 1rem; line-height: 1.18; text-transform: uppercase; letter-spacing: .025em; color: var(--color-pine); }
  .program-card__tag { margin-top: 1rem; }
  .program-card__title { max-width: 16ch; margin-top: 2.4rem; font-family: var(--font-display); font-size: clamp(2rem, 3vw, 3.2rem); font-weight: 700; line-height: .96; letter-spacing: -.035em; }
  .program-card__sched { margin-top: 1.4rem; }
  .program-card__body { max-width: 38rem; margin-top: 1.2rem; color: var(--color-ink-soft); font-size: 1.1rem; line-height: 1.6; }
  .program-card__list { display: grid; gap: .65rem; margin: 1.4rem 0 2rem; padding: 1.25rem 0 0; list-style: none; border-top: 1px solid var(--color-line); color: var(--color-ink-soft); }
  .program-card__list li::before { content: '→'; margin-right: .65rem; color: var(--color-lime-deep); }
  .program-card .link-arrow { margin-top: auto; }
  .program-card--dark .program-card__tag, .program-card--dark .program-card__sched, .program-card--dark .link-arrow { color: var(--color-lime); }
  .program-card--dark .program-card__code { color: var(--color-cream); }
  .program-card--dark .program-card__title { color: var(--color-cream); }
  .program-card--dark .program-card__body { color: rgba(255, 250, 243, .86); }
  .program-card--dark .program-card__list { color: var(--color-cream); }
  .program-card--dark .program-card__list li { color: rgba(255, 250, 243, .86); }
  .program-card--dark .program-card__list { border-color: rgba(255,250,243,.2); }
  .program-card--dark .program-card__list li::before { color: var(--color-lime); }
  .programs__insurance { max-width: 54rem; margin-top: 3rem; padding-left: 1.1rem; border-left: 4px solid var(--color-lime); color: var(--color-ink-soft); }

  .measure { overflow: hidden; background: #dceae5; }
  .measure__layout { display: grid; grid-template-columns: minmax(0, .78fr) minmax(0, 1.22fr); align-items: center; gap: clamp(3rem, 7vw, 8rem); }
  .measure__art { position: relative; width: min(100%, 570px); aspect-ratio: 1 / 1; justify-self: center; isolation: isolate; }
  .measure__wash { position: absolute; z-index: -1; width: 108%; max-width: none; left: 50%; top: 50%; opacity: .68; transform: translate(-50%, -50%) rotate(-3deg); }
  .measure__spot { position: absolute; width: 94%; max-width: none; left: 50%; top: 52%; transform: translate(-50%, -50%); }
  .measure__punct { position: absolute; width: 16%; max-width: 96px; right: 0; top: 3%; transform: rotate(9deg); }
  .measure__copy .section-head { margin-bottom: 2.5rem; }
  .measure__points { border-top: 1px solid rgba(30,61,52,.24); }
  .measure__points article { display: grid; grid-template-columns: minmax(180px, .75fr) 1.25fr; gap: 1.5rem; padding: 1.35rem 0; border-bottom: 1px solid rgba(30,61,52,.24); }
  .measure__points h3 { font-family: var(--font-head); font-size: 1.12rem; line-height: 1.08; text-transform: uppercase; letter-spacing: .012em; }
  .measure__points p { color: var(--color-ink-soft); font-size: 1.0625rem; line-height: 1.58; }
  .measure__more { margin-top: 2.2rem; }

