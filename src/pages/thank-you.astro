---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const next = [
  { n: '01', t: 'We read your note', b: 'Someone on our admissions team reads it personally.' },
  { n: '02', t: 'We call you', b: 'An admissions team member calls the number you provided.' },
  { n: '03', t: 'We find the fit', b: 'Together we figure out the right next step for your teen.' },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Thank you | Joshua Tree Health"
  description="Thanks for reaching out to Joshua Tree Health. Our admissions team will review your request and contact you."
  robots="noindex, follow"
>
  <PageHero
    art="happy"
    eyebrow="Request received"
    title="Your request is <em>in.</em>"
    sub="An admissions team member will read what you sent and call the number you provided."
    primaryCta={{ label: 'Back to home', href: '/' }}
    secondaryCta={{ label: 'Explore programs', href: '/what-we-offer' }}
  />

  <section class="section section--tight" aria-labelledby="next-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 id="next-title" class="section-title font-display">What happens next</h2>
      </div>
      <ol class="process__steps" data-reveal-group>
        {next.map((s) => (
          <li class="step" data-reveal-item>
            <span class="step__num">{s.n}</span>
            <h3 class="step__title">{s.t}</h3>
            <p class="step__body">{s.b}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" aria-labelledby="crisis-title">
    <div class="container-x">
      <div class="callout surface-green">
        <div class="callout__text">
          <h2 id="crisis-title" class="section-title font-display">Need help right now?</h2>
          <p class="section-sub">You don't have to wait for our call. If you or your teen is in crisis, call or text 988, or text HOME to 741741. Both are available any time, day or night.</p>
        </div>
        <a href="tel:988" class="btn btn--on-dark callout__cta">Call or text 988</a>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  // Fire the GA4 conversion only when we arrived from a real submission.
  (function () {
    var fired = false;
    try { fired = sessionStorage.getItem('jth_inquiry_done') === '1'; } catch (e) {}
    if (!fired) return;
    try { sessionStorage.removeItem('jth_inquiry_done'); } catch (e) {}
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'inquiry_submitted' });
  })();
</script>

<style>
  .section--tight { padding-block: clamp(2.5rem, 2rem + 3vw, 4rem); }
</style>
