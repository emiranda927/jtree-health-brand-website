---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { getEntry } from 'astro:content';

const learningHubEntry = await getEntry('learningHubPage', 'learning-hub');
if (!learningHubEntry) throw new Error('Missing CMS content: learning hub page');
const content = learningHubEntry.data;
---
<Base
  bodyClass="brand-page rollout-page"
  title={content.seo.title}
  description={content.seo.description}
>
  <PageHero
    eyebrow={content.hero.eyebrow}
    art="approach"
    title={content.hero.title}
    sub={content.hero.sub}
    primaryCta={{ label: content.hero.primaryCta, href: '/get-started' }}
  />

  <!-- ===== START HERE ===== -->
  <section class="section" aria-labelledby="start-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">{content.resources.eyebrow}</p>
        <h2 class="section-title font-display" id="start-title">{content.resources.title}</h2>
        <p class="section-sub">{content.resources.intro}</p>
      </div>
      <div class="grid-2" data-reveal-group>
        {content.resources.items.map((r) => (
          <a class="info-card info-card--hover" href={r.href} data-reveal-item>
            <h3 class="info-card__title">{r.title}</h3>
            <p class="info-card__body">{r.body}</p>
            <span class="link-arrow">{content.resources.itemCta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="learninghub-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="learninghub-cta-title">{content.closing.title}</h2>
        <p class="section-sub">{content.closing.body}</p>
        <div class="page-hero__actions">
          <a class="btn btn--on-dark" href="/get-started">{content.closing.primaryCta} <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>
