---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

// Learning Hub is in the nav, but there are no articles yet. Rather than ship
// placeholder-slop, this page is an honest landing that points families to the
// pages on the site that are already useful today.
const resources = [
  {
    title: 'What we treat',
    body: 'The struggles we help teens move through, described in plain language — from anxiety and depression to self-harm, trauma, and grief.',
    href: '/what-we-treat',
  },
  {
    title: 'Insurance, explained',
    body: 'What in-network means, how PHP and IOP are billed, and the exact questions to ask your insurer before care begins.',
    href: '/insurance',
  },
  {
    title: 'Crisis resources',
    body: 'If you or your teen is in crisis, here are the numbers to call or text right now, and what to do next.',
    href: '/crisis',
  },
  {
    title: 'How admissions works',
    body: 'What happens when you reach out, what the first call is like, and what to have ready. No commitment, no pressure.',
    href: '/admissions',
  },
];
---
<Base
  title="Learning Hub — Joshua Tree Health"
  description="Plain-language resources for families navigating teen mental health. We're building this section out — in the meantime, here are the pages families find most useful."
>
  <PageHero
    title="Learning Hub"
    sub="Plain-language resources for families navigating teen mental health. We're still building this section out. In the meantime, here are the pages families tell us are the most useful to start with."
    primaryCta={{ label: 'Start the Conversation', href: '/admissions' }}
  />

  <!-- ===== START HERE ===== -->
  <section class="section" aria-labelledby="start-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Start here</p>
        <h2 class="section-title font-display" id="start-title">Where families usually begin.</h2>
        <p class="section-sub">These pages answer the questions we hear most often. If you're not sure where to start, any one of them is a good place to begin.</p>
      </div>
      <div class="grid-2" data-reveal-group>
        {resources.map((r) => (
          <a class="info-card info-card--hover" href={r.href} data-reveal-item>
            <h3 class="info-card__title">{r.title}</h3>
            <p class="info-card__body">{r.body}</p>
            <span class="link-arrow">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ARTICLES COMING SOON ===== -->
  <section class="section surface-cream-deep" aria-labelledby="articles-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="articles-title">Articles are on the way.</h2>
        <p class="section-sub">We're writing guides on the things parents ask us about most: telling a hard week from something bigger, how to talk to a teen who doesn't want help, and what to expect from PHP and IOP. When they're ready, they'll live here.</p>
        <a class="link-arrow" href="/learning-hub/blog">See the blog →</a>
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="learninghub-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="learninghub-cta-title">Would it help to just talk it through?</h2>
        <p class="section-sub">You don't have to read your way to an answer. One call is enough to find out whether Joshua Tree is the right fit for your teen.</p>
        <div class="page-hero__actions">
          <a class="btn btn--on-dark" href="/admissions">Start the Conversation <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>
