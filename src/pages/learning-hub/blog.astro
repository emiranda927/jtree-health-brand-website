---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base
  bodyClass="brand-page rollout-page"
  title="Blog | Joshua Tree Health"
  description="This former blog route has moved to the Joshua Tree Health Learning Hub."
  canonical="/learning-hub/"
  robots="noindex, follow"
>
  <PageHero
    eyebrow="Learning hub"
    art="art"
    title="Blog"
    sub="Articles for parents and teens are on the way."
  />

  <!-- ===== COMING SOON ===== -->
  <section class="section" aria-labelledby="blog-soon-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="blog-soon-title">We're still writing.</h2>
        <p class="lead">
          We're putting together clear, practical articles for parents and teens
          navigating adolescent mental health care. They aren't ready to share yet,
          so there's nothing here to read just now.
        </p>
        <p>
          In the meantime, if you have a question about our programs, insurance, or
          whether Joshua Tree is the right fit for your teen, please reach out. You
          can <a href="/contact">contact our team</a> or call admissions at
          <a href="tel:+19193355053">(919) 335-5053</a>.
        </p>
        <p>
          <a class="link-arrow" href="/learning-hub">Back to the Learning Hub</a>
        </p>
      </div>
    </div>
  </section>
</Base>
