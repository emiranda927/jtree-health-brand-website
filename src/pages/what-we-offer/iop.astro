---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const includes = [
  'Group therapy on Monday, Wednesday, and Thursday',
  'A DBT skills curriculum taught in sequence: mindfulness, distress tolerance, emotion regulation, and interpersonal effectiveness',
  'Nervous system regulation and somatic work (experiential therapy)',
  'Art therapy and music therapy (expressive therapy)',
  'Mindfulness practice, including nature walks at our lakeside Apex location',
  // TODO: VERIFY dedicated fifth-day individual therapy before describing a set day.
  'Individual therapy alongside the group program',
  'Family therapy, built into treatment',
  // TODO: VERIFY scope of coordinated psychiatric care before naming it directly.
  'Care coordination with outside providers, as clinically indicated',
  'Discharge planning and transition support',
];

const whoItsFor = [
  'Teens who need more than weekly therapy but are stable enough to live at home and attend school',
  'Teens stepping down from PHP or a higher level of care',
  'Adolescents ages 10–17',
];

const faqs = [
  {
    q: 'What does a typical week look like?',
    a: 'Teen groups meet Monday, Wednesday, and Thursday, with a morning option (9am–12pm) or an afternoon option (3:30–6:30pm). A parent DBT skills group meets Tuesdays from 3:30–6:30pm for some families, so IOP runs three to four days a week. Individual and family therapy are scheduled alongside the group program.',
  },
  {
    q: 'Can my teen stay in school during IOP?',
    a: 'Yes. Many families choose the afternoon group (3:30–6:30pm) so teens keep their regular school day, coming to Joshua Tree on Monday, Wednesday, and Thursday. A morning group (9am–12pm) is also available.',
  },
  {
    q: 'How long does IOP last?',
    a: 'Most teens are in IOP for about 6 to 12 weeks. Length of stay is individualized — decided with the teen, family, and treatment team and reviewed throughout care, and it depends on clinical progress, insurance authorization, and medical need.',
  },
  {
    q: 'How quickly can we start?',
    a: 'There is no waitlist. A typical start is three to five days from first contact, depending on scheduling and insurance verification.',
  },
  {
    q: 'Will our family be involved?',
    a: "Yes. Family therapy is built into treatment, and you'll hear from your teen's treatment team regularly throughout the program.",
  },
  {
    q: 'Does insurance cover IOP?',
    a: "Coverage depends on your specific plan. We'll verify your insurance benefits and walk you through expected costs before care begins.",
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Base
  bodyClass="brand-page rollout-page"
  title="Teen Intensive Outpatient Program (IOP) | Joshua Tree Health"
  description="IOP for teens ages 10–17 in Apex, NC. Groups meet Mon/Wed/Thu, mornings or afternoons, with individual and family therapy alongside. Typically 6–12 weeks. No waitlist."
  jsonLd={faqSchema}
>
  <PageHero
    art="group"
    title="Intensive Outpatient Program (IOP)"
    sub="Three to four days a week, mornings or afternoons. More support than weekly therapy, with school and home still part of daily life."
    primaryCta={{ label: 'Find the right level of care', href: '/get-started' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <!-- ===== WHAT IT IS ===== -->
  <section class="section" aria-labelledby="what-it-is-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="what-it-is-title">What it is</h2>
        <p>
          IOP is for teens who need more than weekly therapy and can still attend school and live at
          home. The week is structured around skills that can be practiced where daily life is
          happening.
        </p>
        <p>
          Teen groups meet three days a week — Monday, Wednesday, and Thursday — and follow a
          three-part structure: a processing group with peers and a facilitator, skills building with
          DBT and CBT plus nervous system regulation, and an experiential group with art therapy, music therapy,
          somatic exercises, and mindfulness. A parent DBT skills group meets Tuesdays for some
          families, so IOP runs three to four days a week. Individual therapy and family sessions run
          alongside the group program.
        </p>
        <p>
          Most teens are in IOP for about 6 to 12 weeks, though length of stay is individualized. It
          is decided with the teen, family, and treatment team, and reviewed throughout care as
          clinical progress and insurance authorization take shape.
        </p>
        <p>
          Teens go home every evening. School, friendships, and family life remain part of the week,
          giving teens a place to use new skills as they learn them.
        </p>
      </div>
    </div>
  </section>

  <section class="section surface-lavender" aria-labelledby="iop-schedule-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Sample weekly schedule</p>
        <h2 class="section-title font-display" id="iop-schedule-title">A week teens can count on.</h2>
        <p class="section-sub">Teen groups meet Monday, Wednesday, and Thursday, with a morning option (9am–12pm) or an afternoon option (3:30–6:30pm). A parent DBT skills group meets Tuesdays from 3:30–6:30pm for some families.</p>
      </div>
      <div class="grid-3" data-reveal-group>
        <article class="info-card" data-reveal-item><h3>Processing group</h3><p>Teens share what has been going on with peers and a facilitator in a structured group setting.</p></article>
        <article class="info-card" data-reveal-item><h3>Skills-building group</h3><p>DBT and CBT skills work with nervous system regulation: distress tolerance, emotion regulation, mindfulness, and interpersonal effectiveness.</p></article>
        <article class="info-card" data-reveal-item><h3>Experiential group</h3><p>Art, music, movement, somatic exercises, and mindfulness reinforce the skills being practiced.</p></article>
      </div>
      <!-- TODO: VERIFY dedicated fifth-day individual therapy before publishing a set day for it. -->
      <p class="program-note" data-reveal>Individual and family therapy are scheduled alongside the group program. Admissions will walk you through how those sessions fit into your teen's week.</p>
    </div>
  </section>

  <!-- ===== WHAT IT INCLUDES ===== -->
  <section class="section surface-cream-deep" aria-labelledby="what-it-includes-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="what-it-includes-title">What it includes</h2>
      </div>
      <ul class="checklist" data-reveal>
        {includes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="section" aria-labelledby="who-its-for-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="who-its-for-title">Who it's for</h2>
      </div>
      <ul class="checklist" data-reveal>
        {whoItsFor.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <!-- TODO: VERIFY separate pre-teen and teen group tracks before production. -->
      <p class="program-note" data-reveal>Programming is developmentally appropriate across ages 10–17, and our admissions team will explain how groups are organized for your child's age.</p>
    </div>
  </section>

  <!-- ===== WHAT PARENTS NEED TO KNOW ===== -->
  <section class="section surface-lavender" aria-labelledby="parents-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">For parents</p>
        <h2 class="section-title font-display" id="parents-title">What parents need to know</h2>
      </div>
      <div class="prose" data-reveal>
        <h3>Will my teen be able to stay in school?</h3>
        <p>
          Yes. Many families choose the afternoon group (3:30–6:30pm), which meets after the school
          day, so teens keep their regular schedule. A morning group (9am–12pm) is also available.
          Groups meet Monday, Wednesday, and Thursday.
        </p>

        <h3>Do they go home every evening?</h3>
        <p>
          Yes, every night. IOP is fully outpatient, and your teen sleeps at home for the length of
          the program.
        </p>

        <h3>How involved will I be?</h3>
        <p>
          Family therapy is part of the work, and you'll have regular contact with your teen's
          treatment team. For some families, a parent DBT skills group meets on Tuesdays, so parents
          learn the same skills their teen is practicing and the tools your teen brings home are ones
          you recognize.
        </p>

        <h3>What will my teen be doing each week?</h3>
        <!-- TODO: VERIFY dedicated fifth-day individual therapy before describing a set day. -->
        <p>
          Three group sessions — Monday, Wednesday, and Thursday — each with the same three-part
          structure: processing with peers, DBT and CBT skills practice with nervous system regulation, and experiential work
          with art, music, somatic exercises, and mindfulness. Individual therapy runs alongside the
          group program.
        </p>

        <h3>What do they leave with?</h3>
        <p>
          Four DBT skill sets, taught in sequence: mindfulness, distress tolerance, emotion
          regulation, and interpersonal effectiveness. Teens practice them in session, and the
          skills are designed to work at home, at school, and in relationships.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section surface-cream-deep" aria-labelledby="iop-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="iop-faq-title">Questions about IOP.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="iop-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="iop-cta-title">Not sure if IOP is the right level?</h2>
        <p class="section-sub">You do not have to choose the level of care yourself. Tell admissions what has been happening, and we will explain the next step.</p>
        <div class="cta-row">
          <a class="btn btn--on-dark" href="/get-started">Find the right level of care <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .program-note { max-width: 54rem; margin-top: 2rem; color: var(--color-ink-soft); font-size: 1.05rem; line-height: 1.6; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
