---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const includes = [
  'Group therapy, three days a week',
  'DBT skills practice',
  'Polyvagal-informed and somatic work (experiential therapy)',
  'Art therapy and music therapy (expressive therapy)',
  'Mindfulness practice, including nature walks at our lakeside Apex location',
  'Individual therapy',
  'Family sessions',
  'Care coordination and discharge planning',
];

const faqs = [
  {
    q: 'What does a typical week look like?',
    a: 'Groups meet three times a week, typically after school. Each group session combines structured skills work with expressive and somatic elements. Individual sessions and family check-ins happen on separate days as scheduled.',
  },
  {
    q: 'Can my teen stay in school during IOP?',
    a: 'Yes. The program is designed around school schedules. Teens attend school as usual and come to Joshua Tree in the afternoons.',
  },
  {
    q: 'How long does IOP last?',
    a: "Our IOP curriculum runs 12 weeks. That said, a teen's actual length of stay may be shorter or longer depending on clinical progress, insurance authorization, and medical need. We make duration decisions collaboratively with the teen, family, and treatment team — and we never keep someone in the program longer than is clinically warranted.",
  },
  {
    q: 'Will our family be involved?',
    a: "Yes. Family sessions are built into the program. You'll also have regular communication from your teen's treatment team throughout.",
  },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Intensive Outpatient Program (IOP) — Joshua Tree Health"
  description="Structured IOP for teens ages 10–17 in Apex, NC. Group therapy three days a week, with individual and family sessions, while teens stay at home and in school."
>
  <PageHero
    eyebrow="Intensive Outpatient Program"
    art="group"
    title="Intensive Outpatient Program (IOP)"
    sub="Structured support three days a week — while teens stay at home and in school."
    primaryCta={{ label: 'Find the Right Level of Care', href: '/admissions' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <!-- ===== WHAT IT IS ===== -->
  <section class="section" aria-labelledby="what-it-is-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="what-it-is-title">What it is</h2>
        <p>
          IOP is built for teens who need more than weekly therapy but don't require a full day of
          programming. It's structured, evidence-based, and designed to build skills that hold up
          outside the room, in daily life.
        </p>
        <p>
          Groups meet three days a week and combine DBT skills practice, polyvagal-informed and
          experiential (somatic) work, and expressive therapies including art and music. Individual
          therapy and family sessions run in parallel throughout the program.
        </p>
        <p>
          Our IOP curriculum is 12 weeks. A teen's actual length of stay may be shorter or longer
          depending on clinical progress, insurance authorization, and medical need. We make those
          decisions collaboratively with the teen, family, and treatment team.
        </p>
        <p>
          Teens go home every evening. They keep their phone, their friends, their routines. The
          program fits around their life.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT IT INCLUDES ===== -->
  <section class="section surface-cream-deep" aria-labelledby="what-it-includes-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="what-it-includes-title">What it includes</h2>
      </div>
      <ul class="checklist" data-reveal>
        {includes.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="section" aria-labelledby="who-its-for-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="who-its-for-title">Who it's for</h2>
        <p>
          Teens who need more than weekly therapy but are functioning well enough to live at home and
          attend school. IOP is also appropriate for teens stepping down from PHP. We serve
          adolescents ages 10–17.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section surface-cream-deep" aria-labelledby="iop-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="iop-faq-title">Questions about IOP.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="iop-cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="iop-cta-title">Not sure if IOP is the right level?</h2>
        <p class="section-sub">One admissions call is enough to figure it out together. We'll help you understand the options before you commit to anything.</p>
        <div class="cta-row">
          <a class="btn btn--on-dark" href="/admissions">Find the Right Level of Care <span class="btn__arrow">→</span></a>
          <a class="btn btn--ghost-on-dark" href="tel:+19193355053">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .cta-row { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1.6rem; }
</style>
