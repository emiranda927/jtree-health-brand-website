---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

// Three clinical foundations. Each gets its own card with a plain-language explanation.
// TODO: VERIFY lead-therapist DBT credential before adding any certified-clinician language (register: pending).
const foundations = [
  {
    id: 'dbt',
    name: 'Dialectical Behavior Therapy (DBT)',
    href: '/what-we-offer/our-approach/dbt',
    body: [
      'DBT is the clinical spine of our program. It was developed for people whose emotions can become intense and hard to regulate. In our program, it gives each week a clear structure and gives teens something concrete to practice.',
      'Our groups are built around the four DBT skill sets: mindfulness, distress tolerance, emotion regulation, and interpersonal effectiveness. These are concrete tools, practiced in session and used at home, at school, and in relationships.',
    ],
  },
  {
    id: 'nervous-system',
    name: 'Nervous System Regulation',
    href: '/what-we-offer/our-approach/nervous-system-regulation',
    body: [
      'Threat and shutdown can make it much harder to think, speak, and learn. Nervous system regulation asks clinicians to notice that state before pushing ahead with discussion or skills.',
      'We help teens notice what is happening in their body and practice settling enough to stay present. That attention to timing shapes how sessions run.',
    ],
  },
  {
    id: 'trauma',
    name: 'Trauma-Informed Care',
    body: [
      'Trauma-informed care is the lens for the rest of the work. We look for the story behind a behavior. A teen is never required to share more than they are ready to say.',
      'Many teens who arrive with anxiety, depression, or dysregulation are carrying experiences that have not been named yet. We hold that possibility from the first day and pay close attention to safety, trust, and choice.',
    ],
  },
];

// Additional methods woven in as clinically indicated.
const additionalMethods = [
  {
    id: 'act',
    name: 'Acceptance and Commitment Therapy (ACT)',
    body: [
      'ACT helps teens notice difficult thoughts and feelings without letting them make every decision. The work then turns toward actions that match what the teen values.',
    ],
  },
  {
    id: 'cbt',
    name: 'Cognitive Behavioral Therapy (CBT)',
    body: [
      'CBT works on the connections between thoughts, feelings, and behavior, and helps teens develop patterns that serve them better. It is one of the most established approaches in adolescent mental health, woven into individual therapy and skills groups as clinically indicated.',
    ],
  },
  {
    id: 'family-systems',
    name: 'Family Systems Therapy',
    href: '/what-we-offer/our-approach/family-therapy',
    body: [
      'We understand a teen’s challenges in the context of the family around them, and family therapy is built into treatment. Parents leave sessions with concrete tools to support their teen at home.',
    ],
  },
];

// Three-part group structure. Same arc referenced on the IOP page; described in more depth here.
const groupParts = [
  {
    label: 'Part one',
    name: 'Processing group',
    body: 'Teens talk about what has been happening with peers and a facilitator in a structured setting. They hear from people their age and learn that they are not carrying everything alone.',
  },
  {
    label: 'Part two',
    name: 'Skills-building group',
    body: 'This is the teaching portion. Teens learn and practice DBT skills while building awareness of their own nervous-system state. The skills curriculum is delivered here.',
  },
  {
    label: 'Part three',
    name: 'Experiential group',
    body: 'Teens apply what they just learned through art, music, movement, somatic exercises, and mindfulness. A teen who is not ready to talk yet can still do the work here.',
  },
];

// Supporting experiential and expressive modalities.
const supportingModalities = [
  {
    id: 'experiential',
    name: 'Experiential Therapy',
    body: [
      'Experiential therapy brings the body and the environment into the work. Somatic exercises help teens notice what is happening physically when emotions rise.',
      'This connects directly to our nervous system regulation work: noticing body signals can help teens recognize when they are activated and respond with greater choice. Experiential work may also make use of movement, mindfulness, and the outdoor setting near our Apex location.',
    ],
  },
  {
    id: 'expressive',
    name: 'Expressive Therapy',
    body: [
      'Expressive therapy uses art, music, and other creative modalities as a way into emotional material that is hard to reach through words alone.',
      'For a teen who is not ready to talk about what happened, this is often where the work begins. Admissions and the clinical team can explain which expressive modalities are part of the current program.',
    ],
  },
];

// DBT skills curriculum phases. Described without week counts on purpose.
// TODO: VERIFY curriculum length (guide drafts a 12-week structure) before publishing any week numbers.
const phases = [
  {
    label: 'Phase one',
    name: 'Mindfulness',
    body: 'The foundation for everything else. Teens learn to notice what they are experiencing, in thought, emotion, and body, without immediately reacting to it. You can’t use a tool you can’t see yourself reaching for.',
  },
  {
    label: 'Phase two',
    name: 'Distress tolerance',
    body: 'Getting through a crisis without making it worse. Teens practice concrete tools for overwhelming moments, so the moment can pass without leaving new problems behind it.',
  },
  {
    label: 'Phase three',
    name: 'Emotion regulation',
    body: 'Understanding how emotions work and learning to influence them. Teens begin to map their own patterns, what sets them off and what settles them, and work on those patterns directly.',
  },
  {
    label: 'Phase four',
    name: 'Interpersonal effectiveness',
    body: 'Handling relationships without losing yourself or damaging the connection. Teens practice asking for what they need, setting limits, and keeping their self-respect with parents, peers, and teachers. The group itself becomes the practice ground.',
  },
];

// Structural choices, stated claim-safe.
// TODO: VERIFY family-session cadence and any caregiver skills group format before naming either (register: pending).
// TODO: VERIFY how individual sessions are scheduled across the week; no dedicated-day claim until confirmed (register: pending).
// TODO: VERIFY scope of psychiatric and outside-provider coordination before publishing more detail (register: pending).
const structuralChoices = [
  {
    name: 'Family involvement is built in',
    body: 'Family therapy is part of treatment. Parents learn how to recognize and reinforce the skills their teen is practicing, so the language used in session can carry into the kitchen and the car.',
  },
  {
    name: 'Individual therapy alongside the group',
    body: 'Individual therapy runs alongside the group program, so the work that needs privacy has a place of its own. Admissions will explain how individual and family sessions fit into the week.',
  },
  {
    name: 'Care coordination',
    body: 'When a teen already has a psychiatrist, pediatrician, or outside therapist, we coordinate care with those providers as clinically indicated and with your permission. Discharge planning starts well before discharge.',
  },
  {
    name: 'Measurement throughout care',
    body: 'We use standardized measures from intake through discharge. The team reviews the results while care is underway and revisits the plan when progress stalls.',
  },
];

// Modality tags, grouped by tier, shown as chips. No credential chips (register: pending).
const primaryTags = [
  'Dialectical Behavior Therapy (DBT)',
  'Nervous System Regulation',
  'Trauma-Informed Care',
];
const supportingTags = [
  'Acceptance and Commitment Therapy (ACT)',
  'Cognitive Behavioral Therapy (CBT)',
  'Family Systems Therapy',
  'Experiential Therapy',
  'Expressive Therapy',
  'Art Therapy',
  'Music Therapy',
  'Somatic Exercises',
  'Mindfulness Practice',
];

const faqs = [
  {
    q: 'What does DBT look like in a group session?',
    a: 'Teens practice specific skills together. A session might involve a distress tolerance exercise, role-playing a hard conversation, or working through an emotion regulation tool with a partner. Skills get practiced where a therapist can coach them, so they are ready to use outside the room.',
  },
  {
    q: 'My teen has been through therapy before and it didn’t help. How is this different?',
    a: 'IOP offers more clinical contact than weekly outpatient therapy, with structured group practice and family involvement. We also pay attention to the state a teen is in when skills are introduced. A teen who is overwhelmed or shut down may need help settling before they can use what they are learning.',
  },
  {
    q: 'Does my teen need to be willing to participate?',
    a: 'Most teens start with some resistance. Willingness tends to develop in the room, often faster than families expect. The structure and the peer connection do a lot of the early work.',
  },
  {
    q: 'Is the program trauma-focused specifically?',
    a: 'Trauma-informed care and trauma processing are different things. We do not process trauma in a group setting. Trauma-informed means we approach the work assuming a history we may not know yet, move at each teen’s pace, and put felt safety before skill-building. Deeper processing happens in individual therapy, when clinically indicated.',
  },
  {
    q: 'How are parents involved?',
    a: 'Family therapy is built into treatment, and parents practice the same skills their teen is learning, so home and treatment speak the same language. Admissions will explain what family participation currently looks like.',
  },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Our Approach: DBT & Nervous System Regulation | Joshua Tree Health"
  description="Joshua Tree Health's approach for teens in Apex, NC: DBT skills, nervous system regulation and somatic work, trauma-informed practice, and family involvement."
>
  <PageHero
    art="approach"
    title="Grounded in evidence. <em>Centered in connection.</em>"
    sub="The model starts with DBT skills and pays close attention to the state a teen is in when they try to use them. Family participation connects that work to home."
  />

  <!-- ===== INTRO ===== -->
  <section class="section" aria-labelledby="intro-title">
    <div class="container-x">
      <div class="prose" data-reveal>
        <h2 class="section-title font-display" id="intro-title">One plan, built around your teen.</h2>
        <p class="lead">Every teen who comes to Joshua Tree gets a treatment plan built around their specific situation, strengths, and goals.</p>
        <p>The plan draws on two foundational methods, DBT and nervous system regulation, with trauma-informed practice as the lens for everything we deliver. ACT, CBT, and family systems work are woven in where clinically indicated.</p>
      </div>
    </div>
  </section>

  <!-- ===== CLINICAL FOUNDATIONS (+ deeper reading) ===== -->
  <section class="section surface-cream-deep" aria-labelledby="foundations-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Clinical foundations</p>
        <h2 class="section-title font-display" id="foundations-title">The three foundations of our care.</h2>
        <p class="section-sub">You don't need a clinical background to understand what each one means for your teen. Here's what they are and how we use them.</p>
      </div>
      <div class="grid-3" data-reveal-group>
        {foundations.map((m) => (
          <article class="info-card" id={m.id} data-reveal-item>
            <h3 class="info-card__title">{m.name}</h3>
            {m.body.map((p) => (
              <p class="info-card__body">{p}</p>
            ))}
            {m.href && <a class="link-arrow" href={m.href}>Learn more →</a>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INSIDE A GROUP DAY (structure + sample week) ===== -->
  <section class="section surface-lavender" aria-labelledby="groups-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Inside a group day</p>
        <h2 class="section-title font-display" id="groups-title">How our groups are structured.</h2>
        <p class="section-sub">Each group session follows a three-part arc. Each part builds on the one before it.</p>
      </div>
      <div class="grid-3" data-reveal-group>
        {groupParts.map((part) => (
          <article class="info-card" data-reveal-item>
            <p class="part-label">{part.label}</p>
            <h3 class="info-card__title">{part.name}</h3>
            <p class="info-card__body">{part.body}</p>
          </article>
        ))}
      </div>
      <!-- TODO: VERIFY how individual and family sessions are currently scheduled across the week; no dedicated-day claim until confirmed. -->
      <!-- TODO: VERIFY PHP hours and weekly day count before publishing specifics. -->
      <div class="prose week-note" data-reveal>
        <p>In <a href="/what-we-offer/iop">IOP</a>, teen groups meet Monday, Wednesday, and Thursday, with a morning option (9am–12pm) or an afternoon option (3:30–6:30pm). A parent DBT skills group meets Tuesdays for some families, so IOP runs three to four days a week. Individual and family sessions are scheduled alongside group days.</p>
        <p><a href="/what-we-offer/php">PHP</a> runs during the day, four to five days a week. Admissions will walk you through the current schedule for either program.</p>
      </div>
    </div>
  </section>

  <!-- ===== SKILLS CURRICULUM PHASES ===== -->
  <!-- TODO: VERIFY curriculum length before publishing week counts; phases are described without numbers on purpose. -->
  <section class="section" aria-labelledby="curriculum-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">The skills curriculum</p>
        <h2 class="section-title font-display" id="curriculum-title">Skills build in sequence.</h2>
        <p class="section-sub">The curriculum moves through the four DBT skill sets. Experiential work reinforces the skill being taught at that point in the program.</p>
      </div>
      <div class="grid-2" data-reveal-group>
        {phases.map((phase) => (
          <article class="info-card" data-reveal-item>
            <p class="part-label">{phase.label}</p>
            <h3 class="info-card__title">{phase.name}</h3>
            <p class="info-card__body">{phase.body}</p>
          </article>
        ))}
      </div>
      <p class="program-note" data-reveal>Phases build across the program. Length of stay is decided with your family and the treatment team, then reviewed throughout care.</p>
    </div>
  </section>

  <!-- ===== THE WIDER TOOLKIT (additional + supporting methods + full toolkit) ===== -->
  <section class="section surface-cream-deep" aria-labelledby="toolkit-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">The wider toolkit</p>
        <h2 class="section-title font-display" id="toolkit-title">Other methods, woven in as they fit.</h2>
        <p class="section-sub">Beyond the three foundations, the team draws on these in individual sessions and groups. Some — like art, music, movement, and body awareness — give teens a way in before they have the words.</p>
      </div>
      <div class="grid-3" data-reveal-group>
        {[...additionalMethods, ...supportingModalities].map((m) => (
          <article class="info-card" id={m.id} data-reveal-item>
            <h3 class="info-card__title">{m.name}</h3>
            {m.body.map((p) => (
              <p class="info-card__body">{p}</p>
            ))}
            {m.href && <a class="link-arrow" href={m.href}>Learn more →</a>}
          </article>
        ))}
      </div>
      <div class="subsection tag-groups" data-reveal>
        <div class="tag-group">
          <h3 class="tag-group__label">Clinical foundations</h3>
          <div class="tag-row">
            {primaryTags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </div>
        <div class="tag-group">
          <h3 class="tag-group__label">Additional and supporting methods</h3>
          <div class="tag-row">
            {supportingTags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW CARE IS STRUCTURED ===== -->
  <section class="section" aria-labelledby="structure-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Structural choices</p>
        <h2 class="section-title font-display" id="structure-title">How we're structured.</h2>
        <p class="section-sub">These choices determine what the week feels like and where each kind of work has room to happen.</p>
      </div>
      <div class="grid-2" data-reveal-group>
        {structuralChoices.map((item) => (
          <article class="info-card" data-reveal-item>
            <h3 class="info-card__title">{item.name}</h3>
            <p class="info-card__body">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section surface-cream-deep" aria-labelledby="faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Common questions</p>
        <h2 class="section-title font-display" id="faq-title">What parents and clinicians ask about the model.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PULL-QUOTE (migrated from the retired For Teens page) ===== -->
  <section class="section surface-lavender" aria-labelledby="quote-title">
    <div class="container-x">
      <figure class="pullquote" data-reveal>
        <span class="pullquote__mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="pullquote__text font-display" id="quote-title">Small steps. Strong roots. You belong here.</blockquote>
        <figcaption class="pullquote__cite">What we tell every teen who walks in.</figcaption>
      </figure>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="cta-title">Not sure where to start?</h2>
        <p class="section-sub">Tell us what has been happening. We’ll help you understand whether this level of care fits.</p>
        <div class="cta-actions">
          <a href="/get-started" class="btn btn--on-dark">Get started <span class="btn__arrow">→</span></a>
          <a href="tel:+19193355053" class="btn btn--ghost-on-dark">Call (919) 335-5053</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .tag-groups { display: grid; gap: clamp(1.5rem, 1rem + 2vw, 2.5rem); }
  .tag-group__label {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.15;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-deep-sage);
    margin-bottom: 0.9rem;
  }
  .part-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.15;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-deep-sage);
    margin-bottom: 0.55rem;
  }
  .week-note { margin-top: clamp(1.75rem, 1.25rem + 1.5vw, 2.75rem); }
  .info-card .link-arrow { margin-top: 0.9rem; display: inline-flex; }
  .subsection { margin-top: clamp(2.75rem, 2rem + 2.5vw, 4.5rem); }
  .subsection__title {
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2.1rem);
    line-height: 1.06;
    color: var(--color-deep-green);
    margin-bottom: clamp(1.25rem, 1rem + 1vw, 2rem);
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
