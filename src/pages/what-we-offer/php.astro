---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const includes = [
  'Daily group therapy',
  'DBT skills practice',
  'Polyvagal-informed and somatic work (experiential therapy)',
  'Art therapy and music therapy (expressive therapy)',
  'Mindfulness practice, including nature walks at our lakeside Apex location',
  'Individual therapy',
  'Family sessions',
  'Care coordination and discharge planning',
];

const faqs = [
  {
    q: "What's the difference between PHP and IOP?",
    a: 'PHP is more intensive — teens are in programming most of the day, five days a week. IOP runs three days a week for several hours. The right level depends on where your teen is right now. If you’re not sure, the admissions call will help clarify.',
  },
  {
    q: 'Does my teen go home at night?',
    a: 'Yes. PHP is outpatient care. Your teen goes home every evening and maintains family connection throughout the program.',
  },
  {
    q: 'How long does PHP last?',
    a: 'Length of stay is individualized. Most teens move from PHP to IOP as they stabilize, and we make those transition decisions collaboratively with the teen and family.',
  },
];
---
<Base
  title="Partial Hospitalization Program (PHP) — Joshua Tree Health"
  description="A full day of structured, evidence-based treatment for teens ages 10–17 who need intensive support without inpatient hospitalization. Located in Apex, NC."
>
  <PageHero
    title="Partial Hospitalization Program (PHP)"
    sub="A full day of structured treatment for teens who need intensive support without inpatient hospitalization."
  />

  <!-- ===== WHAT IT IS ===== -->
  <section class="section" aria-labelledby="what-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="what-title">What it is</h2>
      </div>
      <div class="prose" data-reveal>
        <p class="lead">
          PHP is our highest level of outpatient care. It's built for teens in acute
          distress who are medically stable and safe at home, but need more support
          than IOP can provide.
        </p>
        <p>
          The program runs during the day. Teens come to Joshua Tree in the morning and
          go home in the evening, keeping family connection throughout treatment without
          the disruption of an inpatient setting.
        </p>
        <p>
          PHP is also a common step-down from inpatient or residential care, providing
          structured support during the transition back to everyday life.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT IT INCLUDES ===== -->
  <section class="section surface-cream-deep" aria-labelledby="includes-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="includes-title">What it includes</h2>
      </div>
      <ul class="checklist" data-reveal>
        {includes.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="section" aria-labelledby="who-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="who-title">Who it's for</h2>
      </div>
      <div class="prose" data-reveal>
        <p>
          Teens in acute distress who are medically stable and safe at home, but whose
          level of need exceeds what IOP provides. It's also appropriate for teens
          stepping down from inpatient or residential care. Ages 10–17.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section surface-cream-deep" aria-labelledby="faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="faq-title">Questions parents ask</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="cta-title">Not sure if PHP is the right level?</h2>
        <p class="section-sub">If you're weighing PHP against IOP, an admissions call is the fastest way to figure out what your teen needs. We'll talk it through with you first.</p>
      </div>
      <div class="page-hero__actions" style="justify-content:center;" data-reveal>
        <a href="/admissions" class="btn btn--on-dark">Find the Right Level of Care <span class="btn__arrow">→</span></a>
        <a href="tel:+19193355053" class="btn btn--ghost-on-dark">Call (919) 335-5053</a>
      </div>
    </div>
  </section>
</Base>
