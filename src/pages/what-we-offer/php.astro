---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const includes = [
  'Group therapy during the day, four to five days a week',
  'DBT and CBT skills practice',
  'Nervous system regulation and somatic work (experiential therapy)',
  'Art therapy and music therapy (expressive therapy)',
  'Mindfulness practice, including nature walks at our lakeside Apex location',
  // TODO: VERIFY dedicated-day individual therapy before describing a set day.
  'Individual therapy alongside the group program',
  'Family therapy sessions',
  // TODO: VERIFY current school-coordination practice during PHP before describing a formal process.
  'Help with school logistics during the school year',
  // TODO: VERIFY scope of coordinated psychiatric care before naming it directly.
  'Care coordination with outside providers, as clinically indicated',
  'Discharge planning and transition support, often into IOP',
];

const whoItsFor = [
  'Teens whose symptoms need more support than IOP provides',
  'Teens stepping down from inpatient, residential, or emergency care',
  'Adolescents ages 10–17',
];

const faqs = [
  {
    q: "What's the difference between PHP and IOP?",
    a: "PHP is our highest level of outpatient care. It runs during the day, four to five days a week — more than IOP, which runs three to four days a week. Both are outpatient, so teens go home every evening. If you're unsure which level fits, the assessment with one of our licensed therapists will help answer that.",
  },
  {
    q: 'Does my teen go home at night?',
    a: 'Yes. PHP is outpatient. Your teen goes home every evening and stays connected to family throughout the program.',
  },
  {
    q: 'What happens to school during PHP?',
    // TODO: VERIFY current school-coordination practice during PHP before describing a formal process.
    a: 'During the school year, we work with families on school logistics. Admissions and the clinical team will talk through what that could look like for your teen.',
  },
  {
    q: 'How long does PHP last?',
    a: 'Most teens are in PHP for about 2 to 6 weeks before stepping down, often into IOP. Length of stay is individualized — decided with the teen, family, and treatment team and reviewed throughout care.',
  },
  {
    q: 'How quickly can we start?',
    a: 'There is no waitlist. A typical start is three to five days from first contact, depending on scheduling and insurance verification.',
  },
  {
    q: 'Does insurance cover PHP?',
    a: "Coverage depends on your specific plan. We'll verify your insurance benefits and walk you through expected costs before care begins.",
  },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Base
  bodyClass="brand-page rollout-page"
  title="Teen Partial Hospitalization (PHP) | Joshua Tree Health"
  description="PHP for teens ages 10–17 in Apex, NC. Our highest level of outpatient care: structured days at Joshua Tree, home every evening. No waitlist."
  jsonLd={faqSchema}
>
  <PageHero
    art="session"
    hideTape
    title="Partial Hospitalization Program (PHP)"
    sub="Our most intensive outpatient program. Teens spend the day in treatment and return home every evening."
    primaryCta={{ label: 'Find the right level of care', href: '/get-started' }}
    secondaryCta={{ label: 'Call (919) 335-5053', href: 'tel:+19193355053' }}
  />

  <!-- ===== WHAT IT IS ===== -->
  <section class="section" aria-labelledby="what-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="what-title">What it is</h2>
      </div>
      <div class="prose" data-reveal>
        <p class="lead">
          PHP is our highest level of outpatient care. It is for teens who are medically stable and
          safe at home while needing focused clinical attention during the day.
        </p>
        <!-- TODO: VERIFY exact PHP daily hours before publishing specifics. -->
        <p>
          The program runs during the day, four to five days a week — more than IOP. Teens come to
          Joshua Tree in the morning and go home each evening, so family life remains part of
          treatment. Admissions will walk you through the current weekly schedule.
        </p>
        <p>
          PHP is often the right fit in two situations: when a teen needs more support than IOP can
          provide, and when a teen is stepping down from inpatient, residential, or emergency care
          and needs structure during that transition.
        </p>
        <p>
          Most teens are in PHP for about 2 to 6 weeks and step down into IOP as they stabilize.
          Length of stay is decided with the teen, family, and treatment team and reviewed throughout
          care.
        </p>
        <!-- TODO: VERIFY current school-coordination practice during PHP before describing a formal process. -->
        <p>
          During the school year, we work with families on the practical questions around school.
          Admissions and the clinical team will explain what that can look like for your teen.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== WHAT IT INCLUDES ===== -->
  <section class="section surface-cream-deep" aria-labelledby="includes-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="includes-title">What it includes</h2>
      </div>
      <ul class="checklist" data-reveal>
        {includes.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="section" aria-labelledby="who-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="who-title">Who it's for</h2>
      </div>
      <ul class="checklist" data-reveal>
        {whoItsFor.map((item) => <li>{item}</li>)}
      </ul>
      <!-- TODO: VERIFY separate pre-teen and teen group tracks before production. -->
      <p class="program-note" data-reveal>Programming is developmentally appropriate across ages 10–17, and our admissions team will explain how groups are organized for your child's age.</p>
    </div>
  </section>

  <!-- ===== WHAT PARENTS NEED TO KNOW ===== -->
  <section class="section surface-lavender" aria-labelledby="parents-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">For parents</p>
        <h2 class="section-title font-display" id="parents-title">What parents need to know</h2>
      </div>
      <div class="prose" data-reveal>
        <h3>Do they go home every evening?</h3>
        <p>
          Yes, every night. PHP is outpatient care, and your teen sleeps at home for the length of
          the program.
        </p>

        <h3>What happens with school?</h3>
        <!-- TODO: VERIFY current school-coordination practice during PHP before describing a formal process. -->
        <p>
          During the school year, we work with families on school logistics. Admissions and the
          clinical team will talk through what that could look like for your teen.
        </p>

        <h3>How involved will I be?</h3>
        <p>
          Family therapy is part of the work, and you'll have regular contact with your teen's
          treatment team while they're in the program.
        </p>

        <h3>What does the day look like?</h3>
        <!-- TODO: VERIFY exact PHP hours and weekly day count before publishing specifics. -->
        <p>
          Groups follow the same three-part structure used across our programs: processing with
          peers, DBT and CBT skills practice with nervous system regulation, and experiential work
          with art, music, somatic exercises, and mindfulness. Individual therapy runs alongside the
          group program, and admissions will walk you through the current weekly schedule.
        </p>

        <h3>What happens after PHP?</h3>
        <p>
          Most teens step down into IOP as they stabilize. Discharge planning starts early, and
          transition decisions are made with the teen, family, and treatment team.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section surface-cream-deep" aria-labelledby="faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <h2 class="section-title font-display" id="faq-title">Questions parents ask</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <div class="faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="section surface-green" aria-labelledby="cta-title">
    <div class="container-x">
      <div class="section-head section-head--center" data-reveal>
        <h2 class="section-title font-display" id="cta-title">Not sure if PHP is the right level?</h2>
        <p class="section-sub">Describe what is happening now. A licensed therapist will assess which level fits, and admissions will explain the schedule and cost before care begins.</p>
      </div>
      <div class="page-hero__actions" style="justify-content:center;" data-reveal>
        <a href="/get-started" class="btn btn--on-dark">Find the right level of care <span class="btn__arrow">→</span></a>
        <a href="tel:+19193355053" class="btn btn--ghost-on-dark">Call (919) 335-5053</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .program-note { max-width: 54rem; margin-top: 2rem; color: var(--color-ink-soft); font-size: 1.05rem; line-height: 1.6; }
</style>
