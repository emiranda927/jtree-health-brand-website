---
import DesignLab from '../layouts/DesignLab.astro';
import { Image } from 'astro:assets';
import peopleInDesert from '../assets/images/joshua-tree-hero.webp';
import FigmaHeroArt from '../components/brand/FigmaHeroArt.astro';

const spots = [
  { name: 'Anxiety', file: 'anxious.svg', note: 'Too many thoughts competing at once.' },
  { name: 'Depression', file: 'depression.svg', note: 'Low energy, with growth still present.' },
  { name: 'DBT + CBT', file: 'dbt-cbt-reframing.svg', note: 'Skills, communication, and reframing.' },
  { name: 'Mindfulness', file: 'mindfulness-meditation.svg', note: 'Steadiness without clinical coldness.' },
  { name: 'Art therapy', file: 'art-therapy.svg', note: 'Expression as part of treatment.' },
  { name: 'Music therapy', file: 'music-therapy.svg', note: 'A warm, age-appropriate point of entry.' },
  { name: 'Nature', file: 'nature-walking.svg', note: 'Movement and the Joshua Tree setting.' },
  { name: 'Hope', file: 'happy.svg', note: 'Optimism that does not feel childish.' },
];

const colors = [
  { name: 'Forest', hex: '#1E3D34' },
  { name: 'Deep Sage', hex: '#2C5F52' },
  { name: 'Mist Sage', hex: '#8FBFB0' },
  { name: 'Cyber Lime', hex: '#B8E04A' },
  { name: 'Digital Lavender', hex: '#A89FD8' },
  { name: 'Light Cream', hex: '#FFFAF3' },
];
---
<DesignLab>
  <header class="lab-bar">
    <a class="lab-brand" href="#top" aria-label="Joshua Tree Health design lab home">
      <img src="/brand-v2/logos/secondary-forest.svg" alt="Joshua Tree Health" />
    </a>
    <p>Internal design review</p>
    <a class="lab-jump" href="#review">Review criteria</a>
  </header>

  <main id="main">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <FigmaHeroArt />
      <div class="hero-copy">
        <p class="eyebrow">Design direction 01 · Mixed-media editorial</p>
        <h1 id="hero-title">Grow in a shape <span>entirely your own.</span></h1>
        <p class="hero-lede">
          Structured mental-health care for teens, grounded in evidence and built around human connection.
        </p>
        <div class="hero-actions" aria-label="Button design samples">
          <a href="#system" class="button button-primary">Explore the system</a>
          <a href="#registers" class="text-link">See the credibility register <span aria-hidden="true">→</span></a>
        </div>
        <dl class="hero-proof" aria-label="Brand qualities">
          <div><dt>Grounded</dt><dd>Real people and real environments</dd></div>
          <div><dt>Optimistic</dt><dd>Growth without forced positivity</dd></div>
          <div><dt>Credible</dt><dd>Clinical clarity stays easy to find</dd></div>
        </dl>
      </div>

    </section>

    <section class="signal" aria-label="Core brand proposition">
      <img src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
      <p>Real humans</p><span aria-hidden="true">+</span>
      <p>Desert resilience</p><span aria-hidden="true">+</span>
      <p>Expressive illustration</p><span aria-hidden="true">+</span>
      <p>Clinical clarity</p>
    </section>

    <section class="pathways" aria-label="Expressive wayfinding examples">
      <a href="#spots" class="pathway">
        <img src="/brand-v2/spots/happy.svg" alt="" aria-hidden="true" />
        <div><h2>For teens</h2><p>Care that feels human, useful, and made for you.</p><span>Explore care →</span></div>
      </a>
      <a href="#registers" class="pathway pathway-offset">
        <img src="/brand-v2/spots/nature-walking.svg" alt="" aria-hidden="true" />
        <div><h2>For families</h2><p>Clear answers for the people helping teens heal.</p><span>For parents →</span></div>
      </a>
      <a href="#system" class="pathway">
        <img src="/brand-v2/spots/dbt-cbt-reframing.svg" alt="" aria-hidden="true" />
        <div><h2>Our approach</h2><p>Evidence-based treatment with room for real life.</p><span>How care works →</span></div>
      </a>
      <a href="#spots" class="pathway pathway-offset">
        <img src="/brand-v2/spots/anxious.svg" alt="" aria-hidden="true" />
        <div><h2>What we treat</h2><p>Support for the thoughts and feelings taking over.</p><span>See conditions →</span></div>
      </a>
    </section>

    <section class="system section" id="system" aria-labelledby="system-title">
      <div class="section-intro">
        <p class="eyebrow">One identity, three registers</p>
        <h2 id="system-title">Expressive where emotion matters. Restrained where trust matters.</h2>
        <p>
          The brand should not use every asset at once. Each family has a specific job, and the amount of expression changes with the audience.
        </p>
      </div>

      <div class="system-row system-row-photo">
        <div class="system-copy">
          <span class="index">01</span>
          <h3>Photography + collage</h3>
          <p>The primary emotional language for the homepage, About, culture, and parent-facing stories.</p>
          <ul>
            <li>Real people and specific environments</li>
            <li>One dominant photograph or collage</li>
            <li>Watercolor, tape, and line art recur in deliberate clusters</li>
            <li>Use owned or appropriately licensed photography in production</li>
          </ul>
        </div>
        <div class="photo-composition">
          <img class="photo-wash" src="/brand-v2/washes/wash-09.webp" alt="" aria-hidden="true" />
          <div class="photo-frame">
            <Image class="photo-base" src={peopleInDesert} alt="A group of teens talking together beneath a Joshua tree in the desert" widths={[720, 1080, 1440]} sizes="(max-width: 1050px) 90vw, 55vw" />
          </div>
          <img class="photo-tape" src="/brand-v2/tapes/tape-06.webp" alt="" aria-hidden="true" />
          <img class="photo-line" src="/brand-v2/halos/halo-15-forest.svg" alt="" aria-hidden="true" />
          <img class="photo-bloom" src="/brand-v2/halos/halo-9-lime.svg" alt="" aria-hidden="true" />
        </div>
      </div>

      <div class="system-row system-row-spots">
        <div class="system-copy">
          <span class="index">02</span>
          <h3>Spot illustrations</h3>
          <p>Distinctive visual explanations for conditions, therapies, and skills—not tiny decorative icons.</p>
          <ul>
            <li>What We Treat and program education</li>
            <li>One illustration family, preserved as delivered</li>
            <li>Open layouts instead of repetitive card boxes</li>
          </ul>
        </div>
        <div class="spot-preview" aria-hidden="true">
          <img src="/brand-v2/spots/anxious.svg" alt="" />
          <img src="/brand-v2/spots/dbt-cbt-reframing.svg" alt="" />
          <img src="/brand-v2/spots/happy.svg" alt="" />
        </div>
      </div>

      <div class="system-row system-row-marks">
        <div class="system-copy">
          <span class="index">03</span>
          <h3>Graphic punctuation</h3>
          <p>Halos, squiggles, tape, and small marks create continuity. They support the composition rather than becoming the composition.</p>
          <ul>
            <li>Forest is the default line color</li>
            <li>Lime and lavender mark emphasis</li>
            <li>A small recurring subset builds recognition</li>
          </ul>
        </div>
        <div class="marks-stage" aria-hidden="true">
          <img class="mark-a" src="/brand-v2/halos/halo-9-lime.svg" alt="" />
          <img class="mark-b" src="/brand-v2/graphics/element-13-deep-sage.svg" alt="" />
          <img class="mark-c" src="/brand-v2/graphics/element-11-colorway.svg" alt="" />
          <img class="mark-d" src="/brand-v2/halos/halo-10-lavender.svg" alt="" />
        </div>
      </div>
    </section>

    <section class="spots section" id="spots" aria-labelledby="spots-title">
      <div class="section-intro section-intro-wide">
        <p class="eyebrow">Illustration voice</p>
        <h2 id="spots-title">Characterful enough to remember. Clear enough to understand.</h2>
      </div>
      <div class="spot-grid">
        {spots.map((spot, index) => (
          <article class:list={['spot-item', index === 0 || index === 3 ? 'spot-item-wide' : '']}>
            <div class="spot-art"><img src={`/brand-v2/spots/${spot.file}`} alt={`${spot.name} spot illustration`} loading="lazy" /></div>
            <div class="spot-caption"><h3>{spot.name}</h3><p>{spot.note}</p></div>
          </article>
        ))}
      </div>
    </section>

    <section class="registers" id="registers" aria-labelledby="register-title">
      <div class="register-copy">
        <p class="eyebrow eyebrow-light">Parent + referral register</p>
        <h2 id="register-title">Warm does not have to mean informal.</h2>
        <p>
          Clinical credibility comes from hierarchy, restraint, readable evidence, and direct language. The expressive system remains present, but at a lower volume.
        </p>
        <div class="care-facts">
          <div><strong>PHP + IOP</strong><span>Structured levels of care</span></div>
          <div><strong>Ages 10–17</strong><span>Adolescent specialization</span></div>
          <div><strong>Apex, NC</strong><span>Serving Triangle families</span></div>
        </div>
        <a class="button button-lime" href="#review">Review the system</a>
      </div>
      <div class="register-art">
        <img class="register-wash" src="/brand-v2/washes/wash-08.webp" alt="" aria-hidden="true" />
        <img class="register-scene" src="/brand-v2/watercolor/one-on-one-therapy.webp" alt="Watercolor illustration of a teen in a one-on-one therapy session" loading="lazy" />
        <img class="register-tape" src="/brand-v2/tapes/tape-08.webp" alt="" aria-hidden="true" />
        <img class="register-line" src="/brand-v2/halos/halo-10-lime.svg" alt="" aria-hidden="true" />
      </div>
    </section>

    <section class="foundations section" aria-labelledby="foundations-title">
      <div class="section-intro">
        <p class="eyebrow">Foundations</p>
        <h2 id="foundations-title">A controlled base lets the expressive work feel intentional.</h2>
      </div>

      <div class="type-specimen">
        <div class="type-primary"><span>Batica Sans</span><p>Primary display headings: warm, modern, and slightly unconventional.</p></div>
        <div class="type-impact"><span>Misoka Heavy</span><p>Brows, navigation, buttons, short headings, and compact moments of emphasis.</p></div>
        <div class="type-editorial"><span>Fraunces SuperSoft</span><p>Body copy and editorial support that restores warmth and clinical credibility.</p></div>
      </div>

      <div class="palette" aria-label="Official brand colors">
        {colors.map((color) => (
          <div class="swatch" style={`--swatch: ${color.hex}`}>
            <div class="swatch-color"></div>
            <p><strong>{color.name}</strong><span>{color.hex}</span></p>
          </div>
        ))}
      </div>
    </section>

    <section class="review section" id="review" aria-labelledby="review-title">
      <img class="review-mark" src="/brand-v2/graphics/element-1-forest.svg" alt="" aria-hidden="true" />
      <p class="eyebrow">Approval gate</p>
      <h2 id="review-title">Before this touches the live site</h2>
      <ol>
        <li><span>01</span><p>Does the Batica, Misoka, and Fraunces hierarchy balance personality with clinical credibility?</p></li>
        <li><span>02</span><p>Does Light Cream feel right as the default ground instead of white?</p></li>
        <li><span>03</span><p>Is the increased use of spot art, line work, color, and underlines expressive without becoming busy?</p></li>
        <li><span>04</span><p>Do the parent and referral sections feel calm and clinically trustworthy?</p></li>
        <li><span>05</span><p>Which two or three halo/squiggle marks should repeat across the whole site?</p></li>
      </ol>
      <p class="review-note">No production pages have been changed. This route is excluded from search indexing.</p>
    </section>
  </main>

  <footer class="lab-footer">
    <img src="/brand-v2/logos/primary-white.svg" alt="Joshua Tree Health" />
    <p>Design laboratory · Final assets from Nicole · July 2026</p>
  </footer>
</DesignLab>

<style>
  .lab-bar {
    min-height: 78px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem clamp(1.25rem, 4vw, 4.5rem);
    border-bottom: 1px solid var(--jth-line);
    background: color-mix(in srgb, var(--jth-cream) 92%, transparent);
    backdrop-filter: blur(18px);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .lab-brand img { width: 174px; height: auto; }
  .lab-bar p { margin: 0; font-family: var(--jth-impact); font-size: .95rem; line-height: 1.15; text-transform: uppercase; letter-spacing: .04em; color: var(--jth-ink-soft); }
  .lab-jump { justify-self: end; font-family: var(--jth-impact); font-size: .95rem; line-height: 1.15; text-transform: uppercase; letter-spacing: .025em; text-decoration: none; border-bottom: 2px solid var(--jth-lavender); }

  .hero {
    position: relative;
    min-height: min(850px, calc(100dvh - 78px));
    display: grid;
    grid-template-columns: minmax(0, .94fr) minmax(0, 1.06fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 7rem);
    max-width: 1440px;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 5vw, 5rem) clamp(5rem, 9vw, 9rem);
    overflow: hidden;
  }
  .hero-copy { min-width: 0; position: relative; z-index: 2; }
  .eyebrow { margin: 0 0 1.4rem; font-family: var(--jth-impact); font-size: .98rem; line-height: 1.15; letter-spacing: .04em; text-transform: uppercase; color: var(--jth-deep-sage); }
  .hero h1 {
    margin: 0;
    max-width: 9.8ch;
    font-family: var(--jth-display);
    font-size: clamp(3.7rem, 7.1vw, 7.3rem);
    font-weight: 700;
    letter-spacing: -.045em;
    line-height: .88;
  }
  .hero h1 span { display: block; color: var(--jth-deep-sage); }
  .hero-lede { max-width: 37rem; margin: 2rem 0 0; font-size: clamp(1.08rem, 1.5vw, 1.35rem); line-height: 1.55; color: var(--jth-ink-soft); }
  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.35rem; margin-top: 2.25rem; }
  .button { display: inline-flex; align-items: center; justify-content: center; min-height: 52px; padding: .9rem 1.55rem; border-radius: 999px; font-family: var(--jth-impact); font-size: 1rem; line-height: 1.1; text-transform: uppercase; letter-spacing: .025em; text-decoration: none; transition: transform 180ms ease, background 180ms ease; }
  .button:hover { transform: translateY(-2px); }
  .button:active { transform: translateY(0) scale(.98); }
  .button:focus-visible, .text-link:focus-visible, .lab-jump:focus-visible { outline: 3px solid var(--jth-lavender); outline-offset: 4px; }
  .button-primary { background: var(--jth-forest); color: var(--jth-cream); }
  .text-link { font-family: var(--jth-impact); font-size: .95rem; line-height: 1.2; text-transform: uppercase; letter-spacing: .025em; text-decoration-color: var(--jth-lavender); text-decoration-thickness: 2px; text-underline-offset: .35em; }
  .text-link span { margin-left: .25rem; }
  .hero-proof { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 3.25rem 0 0; padding-top: 1.25rem; border-top: 1px solid var(--jth-line); }
  .hero-proof div { min-width: 0; }
  .hero-proof dt { font-family: var(--jth-impact); font-size: .95rem; line-height: 1.15; text-transform: uppercase; letter-spacing: .025em; }
  .hero-proof dd { margin: .25rem 0 0; font-size: .95rem; line-height: 1.5; color: var(--jth-ink-soft); }

  .signal { position: relative; display: grid; grid-template-columns: repeat(7, auto); justify-content: center; align-items: center; gap: .85rem; min-height: 118px; padding: 2rem clamp(1.25rem, 5vw, 5rem); background: var(--jth-lime); color: var(--jth-forest); overflow: hidden; }
  .signal > img { position: absolute; width: 76px; left: clamp(1rem, 5vw, 5rem); top: 50%; transform: translateY(-50%) rotate(-12deg); opacity: .72; }
  .signal p { position: relative; margin: 0; font-family: var(--jth-impact); font-size: clamp(.95rem, 1.35vw, 1.2rem); text-transform: uppercase; letter-spacing: .018em; white-space: nowrap; }
  .signal span { font-family: var(--jth-editorial); font-size: 1.3rem; }

  .pathways { max-width: 1440px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(1rem, 2vw, 2rem); padding: clamp(4.5rem, 7vw, 7rem) clamp(1.25rem, 5vw, 5rem); }
  .pathway { min-width: 0; display: grid; grid-template-rows: 240px auto; color: inherit; text-decoration: none; }
  .pathway-offset { transform: translateY(2.25rem); }
  .pathway > img { width: 100%; height: 230px; object-fit: contain; transition: transform 260ms cubic-bezier(.2,.8,.2,1); }
  .pathway:hover > img { transform: translateY(-8px) rotate(-1.5deg); }
  .pathway > div { position: relative; padding-top: 1.25rem; border-top: 1px solid var(--jth-line); }
  .pathway:nth-child(2) > div { border-color: var(--jth-lavender); }
  .pathway:nth-child(3) > div { border-color: var(--jth-lime); }
  .pathway h2 { margin: 0; font-family: var(--jth-impact); font-size: clamp(1rem, 1.5vw, 1.35rem); line-height: 1; text-transform: uppercase; letter-spacing: .02em; }
  .pathway p { margin: .75rem 0 1.3rem; color: var(--jth-ink-soft); font-size: 1.0625rem; line-height: 1.58; }
  .pathway span { font-family: var(--jth-impact); font-size: .95rem; line-height: 1.2; text-transform: uppercase; letter-spacing: .025em; border-bottom: 2px solid var(--jth-lavender); }

  .section { padding: clamp(5.5rem, 9vw, 10rem) clamp(1.25rem, 5vw, 5rem); }
  #system, #spots, #registers, #review { scroll-margin-top: 78px; }
  .section-intro { max-width: 840px; margin-bottom: clamp(4rem, 7vw, 7rem); }
  .section-intro-wide { max-width: 1050px; }
  .section h2, .registers h2, .review h2 { margin: 0; font-family: var(--jth-display); font-size: clamp(2.8rem, 5.5vw, 5.7rem); line-height: .95; letter-spacing: -.035em; }
  .section-intro > p:last-child { max-width: 58ch; margin: 1.5rem 0 0; color: var(--jth-ink-soft); font-size: 1.08rem; }
  .system { max-width: 1440px; margin: 0 auto; }
  .system-row { display: grid; grid-template-columns: minmax(260px, .72fr) minmax(0, 1.28fr); gap: clamp(2.5rem, 7vw, 8rem); align-items: center; padding: clamp(3.5rem, 7vw, 7rem) 0; border-top: 1px solid var(--jth-line); }
  .system-copy .index { display: inline-block; margin-bottom: 2.2rem; font-family: var(--jth-impact); font-size: .95rem; line-height: 1.15; letter-spacing: .04em; }
  .system-copy h3 { margin: 0; font-family: var(--jth-impact); font-size: clamp(1.65rem, 2.9vw, 3rem); line-height: .9; text-transform: uppercase; letter-spacing: .012em; }
  .system-copy > p { max-width: 38rem; margin: 1.25rem 0 0; color: var(--jth-ink-soft); }
  .system-copy ul { margin: 1.7rem 0 0; padding: 0; list-style: none; }
  .system-copy li { padding: .7rem 0; border-top: 1px solid var(--jth-line); font-size: 1.0625rem; line-height: 1.5; }
  .photo-composition { width: 100%; max-width: 780px; min-height: 560px; position: relative; justify-self: end; isolation: isolate; }
  .photo-wash { position: absolute; width: 100%; max-width: none; left: 50%; top: 5%; z-index: -1; opacity: .74; transform: translateX(-50%) rotate(4deg); }
  .photo-frame { position: absolute; width: 88%; right: 3%; top: 10%; padding: 10px; background: var(--jth-cream); box-shadow: 0 28px 54px rgba(30,61,52,.12); transform: rotate(-1.4deg); clip-path: polygon(2% 4%, 98% 0, 100% 93%, 94% 100%, 3% 97%, 0 12%); }
  .photo-base { width: 100%; height: 390px; object-fit: cover; object-position: 70% center; clip-path: polygon(1% 2%, 99% 0, 100% 95%, 94% 100%, 2% 98%, 0 8%); }
  .photo-tape { position: absolute; width: 25%; max-width: 170px; right: 2%; top: 4%; transform: rotate(13deg); }
  .photo-line { position: absolute; width: 17%; max-width: 118px; left: 2%; bottom: 6%; }
  .photo-bloom { position: absolute; width: 14%; max-width: 98px; right: 0; bottom: 2%; transform: rotate(12deg); }
  .spot-preview { min-height: 520px; display: grid; grid-template-columns: repeat(3, 1fr); align-items: end; gap: 1rem; padding: 3rem 2rem 1.5rem; background: var(--jth-paper); overflow: hidden; }
  .spot-preview img { width: 100%; height: 300px; object-fit: contain; }
  .spot-preview img:nth-child(2) { align-self: start; transform: translateY(-1rem); }
  .marks-stage { min-height: 520px; position: relative; overflow: hidden; background: var(--jth-mist-sage); }
  .mark-a { position: absolute; width: 120px; left: 8%; bottom: 8%; }
  .mark-b { position: absolute; width: 165px; right: 8%; bottom: 8%; }
  .mark-c { position: absolute; width: 150px; right: 23%; top: 15%; }
  .mark-d { position: absolute; width: 105px; left: 13%; top: 12%; transform: rotate(-14deg); }

  .spots { background: var(--jth-paper); overflow: hidden; }
  .spots > * { max-width: 1440px; margin-left: auto; margin-right: auto; }
  .spot-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: clamp(2rem, 4vw, 5rem) 1.25rem; }
  .spot-item { grid-column: span 3; margin: 0; }
  .spot-item-wide { grid-column: span 4; }
  .spot-art { min-height: 300px; display: grid; place-items: center; }
  .spot-art img { width: 100%; height: 290px; object-fit: contain; transition: transform 260ms cubic-bezier(.2,.8,.2,1); }
  .spot-item:hover .spot-art img { transform: translateY(-8px) rotate(-1deg); }
  .spot-caption { padding-top: 1.2rem; border-top: 1px solid var(--jth-line); }
  .spot-caption h3 { margin: 0; font-family: var(--jth-impact); font-size: 1.08rem; line-height: 1; text-transform: uppercase; letter-spacing: .02em; }
  .spot-caption p { margin: .5rem 0 0; color: var(--jth-ink-soft); font-size: 1rem; line-height: 1.55; }

  .registers { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, .9fr); min-height: 760px; background: var(--jth-forest); color: var(--jth-cream); overflow: hidden; }
  .register-copy { padding: clamp(5rem, 9vw, 9rem) clamp(1.25rem, 6vw, 7rem); align-self: center; }
  .eyebrow-light { color: var(--jth-mist-sage); }
  .register-copy > p:not(.eyebrow) { max-width: 52ch; margin: 1.7rem 0 0; color: rgba(255,250,243,.75); }
  .care-facts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 3rem 0; padding-top: 1.3rem; border-top: 1px solid rgba(255,250,243,.22); }
  .care-facts strong, .care-facts span { display: block; }
  .care-facts strong { font-family: var(--jth-impact); font-size: 1rem; text-transform: uppercase; letter-spacing: .02em; }
  .care-facts span { margin-top: .25rem; color: rgba(255,250,243,.78); font-size: .95rem; line-height: 1.5; }
  .button-lime { background: var(--jth-lime); color: var(--jth-forest); }
  .register-art { position: relative; width: 100%; min-height: 620px; align-self: stretch; background: var(--jth-deep-sage); isolation: isolate; overflow: hidden; }
