---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Figure from '../components/Figure.astro';
import sessionImg from '../assets/illustrations/session-1to1.png';

const vibe = [
  { title: 'No judgment', body: "You won't be lectured, labeled, or treated like a problem. You're a person, not a diagnosis." },
  { title: 'You set the pace', body: "Don't want to talk yet? That's allowed. Nobody's going to force you to share before you're ready." },
  { title: 'Keep your life', body: 'You go home every night. You keep your phone, your friends, your routines. This fits around your life.' },
  { title: 'Real tools', body: "Not just 'how does that make you feel.' Actual skills for when things get loud in your head." },
];

const faqs = [
  { q: 'Do I have to talk in group?', a: "Nope. You can listen until you're ready. Most people find it's easier than they expected once they're in the room." },
  { q: 'Will my friends find out?', a: 'What happens here is private. You decide who knows and what you share. That part is yours.' },
  { q: 'Is this like being locked up?', a: 'Not even close. You go home every evening. You keep your phone. You keep your life. This is the opposite of being sent away.' },
  { q: "What if I don't even want to be here?", a: "Fair. A lot of people start exactly there. We're not trying to 'fix' you — we're here to help you figure out your own next step." },
];
---
<Base
  title="For Teens — What it's actually like | Joshua Tree Health"
  description="Real talk for teens: what Joshua Tree Health is actually like. No judgment, you set the pace, you keep your life, and you get real tools that work."
>
  <PageHero
    variant="green"
    eyebrow="For teens"
    title="You don't have to have it<br>all <em>figured out</em>."
    sub="Real talk: this isn't about being 'fixed.' It's a place to catch your breath, pick up some tools, and figure out your own next step — with people who actually get it."
    primaryCta={{ label: 'See how it works', href: '/programs' }}
  />

  <section class="section" aria-labelledby="session-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal>
          <p class="eyebrow">What it feels like</p>
          <h2 class="section-title font-display" id="session-title">Just you and someone who's actually listening.</h2>
          <p class="section-sub">One-on-one sessions are exactly what they sound like — a real conversation, at your pace, with someone whose whole job is to get where you're coming from. No script. No rush. No judgment.</p>
        </div>
        <div data-reveal data-reveal-delay="0.08">
          <Figure src={sessionImg} alt="Illustration of a teen and a therapist talking in armchairs during a one-on-one session" />
        </div>
      </div>
    </div>
  </section>

  <section class="section surface-cream-deep" aria-labelledby="vibe-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">What it's actually like</p>
        <h2 class="section-title font-display" id="vibe-title">No fixing. Just real support.</h2>
      </div>
      <div class="grid-4" data-reveal-group>
        {vibe.map((v) => (
          <article class="info-card info-card--hover" data-reveal-item>
            <h3 class="info-card__title">{v.title}</h3>
            <p class="info-card__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="quote surface-lavender" aria-label="In their words">
    <div class="container-x">
      <div class="pullquote">
        <span class="pullquote__mark" aria-hidden="true">“</span>
        <p class="pullquote__text" data-reveal>Small steps. Strong roots. You belong here.</p>
        <p class="pullquote__cite" data-reveal data-reveal-delay="0.08">What we tell every teen who walks in</p>
      </div>
    </div>
  </section>

  <section class="section surface-cream-deep" aria-labelledby="teen-faq-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Stuff you might be wondering</p>
        <h2 class="section-title font-display" id="teen-faq-title">The real questions.</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <p class="faq__answer">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>
