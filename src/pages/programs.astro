---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Figure from '../components/Figure.astro';
import groupImg from '../assets/illustrations/group-therapy.png';

const facts = [
  { num: '3–5', unit: 'days', label: 'Typical time from your first call to starting care.' },
  { num: '10–17', unit: 'ages', label: 'We work exclusively with adolescents — no adults.' },
  { num: '5', unit: 'insurers', label: 'In-network with BCBS, Cigna, Aetna, UHC & Tricare.' },
];

const phpDay = [
  ['9:00', 'Check-in & daily goals'],
  ['9:30', 'Process group therapy'],
  ['11:00', 'DBT skills group'],
  ['12:00', 'Lunch'],
  ['1:00', 'Individual / family session'],
  ['2:00', 'Academic support'],
  ['2:45', 'Reflection & wrap-up'],
];
const iopDay = [
  ['3:00', 'Check-in'],
  ['3:30', 'Process group therapy'],
  ['4:30', 'DBT skills group'],
  ['5:30', 'Individual / family session'],
  ['6:00', 'Close'],
];

const psychCare = [
  { title: 'Psychiatric evaluation', body: 'A thorough assessment by a child & adolescent psychiatrist embedded in the treatment team — not a separate referral.' },
  { title: 'Medication management', body: 'When medication helps, dosing is reviewed and adjusted carefully — always with your input. No changes happen without your knowledge.' },
  { title: 'Pharmacogenomic testing', body: 'Optional genetic testing that helps match the right medication faster, with fewer trial-and-error cycles.' },
  { title: 'Coordinated care', body: "Your teen's prescriber and therapists are on the same team and in the same conversation — every week." },
];
---
<Base
  title="Programs — PHP & IOP for teens | Joshua Tree Health"
  description="Evidence-based PHP and IOP for teens ages 10–17 in Apex, NC. Full-day or after-school intensive care, integrated psychiatric support, no waitlist."
>
  <PageHero
    eyebrow="Our programs"
    title="Two levels of care.<br>One team. <em>No waitlist.</em>"
    sub="Evidence-based PHP and IOP for teens ages 10–17 in Apex, NC. Structured intensive care that fits around your family — not the other way around."
    primaryCta={{ label: 'Start the Conversation', href: '/admissions' }}
    secondaryCta={{ label: 'Check your insurance', href: '/insurance' }}
  />

  <!-- Facts -->
  <section class="section section--tight surface-cream-deep" aria-label="Program facts">
    <div class="container-x">
      <div class="grid-3" data-reveal-group>
        {facts.map((f) => (
          <div class="stat" data-reveal-item>
            <span class="stat__num font-display">{f.num}<span class="stat__unit">{f.unit}</span></span>
            <span class="stat__label">{f.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PHP -->
  <section class="section" id="php" aria-labelledby="php-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Partial Hospitalization · PHP</p>
        <h2 class="section-title font-display" id="php-title">Full-day care. Home each evening.</h2>
        <p class="section-sub">Structured daily care for teens who need more than therapy — intensive enough to matter, and light enough to keep your family together each night.</p>
      </div>
      <div class="split">
        <div data-reveal>
          <p class="prog-sched"><span>Five days a week</span><span class="dot">·</span><span>9am – 3pm</span></p>
          <div class="cols-2">
            <div>
              <h3 class="mini-head">What's included</h3>
              <ul class="checklist">
                <li>Group &amp; individual therapy</li>
                <li>DBT skills for real life</li>
                <li>Weekly family sessions</li>
                <li>On-site academic support</li>
                <li>Integrated psychiatric care</li>
              </ul>
            </div>
            <div>
              <h3 class="mini-head">A good fit when</h3>
              <ul class="checklist">
                <li>Weekly therapy isn't enough</li>
                <li>They're in crisis but safe to come home each evening</li>
                <li>Stepping down from inpatient or a hospital stay</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="schedule card" data-reveal data-reveal-delay="0.08">
          <p class="schedule__head">A day in PHP</p>
          <ul class="schedule__list">
            {phpDay.map(([t, a]) => (
              <li class="schedule__row"><span class="schedule__time">{t}</span><span class="schedule__act">{a}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- IOP -->
  <section class="section surface-cream-deep" id="iop" aria-labelledby="iop-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Intensive Outpatient · IOP</p>
        <h2 class="section-title font-display" id="iop-title">After school. Life stays intact.</h2>
        <p class="section-sub">Three afternoons a week, teens stay in school, stay at home, and stay connected to their lives — while getting the intensive support they actually need.</p>
      </div>
      <div class="split split--reverse">
        <div data-reveal>
          <p class="prog-sched"><span>Three afternoons a week</span><span class="dot">·</span><span>3 – 6pm</span></p>
          <div class="cols-2">
            <div>
              <h3 class="mini-head">What's included</h3>
              <ul class="checklist">
                <li>Group &amp; individual therapy</li>
                <li>DBT skills for real life</li>
                <li>Family sessions</li>
                <li>Integrated psychiatric care</li>
              </ul>
            </div>
            <div>
              <h3 class="mini-head">A good fit when</h3>
              <ul class="checklist">
                <li>They need intensive support but they're ready to stay in school</li>
                <li>Stepping down from PHP</li>
                <li>More than weekly therapy can hold</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="schedule card" data-reveal data-reveal-delay="0.08">
          <p class="schedule__head">An afternoon in IOP</p>
          <ul class="schedule__list">
            {iopDay.map(([t, a]) => (
              <li class="schedule__row"><span class="schedule__time">{t}</span><span class="schedule__act">{a}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Group therapy -->
  <section class="section" aria-labelledby="group-title">
    <div class="container-x">
      <div class="split">
        <div data-reveal data-reveal-delay="0.08">
          <Figure src={groupImg} alt="Illustration of teens sitting together in a group therapy circle with plants and cushions" />
        </div>
        <div data-reveal>
          <p class="eyebrow">The heart of it</p>
          <h2 class="section-title font-display" id="group-title">Group is where it clicks.</h2>
          <p class="section-sub">Most of the real change happens in group — teens realizing they're not the only one, practicing skills with people who actually get it, and building peer support that sticks. Structured, safe, and led by clinicians who keep it real.</p>
          <ul class="checklist" style="margin-top:1.5rem;">
            <li>Small, age-matched groups</li>
            <li>DBT skills you can use that night</li>
            <li>Led by licensed clinicians</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrated psychiatric care -->
  <section class="section" aria-labelledby="psych-title">
    <div class="container-x">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Integrated Psychiatric Care</p>
        <h2 class="section-title font-display" id="psych-title">Therapy and prescribing, on the same team.</h2>
        <p class="section-sub">For teens who benefit from psychiatric evaluation and medication support — embedded in the treatment plan, not a separate referral.</p>
      </div>
      <div class="grid-4" data-reveal-group>
        {psychCare.map((c) => (
          <article class="info-card info-card--hover" data-reveal-item>
            <h3 class="info-card__title">{c.title}</h3>
            <p class="info-card__body">{c.body}</p>
          </article>
        ))}
      </div>
      <p class="programs__insurance" data-reveal>
        Covered by most major insurance plans — in-network with BCBS, Cigna, Aetna, UHC, and Tricare.
        We verify your benefits before you start, so there are no surprises.
      </p>
    </div>
  </section>
</Base>

<style>
  .section--tight { padding-block: clamp(2.5rem, 2rem + 3vw, 4rem); }
  .prog-sched { font-family: var(--font-mono); font-size: 0.9rem; color: var(--color-pine); display: flex; gap: 0.5em; align-items: center; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .prog-sched .dot { opacity: 0.4; }
  .mini-head { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-sage); margin-bottom: 0.8rem; }
  .cols-2 { display: grid; grid-template-columns: 1fr; gap: 1.6rem; }

  .schedule { padding: clamp(1.4rem, 1rem + 1.5vw, 2rem); }
  .schedule__head { font-family: var(--font-head); font-weight: 600; font-size: 1.05rem; color: var(--color-deep-green); margin-bottom: 1rem; }
  .schedule__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.1rem; }
  .schedule__row { display: grid; grid-template-columns: 4rem 1fr; gap: 1rem; align-items: baseline; padding: 0.6rem 0; border-top: 1px solid var(--color-line); }
  .schedule__row:first-child { border-top: 0; }
  .schedule__time { font-family: var(--font-mono); font-size: 0.82rem; color: var(--color-lime-deep); font-weight: 500; }
  .schedule__act { font-size: 0.95rem; color: var(--color-ink-soft); }

  .programs__insurance {
    margin-top: clamp(1.75rem, 1rem + 2vw, 2.75rem);
    font-size: 0.96rem; line-height: 1.55; color: var(--color-ink-soft);
    max-width: 54rem; padding: 1.1rem 1.4rem;
    border-left: 3px solid var(--color-lime);
    background: var(--color-cream-deep);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  @media (min-width: 560px) { .cols-2 { grid-template-columns: 1fr 1fr; } }
</style>
