---
import Base from '../layouts/Base.astro';

const resources = [
  { tag: 'Call or text, 24/7', name: '988 Suicide & Crisis Lifeline', detail: 'Call or text 988 to reach a trained crisis counselor. Free, confidential, and available 24/7.', actions: [{ label: 'Call 988', href: 'tel:988' }, { label: 'Text 988', href: 'sms:988' }] },
  { tag: 'Text support, 24/7', name: 'Crisis Text Line', detail: 'Text HOME to 741741 to connect with a crisis counselor by text. Free, confidential, and available 24/7.', actions: [{ label: 'Text HOME to 741741', href: 'sms:741741?&body=HOME' }] },
  { tag: 'Immediate danger', name: 'Call 911', detail: 'If your teen is in immediate physical danger or you cannot keep them safe, call 911 or go to the nearest emergency room.', actions: [{ label: 'Call 911', href: 'tel:911' }] },
];
---
<Base
  bodyClass="brand-page rollout-page"
  title="Crisis Resources | Joshua Tree Health"
  description="If you or your teen is in crisis, call or text 988, or text HOME to 741741. For immediate danger, call 911. Free, confidential, available 24/7."
>
  <section class="crisis-hero" aria-labelledby="crisis-page-title">
    <div class="container-x">
      <h1 id="crisis-page-title" class="font-display">If your teen is in crisis right now</h1>
      <p>Call or text 988 to reach the Suicide & Crisis Lifeline. If your teen is in immediate physical danger or you cannot keep them safe, call 911.</p>
    </div>
  </section>

  <section class="section" aria-labelledby="crisis-lines-title">
    <div class="container-x">
      <h2 id="crisis-lines-title" class="section-title font-display">Where to get help right now</h2>
      <div class="grid-2">
        {resources.map((r) => (
          <article class="crisis-card">
            <p class="crisis-card__tag">{r.tag}</p>
            <h3 class="crisis-card__name font-display">{r.name}</h3>
            <p class="crisis-card__detail">{r.detail}</p>
            <div class="crisis-card__actions">
              {r.actions.map((action) => <a href={action.href} class="btn crisis-card__btn">{action.label}</a>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section surface-cream-deep" aria-labelledby="crisis-steps-title">
    <div class="container-x prose">
      <h2 id="crisis-steps-title">What to do if your teen is in crisis</h2>
      <ul>
        <li>Stay with them.</li>
        <li>Remove access to means of self-harm if you can do so safely.</li>
        <li>Call or text 988. They will help you decide next steps.</li>
        <li>If your teen is in immediate danger, call 911 or go to your nearest emergency room.</li>
      </ul>
      <h2>Need support soon?</h2>
      <p>If your teen is struggling but not in immediate danger, Joshua Tree Health may be the right next step. We provide PHP and IOP programs for adolescents ages 10–17 in Apex, North Carolina. These are outpatient programs and do not replace emergency or inpatient care.</p>
      <p><a class="btn" href="/get-started">Get started</a> <a class="link-arrow" href="tel:+19193355053">Call (919) 335-5053</a></p>
    </div>
  </section>
</Base>

<style>
  .crisis-hero { padding-block: clamp(3rem, 7vw, 6rem); background: var(--color-deep-green); color: var(--color-cream); }
  .crisis-hero h1 { max-width: 15ch; font-size: clamp(3rem, 6vw, 6rem); line-height: .96; letter-spacing: -.045em; }
  .crisis-hero > div > p:last-child { max-width: 48rem; margin-top: 1.5rem; color: var(--color-cream-dim); font-size: clamp(1.15rem, 2vw, 1.45rem); line-height: 1.5; }
  #crisis-lines-title {
    color: var(--color-deep-green);
    margin-bottom: clamp(1.5rem, 1rem + 2vw, 2.5rem);
  }
  .crisis-card {
    background: var(--color-cream-card);
    border: 1px solid var(--color-line);
    border-left: 4px solid var(--color-lime);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 1rem + 2vw, 2.25rem);
    display: flex; flex-direction: column; gap: 0.7rem; align-items: flex-start;
  }
  .crisis-card__tag { font-family: var(--font-mono); font-size: 0.95rem; line-height: 1.15; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-deep-sage); }
  .crisis-card__name { font-size: clamp(1.4rem, 1.1rem + 1.2vw, 1.9rem); color: var(--color-deep-green); }
  .crisis-card__detail { color: var(--color-ink-soft); font-size: 1.0625rem; line-height: 1.62; }
  .crisis-card__actions { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: .6rem; }
  .crisis-card__btn { margin-top: 0.6rem; }
  .crisis-card__actions .crisis-card__btn { margin-top: 0; }
</style>
