---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const resources = [
  { tag: 'Immediate danger', name: 'Call 911', detail: 'If your teen is in immediate physical danger, call 911 or go to your nearest emergency room.', action: 'Call 911', href: 'tel:911' },
  { tag: '24/7 · free · confidential', name: '988 Suicide & Crisis Lifeline', detail: 'Call or text 988 to reach trained counselors any time, day or night.', action: 'Call or text 988', href: 'tel:988' },
  { tag: 'Text support', name: 'Crisis Text Line', detail: 'Text HOME to 741741 to connect with a crisis counselor by text.', action: 'Text HOME to 741741', href: 'sms:741741' },
  { tag: 'Non-emergency', name: 'Joshua Tree Health', detail: 'For admissions or questions during business hours, our team is here for you.', action: 'Call (919) 335-5053', href: 'tel:+19193355053' },
];
---
<Base
  title="Crisis Resources | Joshua Tree Health"
  description="If you or your teen is in crisis: call 911 for emergencies, call or text 988 for the Suicide & Crisis Lifeline, or text HOME to 741741. Free, confidential, 24/7."
>
  <PageHero
    variant="green"
    eyebrow="Crisis resources"
    title="In a crisis, you're <em>not alone</em>."
    sub="If you or your teen is in immediate danger, call 911. For urgent mental health support, these lines are free, confidential, and available 24/7."
  />

  <section class="section" aria-label="Crisis resources">
    <div class="container-x">
      <div class="grid-2" data-reveal-group>
        {resources.map((r) => (
          <article class="crisis-card" data-reveal-item>
            <p class="crisis-card__tag">{r.tag}</p>
            <h2 class="crisis-card__name font-display">{r.name}</h2>
            <p class="crisis-card__detail">{r.detail}</p>
            <a href={r.href} class="btn crisis-card__btn">{r.action}</a>
          </article>
        ))}
      </div>
      <p class="crisis-foot" data-reveal>
        You are not a burden, and reaching out is not an overreaction. If you're not sure how serious it is, treat it as serious. Help is always worth the call.
      </p>
    </div>
  </section>
</Base>

<style>
  .crisis-card {
    background: var(--color-cream-card);
    border: 1px solid var(--color-line);
    border-left: 4px solid var(--color-lime);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 1rem + 2vw, 2.25rem);
    display: flex; flex-direction: column; gap: 0.7rem; align-items: flex-start;
  }
  .crisis-card__tag { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-sage); }
  .crisis-card__name { font-size: clamp(1.4rem, 1.1rem + 1.2vw, 1.9rem); color: var(--color-deep-green); }
  .crisis-card__detail { color: var(--color-ink-soft); line-height: 1.55; }
  .crisis-card__btn { margin-top: 0.6rem; }
  .crisis-foot { margin-top: clamp(2rem, 1.5rem + 2vw, 3rem); max-width: 46rem; font-size: var(--text-body-l); line-height: 1.6; color: var(--color-pine); font-family: var(--font-display); }
</style>
