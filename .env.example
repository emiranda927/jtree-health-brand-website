# Public (client-exposed) config for the marketing site.
# Copy to .env and set as needed. All are safe to expose to the browser.

# Google Tag Manager container (analytics). Existing container: GTM-WGCMNLXH
PUBLIC_GTM_ID=GTM-WGCMNLXH

# Live form API (jtree-form-api on Vercel). Do not change unless the API moves.
PUBLIC_INQUIRY_API_URL=https://api.jtreehealth.com/api/inquiry

# Cloudflare Turnstile SITE key (public half). Leave blank to disable the widget
# in dev/preview — the API verifier falls open when no token is present.
PUBLIC_TURNSTILE_SITE_KEY=
