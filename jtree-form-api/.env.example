# Ritten CRM — full endpoint URL + Bearer token.
# Leave both blank to skip Ritten and write directly to Google Sheets.
# Examples:
#   RITTEN_API_URL=https://api.ritten.io/v1/contacts
#   RITTEN_API_URL=https://hooks.keragon.com/<workflow-id>
RITTEN_API_KEY=
RITTEN_API_URL=

# Resend transactional email
RESEND_API_KEY=
ADMISSIONS_EMAIL=admissions@jtreehealth.com
OWNER_ALERT_EMAIL=

# Supabase — intake CRM system of record. A submitted lead is inserted into the
# `clients` table and appears on the pipeline board immediately.
#   SUPABASE_URL              project URL, e.g. https://xxxx.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY service-role key (SERVER-ONLY SECRET — bypasses RLS;
#                             never put it in the site bundle or the browser).
# Leave both blank to skip Supabase and write only to Google Sheets.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets — best-effort mirror of the CRM (written in parallel with Supabase).
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional — unused by current rate limiter (in-memory). Reserved for future Upstash swap.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# CORS — comma-separated list of allowed front-end origins.
# Entries are matched as exact strings. Use a leading `*.` for a subdomain
# suffix match (e.g. `*.flywheelsites.com` matches any subdomain).
# Examples:
#   ALLOWED_ORIGINS=https://jtreehealth.com,https://www.jtreehealth.com
#   ALLOWED_ORIGINS=https://jtreehealth.com,http://jtree-local.local,*.flywheelsites.com
ALLOWED_ORIGINS=https://jtreehealth.com,https://www.jtreehealth.com

# Legacy single-origin variable. Still honored as a fallback when
# ALLOWED_ORIGINS is unset, so old deploys keep working. Prefer ALLOWED_ORIGINS.
# ALLOWED_ORIGIN=https://jtreehealth.com
